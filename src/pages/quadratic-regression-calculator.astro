---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import QuadraticRegressionCalculator from 'theme/components/QuadraticRegressionCalculator.astro';
import ToolInfoBox from 'theme/components/ToolInfoBox.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/quadratic-hero.png';

const locale = 'en';
const translations = await mergeTranslations(locale);
const qc = (translations as any).quadCalc;

const canonicalUrl = new URL('/quadratic-regression-calculator/', siteConfig.siteUrl).href;

const breadcrumb = qc?.breadcrumb || 'Back to Main Regression Calculator';

const whatIsTitle = qc?.whatIsTitle || 'How to Calculate Quadratic Regression';
const whatIsText = qc?.whatIsText || '';

const formulaTitle = qc?.formulaTitle || 'Quadratic Regression Formula Calculator Explained';
const formulaText = qc?.formulaText || '';
const formulaTable = qc?.formulaTable || '';
const formulas: string[] = qc?.formulas ?? [];

const howCalcTitle = qc?.howCalcTitle || 'How to Calculate Quadratic Regression';
const howCalcManual = qc?.howCalcManual || '';
const howCalcSteps: string[] = qc?.howCalcSteps ?? [];

const calcStepsTitle = qc?.calcStepsTitle || 'Quadratic Regression Calculator Steps';
const calcStepsIntro = qc?.calcStepsIntro || '';
const calcStepsPoints: string[] = qc?.calcStepsPoints ?? [];

const tableDataTitle = qc?.tableDataTitle || 'Quadratic Regression Calculator from Table Data';
const tableDataIntro = qc?.tableDataIntro || '';
const tableDataTable = qc?.tableDataTable || '';
const tableDataSteps: string[] = qc?.tableDataSteps ?? [];

const vertexTitle = qc?.vertexTitle || 'Finding the Vertex of a Quadratic Regression';
const vertexText = qc?.vertexText || '';
const vertexPoints: string[] = qc?.vertexPoints ?? [];

const howDoTitle = qc?.howDoTitle || 'How to Do Quadratic Regression on Calculator';
const howDoIntro = qc?.howDoIntro || '';
const howDoTi84 = qc?.howDoTi84 || 'TI-84 Plus';
const howDoTi84Steps: string[] = qc?.howDoTi84Steps ?? [];
const howDoTi83 = qc?.howDoTi83 || 'TI-83 Plus';
const howDoTi83Steps: string[] = qc?.howDoTi83Steps ?? [];
const howDoCasio = qc?.howDoCasio || 'Casio fx-9860GII';
const howDoCasioSteps: string[] = qc?.howDoCasioSteps ?? [];
const howDoTiNspire = qc?.howDoTiNspire || 'TI-Nspire';
const howDoTiNspireSteps: string[] = qc?.howDoTiNspireSteps ?? [];
const howDoNote = qc?.howDoNote || '';

const graphCalcTitle = qc?.graphCalcTitle || 'Quadratic Regression on Graphing Calculator';
const graphCalcIntro = qc?.graphCalcIntro || '';
const graphCalcSteps: string[] = qc?.graphCalcSteps ?? [];

const whenTitle = qc?.whenTitle || 'When to Use Quadratic Regression';
const whenText = qc?.whenText || '';
const whenTable = qc?.whenTable || '';
const whenPoints: string[] = qc?.whenPoints ?? [];
const avoidTitle = qc?.avoidTitle || 'When to Avoid Quadratic Regression';
const avoidPoints: string[] = qc?.avoidPoints ?? [];

const faqTitle = qc?.faqTitle || 'Frequently Asked Questions';
const faqs: Array<{q: string; a: string}> = qc?.faqs ?? [];

const relatedTitle = qc?.relatedTitle || 'Related Regression Calculators';
const relatedItems: Array<{name: string; url: string; desc: string}> = qc?.relatedItems ?? [];

const fmHeaders = formulaTable ? formulaTable.split('|').slice(0, 3) : [];
const fmRows: string[][] = [];
if (formulaTable) {
  const fmParts = formulaTable.split('|');
  for (let i = 3; i + 2 < fmParts.length; i += 3) {
    fmRows.push([fmParts[i], fmParts[i+1], fmParts[i+2]]);
  }
}

const wnHeaders = whenTable ? whenTable.split('|').slice(0, 3) : [];
const wnRows: string[][] = [];
if (whenTable) {
  const wnParts = whenTable.split('|');
  for (let i = 3; i + 2 < wnParts.length; i += 3) {
    wnRows.push([wnParts[i], wnParts[i+1], wnParts[i+2]]);
  }
}

const tdHeaders = tableDataTable ? tableDataTable.split('|').slice(0, 5) : [];
const tdRows: string[][] = [];
if (tableDataTable) {
  const tdParts = tableDataTable.split('|');
  for (let i = 5; i + 4 < tdParts.length; i += 5) {
    tdRows.push([tdParts[i], tdParts[i+1], tdParts[i+2], tdParts[i+3], tdParts[i+4]]);
  }
}

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Quadratic Regression Calculator",
  "description": "Free online quadratic regression calculator. Compute y = ax² + bx + c with coefficients, R², vertex, and step-by-step solution.",
  "url": "https://www.regressionequationcalculator.com/quadratic-regression-calculator/",
  "applicationCategory": "MathCalculator",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": ["Step-by-step solutions", "R² calculation", "Vertex computation", "Table input", "Prediction forecasting", "Coefficient analysis"]
};

const faqSchema = faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: { '@type': 'Answer', text: faq.a },
      })),
    }
  : null;

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Calculate Quadratic Regression",
  "description": "Step-by-step guide to calculating quadratic regression from your data",
  "totalTime": "PT5M",
  "step": [
    { "@type": "HowToStep", "name": "Enter Data", "text": "Input your X and Y data pairs. You need at least 3 points." },
    { "@type": "HowToStep", "name": "Compute Sums", "text": "Calculate Σx, Σx², Σx³, Σx⁴, Σy, Σxy, Σx²y." },
    { "@type": "HowToStep", "name": "Solve System", "text": "Solve the 3×3 normal equations for coefficients a, b, c." },
    { "@type": "HowToStep", "name": "Find Vertex", "text": "Calculate vertex at x = −b/(2a) and evaluate ŷ at that point." },
    { "@type": "HowToStep", "name": "Evaluate Fit", "text": "Compute R² = 1 − SSres/SStot to assess goodness of fit." },
    { "@type": "HowToStep", "name": "Make Predictions", "text": "Use ŷ = ax² + bx + c to predict Y for new X values." }
  ]
};
---

<BaseLayout
  title={qc?.title || "Quadratic Regression Calculator — Calculate y = ax² + bx + c"}
  description={qc?.description || "Free online quadratic regression calculator. Compute y = ax² + bx + c with coefficients, R², and step-by-step solution."}
  locale={locale}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-1/4 right-1/4 w-[450px] h-[450px] bg-emerald-100/30 dark:bg-emerald-900/10 blur-[110px] rounded-full animate-pulse"></div>
      <div class="absolute bottom-1/4 left-1/4 w-[380px] h-[380px] bg-primary-100/30 dark:bg-primary-900/10 blur-[100px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 text-center lg:text-left reveal-on-scroll">
          <nav class="mb-6 text-sm font-medium flex items-center justify-center lg:justify-start gap-2">
            <a href="/" class="text-surface-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
          </nav>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-emerald-700 via-primary-600 to-accent-600 dark:from-emerald-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight mb-6">
            Quadratic Regression Calculator
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-8">
            Solve complex parabolic models with ease. Calculate vertex coordinates, coefficient precision, and goodness-of-fit metrics for any dataset.
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="#calculator-tool" class="px-8 py-3 rounded-xl bg-emerald-600 text-white font-semibold shadow-lg shadow-emerald-600/20 hover:bg-emerald-700 hover:shadow-xl hover:shadow-emerald-600/30 transition-all duration-300 hover:-translate-y-1">
              Analyze Data
            </a>
            <a href="#how-to" class="px-8 py-3 rounded-xl bg-white dark:bg-surface-800 text-surface-700 dark:text-surface-200 font-semibold border border-surface-200 dark:border-surface-700 hover:border-emerald-300 transition-all duration-300 hover:-translate-y-1">
              View Guide
            </a>
          </div>
        </div>
        <div class="flex-1 w-full max-w-lg lg:max-w-none reveal-on-scroll" style="transition-delay: 200ms">
          <div class="relative group" data-tilt>
            <div class="absolute -inset-4 bg-gradient-to-r from-emerald-500/20 to-primary-500/20 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-500"></div>
            <div class="relative overflow-hidden rounded-3xl border border-white/20 shadow-2xl">
              <Image
                src={heroImage}
                alt="Quadratic Curve Visualization"
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                width={800}
                densities={[1, 2]}
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/20 via-transparent to-transparent opacity-40"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator Tool -->
  <section id="calculator-tool" class="py-12 md:py-16 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <QuadraticRegressionCalculator translations={translations} />
    </div>
  </section>

  <!-- Tool Info Box -->
  <ToolInfoBox
    toolName="Quadratic Regression Calculator"
    keyPoints={[
      {
        icon: "📐",
        title: "Curve Fitting",
        description: "Fits a parabolic (y = ax² + bx + c) model to your data."
      },
      {
        icon: "📥",
        title: "Enter Data Points",
        description: "Input X and Y values as comma-separated pairs or pasted columns."
      },
      {
        icon: "📊",
        title: "Equation & Metrics",
        description: "Get the quadratic equation, R², vertex, and predicted values."
      },
      {
        icon: "🔬",
        title: "Best For",
        description: "Data with curvature — projectile motion, growth rates, pricing models."
      }
    ]}
    highlightTip="Compare quadratic R² with linear R² to confirm that a curve genuinely fits better than a straight line."
  />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-12 py-16">
    <!-- H2: What Is Quadratic Regression -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity">
            <svg class="w-32 h-32 text-emerald-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-emerald-600 rounded-full"></span>
          {whatIsTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg" set:html={whatIsText} />
      </div>
    </section>

    <!-- H2: Formula -->
    <section id="how-to" class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-accent-600 rounded-full"></span>
          {formulaTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={formulaText} />

        {fmRows.length > 0 && (
          <div class="overflow-hidden mb-8 rounded-2xl border border-surface-200 dark:border-surface-700/50 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gradient-to-r from-accent-600 to-accent-500 dark:from-accent-800 dark:to-accent-700">
                  {fmHeaders.map((h) => (
                    <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                {fmRows.map((row) => (
                  <tr class="hover:bg-accent-50/20 dark:hover:bg-accent-900/10 transition-colors">
                    {row.map((cell) => (
                      <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400 font-medium">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        <div class="grid sm:grid-cols-2 gap-4">
          {formulas.map((f, i) => (
            <div class="group flex items-start gap-4 p-4 rounded-xl bg-surface-50/50 dark:bg-surface-900/40 border border-surface-100 dark:border-surface-700/40 hover:border-accent-300 dark:hover:border-accent-700 transition-all duration-300">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center text-sm font-bold text-accent-700 dark:text-accent-400 group-hover:scale-110 transition-transform">{i + 1}</span>
              <span class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed pt-1" set:html={f} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- H2: Calculation Guide -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-primary-600 rounded-full"></span>
          {howCalcTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={howCalcManual} />
        <div class="space-y-6">
          {howCalcSteps.map((step, i) => (
            <div class="flex gap-5 group">
                <div class="flex-shrink-0 flex flex-col items-center">
                    <span class="w-10 h-10 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-primary-700 dark:text-primary-400 font-bold group-hover:scale-110 transition-transform">{i + 1}</span>
                    {i < howCalcSteps.length - 1 && <div class="w-0.5 h-full bg-surface-100 dark:bg-surface-700/50 mt-2"></div>}
                </div>
                <div class="pb-6">
                    <div class="text-base text-surface-600 dark:text-surface-400 leading-relaxed pt-1.5" set:html={step} />
                </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Vertex & Table Data -->
    <section class="reveal-on-scroll">
        <div class="grid md:grid-cols-2 gap-8">
          <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
              <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                  <svg class="w-6 h-6 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                  {vertexTitle}
              </h2>
              <div class="prose prose-surface max-w-none text-sm text-surface-600 dark:text-surface-400 mb-6" set:html={vertexText} />
              <ul class="space-y-3">
                {vertexPoints.map((point, i) => (
                  <li class="flex items-start gap-3 p-3 rounded-xl bg-violet-50/50 dark:bg-violet-900/10 border border-violet-100/50 dark:border-violet-800/30">
                    <span class="flex-shrink-0 w-6 h-6 rounded-lg bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center text-xs font-bold text-violet-700 dark:text-violet-400">{i + 1}</span>
                    <p class="text-sm text-surface-700 dark:text-surface-300" set:html={point} />
                  </li>
                ))}
              </ul>
          </div>
  
          <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
              <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                  <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  {tableDataTitle}
              </h2>
              <p class="text-sm text-surface-500 dark:text-surface-400 mb-6">{tableDataIntro}</p>
              {tdRows.length > 0 && (
                <div class="overflow-hidden mb-6 rounded-xl border border-surface-200 dark:border-surface-700/50">
                  <table class="w-full text-[10px] sm:text-xs">
                    <thead class="bg-amber-600 text-white">
                      <tr>
                        {tdHeaders.map(h => <th class="px-2 py-2 text-left font-bold">{h}</th>)}
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                      {tdRows.map(row => (
                        <tr class="hover:bg-amber-50/20 dark:hover:bg-amber-900/10">
                          {row.map(cell => <td class="px-2 py-2 text-surface-600 dark:text-surface-400">{cell}</td>)}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
              <ol class="space-y-2 list-decimal list-inside text-sm text-surface-600 dark:text-surface-400">
                {tableDataSteps.map(step => <li set:html={step} />)}
              </ol>
          </div>
        </div>
      </section>

    <!-- Graphing Calculator Guide -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
          <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-8 text-center">{howDoTitle}</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
              {[
                { title: howDoTi84, steps: howDoTi84Steps, color: 'rose' },
                { title: howDoTi83, steps: howDoTi83Steps, color: 'blue' },
                { title: howDoCasio, steps: howDoCasioSteps, color: 'indigo' },
                { title: howDoTiNspire, steps: howDoTiNspireSteps, color: 'violet' }
              ].map(calc => (
                <div class="space-y-4">
                    <h3 class={`text-base font-bold text-${calc.color}-600 dark:text-${calc.color}-400 mb-2`}>{calc.title}</h3>
                    <ul class="space-y-2">
                        {calc.steps.map(step => (
                            <li class="text-sm text-surface-600 dark:text-surface-400 flex items-start gap-2">
                                <span class={`text-${calc.color}-500 mt-1.5 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-current`}></span>
                                <span set:html={step} />
                            </li>
                        ))}
                    </ul>
                </div>
              ))}
          </div>
          <div class="mt-8 pt-6 border-t border-surface-100 dark:border-surface-700 text-center">
            <p class="text-xs text-surface-500 dark:text-surface-400 italic" set:html={howDoNote} />
          </div>
      </div>
    </section>

    <!-- When to Use Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg relative overflow-hidden group">
                <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-6">{whenTitle}</h2>
                <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 mb-8" set:html={whenText} />
                <div class="grid gap-4">
                  {whenPoints.map(point => (
                    <div class="flex items-start gap-4 p-4 rounded-2xl bg-emerald-50/50 dark:bg-emerald-900/10 border border-emerald-100/50 dark:border-emerald-800/30 hover:shadow-md transition-shadow">
                        <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-600 dark:text-emerald-400 flex-shrink-0">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <p class="text-sm text-surface-700 dark:text-surface-300" set:html={point} />
                    </div>
                  ))}
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50 text-center mb-10">{faqTitle}</h2>
            <div class="space-y-4">
                {faqs.map((faq, i) => (
                    <details class="group rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm overflow-hidden hover:shadow-lg transition-all duration-300">
                        <summary class="flex items-center justify-between px-6 py-5 cursor-pointer text-base font-bold text-surface-800 dark:text-surface-200 hover:text-emerald-600 transition-colors list-none">
                            <span>{faq.q}</span>
                            <div class="w-8 h-8 rounded-full bg-surface-50 dark:bg-surface-900/50 flex items-center justify-center group-open:rotate-180 transition-transform">
                                <svg class="w-4 h-4 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </summary>
                        <div class="px-6 pb-6 text-base text-surface-600 dark:text-surface-400 leading-relaxed border-t border-surface-100 dark:border-surface-700/50 pt-4" set:html={faq.a} />
                    </details>
                ))}
            </div>
        </div>
    </section>

    <!-- Related Calculators -->
    <section class="reveal-on-scroll">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50">{relatedTitle}</h2>
        <p class="text-surface-500 mt-2">Discover more specialized regression modeling tools.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {relatedItems.map((item, i) => {
          const themes = [
            { accent: 'accent', icon: '📈' },
            { accent: 'primary', icon: '📐' },
            { accent: 'emerald', icon: '🧬' },
            { accent: 'violet', icon: '🔮' },
            { accent: 'cyan', icon: '🔬' },
            { accent: 'rose', icon: '📍' },
          ];
          const t = themes[i % themes.length];
          return (
            <a href={item.url} class="group/card relative p-6 rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 overflow-hidden">
              <div class={`absolute inset-0 bg-gradient-to-br from-${t.accent}-500/0 to-${t.accent}-500/0 group-hover/card:from-${t.accent}-500/5 group-hover/card:to-${t.accent}-500/10 transition-all duration-500`}></div>
              <div class="relative z-10">
                <div class={`w-12 h-12 rounded-xl bg-${t.accent}-100 dark:bg-${t.accent}-900/30 flex items-center justify-center mb-4 group-hover/card:scale-110 transition-transform duration-300 text-xl`}>
                  {t.icon}
                </div>
                <h3 class={`text-lg font-bold text-${t.accent}-700 dark:text-${t.accent}-400 mb-2`}>{item.name}</h3>
                <p class="text-sm text-surface-500 dark:text-surface-400">{item.desc}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // ── Reveal on Scroll (IntersectionObserver) ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── Interactive 3D Tilt Effect (Optimized) ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    let rect: DOMRect | null = null;
    el.addEventListener('mouseenter', () => { rect = el.getBoundingClientRect(); });
    el.addEventListener('mousemove', (e: MouseEvent) => {
      if (!rect) rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -10;
      const rotateY = ((x - centerX) / centerX) * 10;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave', () => {
      rect = null;
      el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
