---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import QuadraticRegressionCalculator from 'theme/components/QuadraticRegressionCalculator.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

const locale = 'en';
const translations = await mergeTranslations(locale);
const qc = (translations as any).quadCalc;

const canonicalUrl = new URL('/quadratic-regression-calculator/', siteConfig.siteUrl).href;

const breadcrumb = qc?.breadcrumb || 'Back to Main Regression Calculator';
const introText = qc?.introText || '';

const whatIsTitle = qc?.whatIsTitle || 'How to Calculate Quadratic Regression';
const whatIsText = qc?.whatIsText || '';

const formulaTitle = qc?.formulaTitle || 'Quadratic Regression Formula Calculator Explained';
const formulaText = qc?.formulaText || '';
const formulaTable = qc?.formulaTable || '';
const formulas: string[] = qc?.formulas ?? [];

const howCalcTitle = qc?.howCalcTitle || 'How to Calculate Quadratic Regression';
const howCalcManual = qc?.howCalcManual || '';
const howCalcSteps: string[] = qc?.howCalcSteps ?? [];

const calcStepsTitle = qc?.calcStepsTitle || 'Quadratic Regression Calculator Steps';
const calcStepsIntro = qc?.calcStepsIntro || '';
const calcStepsPoints: string[] = qc?.calcStepsPoints ?? [];

const tableDataTitle = qc?.tableDataTitle || 'Quadratic Regression Calculator from Table Data';
const tableDataIntro = qc?.tableDataIntro || '';
const tableDataTable = qc?.tableDataTable || '';
const tableDataSteps: string[] = qc?.tableDataSteps ?? [];

const vertexTitle = qc?.vertexTitle || 'Finding the Vertex of a Quadratic Regression';
const vertexText = qc?.vertexText || '';
const vertexPoints: string[] = qc?.vertexPoints ?? [];

const howDoTitle = qc?.howDoTitle || 'How to Do Quadratic Regression on Calculator';
const howDoIntro = qc?.howDoIntro || '';
const howDoTi84 = qc?.howDoTi84 || 'TI-84 Plus';
const howDoTi84Steps: string[] = qc?.howDoTi84Steps ?? [];
const howDoTi83 = qc?.howDoTi83 || 'TI-83 Plus';
const howDoTi83Steps: string[] = qc?.howDoTi83Steps ?? [];
const howDoCasio = qc?.howDoCasio || 'Casio fx-9860GII';
const howDoCasioSteps: string[] = qc?.howDoCasioSteps ?? [];
const howDoTiNspire = qc?.howDoTiNspire || 'TI-Nspire';
const howDoTiNspireSteps: string[] = qc?.howDoTiNspireSteps ?? [];
const howDoNote = qc?.howDoNote || '';

const graphCalcTitle = qc?.graphCalcTitle || 'Quadratic Regression on Graphing Calculator';
const graphCalcIntro = qc?.graphCalcIntro || '';
const graphCalcSteps: string[] = qc?.graphCalcSteps ?? [];

const whenTitle = qc?.whenTitle || 'When to Use Quadratic Regression';
const whenText = qc?.whenText || '';
const whenTable = qc?.whenTable || '';
const whenPoints: string[] = qc?.whenPoints ?? [];
const avoidTitle = qc?.avoidTitle || 'When to Avoid Quadratic Regression';
const avoidPoints: string[] = qc?.avoidPoints ?? [];

const faqTitle = qc?.faqTitle || 'Frequently Asked Questions';
const faqs: Array<{q: string; a: string}> = qc?.faqs ?? [];

const relatedTitle = qc?.relatedTitle || 'Related Regression Calculators';
const relatedItems: Array<{name: string; url: string; desc: string}> = qc?.relatedItems ?? [];

const fmHeaders = formulaTable ? formulaTable.split('|').slice(0, 3) : [];
const fmRows: string[][] = [];
if (formulaTable) {
  const fmParts = formulaTable.split('|');
  for (let i = 3; i + 2 < fmParts.length; i += 3) {
    fmRows.push([fmParts[i], fmParts[i+1], fmParts[i+2]]);
  }
}

const wnHeaders = whenTable ? whenTable.split('|').slice(0, 3) : [];
const wnRows: string[][] = [];
if (whenTable) {
  const wnParts = whenTable.split('|');
  for (let i = 3; i + 2 < wnParts.length; i += 3) {
    wnRows.push([wnParts[i], wnParts[i+1], wnParts[i+2]]);
  }
}

const tdHeaders = tableDataTable ? tableDataTable.split('|').slice(0, 5) : [];
const tdRows: string[][] = [];
if (tableDataTable) {
  const tdParts = tableDataTable.split('|');
  for (let i = 5; i + 4 < tdParts.length; i += 5) {
    tdRows.push([tdParts[i], tdParts[i+1], tdParts[i+2], tdParts[i+3], tdParts[i+4]]);
  }
}

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Quadratic Regression Calculator",
  "description": "Free online quadratic regression calculator. Compute y = ax² + bx + c with coefficients, R², vertex, and step-by-step solution.",
  "url": "https://www.regressionequationcalculator.com/quadratic-regression-calculator/",
  "applicationCategory": "MathCalculator",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": ["Step-by-step solutions", "R² calculation", "Vertex computation", "Table input", "Prediction forecasting", "Coefficient analysis"]
};

const faqSchema = faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: { '@type': 'Answer', text: faq.a },
      })),
    }
  : null;

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Calculate Quadratic Regression",
  "description": "Step-by-step guide to calculating quadratic regression from your data",
  "totalTime": "PT5M",
  "step": [
    { "@type": "HowToStep", "name": "Enter Data", "text": "Input your X and Y data pairs. You need at least 3 points." },
    { "@type": "HowToStep", "name": "Compute Sums", "text": "Calculate Σx, Σx², Σx³, Σx⁴, Σy, Σxy, Σx²y." },
    { "@type": "HowToStep", "name": "Solve System", "text": "Solve the 3×3 normal equations for coefficients a, b, c." },
    { "@type": "HowToStep", "name": "Find Vertex", "text": "Calculate vertex at x = −b/(2a) and evaluate ŷ at that point." },
    { "@type": "HowToStep", "name": "Evaluate Fit", "text": "Compute R² = 1 − SSres/SStot to assess goodness of fit." },
    { "@type": "HowToStep", "name": "Make Predictions", "text": "Use ŷ = ax² + bx + c to predict Y for new X values." }
  ]
};
---

<BaseLayout
  title={qc?.title || "Quadratic Regression Calculator — Calculate y = ax² + bx + c"}
  description={qc?.description || "Free online quadratic regression calculator. Compute y = ax² + bx + c with coefficients, R², and step-by-step solution."}
  locale={locale}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- H1 + Intro -->
  <section class="py-10 md:py-14">
    <div class="max-w-3xl mx-auto text-center">
      <nav class="mb-4 text-sm text-surface-500 dark:text-surface-400">
        <a href="/" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
      </nav>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 via-primary-600 to-accent-600 dark:from-primary-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight">
        Quadratic Regression Calculator
      </h1>
      <p class="mt-5 text-lg md:text-xl text-surface-600 dark:text-surface-400 max-w-2xl mx-auto leading-relaxed">
        Calculate the quadratic regression equation y = ax² + bx + c with coefficients, R², and step-by-step solution
      </p>
    </div>
    <div class="max-w-3xl mx-auto mt-6">
      <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed" set:html={introText} />
    </div>
  </section>

  <!-- Calculator Tool -->
  <section class="py-8 md:py-12 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-3xl -mt-2">
    <div class="max-w-4xl mx-auto">
      <QuadraticRegressionCalculator translations={translations} />
    </div>
  </section>

  <!-- H2: What Is Quadratic Regression -->
  <section class="py-8 md:py-12">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200/60 dark:border-surface-700/40 bg-white/60 dark:bg-surface-800/40 backdrop-blur-sm p-6 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-r before:from-primary-500/0 before:to-accent-500/0 hover:before:from-primary-500/5 hover:before:to-accent-500/5 dark:hover:before:from-primary-400/8 dark:hover:before:to-accent-400/8 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-surface-950/40 hover:-translate-y-1 hover:border-primary-200 dark:hover:border-primary-700/50 transition-all duration-300">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-4">{whatIsTitle}</h2>
      <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed" set:html={whatIsText} />
    </div>
  </section>

  <!-- H2: Quadratic Regression Formula Calculator Explained -->
  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-accent-500/0 before:to-accent-500/0 hover:before:from-accent-500/5 hover:before:to-accent-500/8 dark:hover:before:from-accent-400/8 dark:hover:before:to-accent-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-accent-900/10 hover:-translate-y-1 hover:border-accent-300 dark:hover:border-accent-700/50 transition-all duration-300">
      <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-3">{formulaTitle}</h2>
      <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-4" set:html={formulaText} />
      {fmRows.length > 0 && (
        <div class="overflow-x-auto mb-5 rounded-lg border border-surface-200 dark:border-surface-700/50">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gradient-to-r from-accent-600 to-accent-500 dark:from-accent-800 dark:to-accent-700">
                {fmHeaders.map((h) => (
                  <th class="px-4 py-2 text-left text-xs font-semibold text-white uppercase tracking-wider">{h}</th>
                ))}
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
              {fmRows.map((row) => (
                <tr class="hover:bg-accent-50/30 dark:hover:bg-accent-900/10 transition-colors">
                  {row.map((cell) => (
                    <td class="px-4 py-2 text-surface-600 dark:text-surface-400">{cell}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
      {formulas.length > 0 && (
        <div class="space-y-2.5 mt-4">
          {formulas.map((f, i) => (
            <div class="flex items-start gap-3 px-4 py-2.5 rounded-lg bg-surface-50 dark:bg-surface-900/40 border border-surface-100 dark:border-surface-700/40">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center text-xs font-bold text-accent-700 dark:text-accent-400">{i + 1}</span>
              <span class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed" set:html={f} />
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- H2: How to Calculate Quadratic Regression -->
  <section class="py-8 md:py-12">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-primary-500/0 before:to-primary-500/0 hover:before:from-primary-500/5 hover:before:to-primary-500/8 dark:hover:before:from-primary-400/8 dark:hover:before:to-primary-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-primary-900/10 hover:-translate-y-1 hover:border-primary-300 dark:hover:border-primary-700/50 transition-all duration-300">
      <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{howCalcTitle}</h2>
      <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-5" set:html={howCalcManual} />
      {howCalcSteps.length > 0 && (
        <ol class="space-y-4 list-decimal list-inside">
          {howCalcSteps.map((step) => (
            <li class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={step} />
          ))}
        </ol>
      )}
    </div>
  </section>

  <!-- H2: Quadratic Regression Calculator Steps -->
  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-emerald-500/0 before:to-emerald-500/0 hover:before:from-emerald-500/5 hover:before:to-emerald-500/8 dark:hover:before:from-emerald-400/8 dark:hover:before:to-emerald-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-emerald-900/10 hover:-translate-y-1 hover:border-emerald-300 dark:hover:border-emerald-700/50 transition-all duration-300">
      <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-3">{calcStepsTitle}</h2>
      <p class="text-sm text-surface-500 dark:text-surface-400 mb-5">{calcStepsIntro}</p>
      <div class="space-y-4">
        {calcStepsPoints.map((point, i) => (
          <div class="flex items-start gap-3">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center text-xs font-bold text-emerald-700 dark:text-emerald-400">{i + 1}</span>
            <div class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- H2: Quadratic Regression Calculator from Table Data -->
  <section class="py-8 md:py-12">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-amber-500/0 before:to-amber-500/0 hover:before:from-amber-500/5 hover:before:to-amber-500/8 dark:hover:before:from-amber-400/8 dark:hover:before:to-amber-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-amber-900/10 hover:-translate-y-1 hover:border-amber-300 dark:hover:border-amber-700/50 transition-all duration-300">
      <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-3">{tableDataTitle}</h2>
      <p class="text-sm text-surface-500 dark:text-surface-400 mb-4">{tableDataIntro}</p>
      {tdRows.length > 0 && (
        <div class="overflow-x-auto mb-5 rounded-lg border border-surface-200 dark:border-surface-700/50">
          <table class="w-full text-xs">
            <thead>
              <tr class="bg-gradient-to-r from-amber-600 to-amber-500 dark:from-amber-800 dark:to-amber-700">
                {tdHeaders.map((h) => (
                  <th class="px-3 py-2 text-left font-semibold text-white uppercase tracking-wider">{h}</th>
                ))}
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
              {tdRows.map((row) => (
                <tr class="hover:bg-amber-50/30 dark:hover:bg-amber-900/10 transition-colors">
                  {row.map((cell) => (
                    <td class="px-3 py-2 text-surface-600 dark:text-surface-400">{cell}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
      {tableDataSteps.length > 0 && (
        <ol class="space-y-3 list-decimal list-inside">
          {tableDataSteps.map((step) => (
            <li class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={step} />
          ))}
        </ol>
      )}
    </div>
  </section>

  <!-- H2: Finding the Vertex -->
  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-violet-500/0 before:to-violet-500/0 hover:before:from-violet-500/5 hover:before:to-violet-500/8 dark:hover:before:from-violet-400/8 dark:hover:before:to-violet-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-violet-900/10 hover:-translate-y-1 hover:border-violet-300 dark:hover:border-violet-700/50 transition-all duration-300">
      <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-3">{vertexTitle}</h2>
      <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-4" set:html={vertexText} />
      {vertexPoints.length > 0 && (
        <ul class="space-y-2.5">
          {vertexPoints.map((point, i) => (
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center text-xs font-bold text-violet-700 dark:text-violet-400">{i + 1}</span>
              <div class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <!-- H2: How to Do Quadratic Regression on Calculator -->
  <section class="py-8 md:py-12">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-rose-500/0 before:to-rose-500/0 hover:before:from-rose-500/5 hover:before:to-rose-500/8 dark:hover:before:from-rose-400/8 dark:hover:before:to-rose-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-rose-900/10 hover:-translate-y-1 hover:border-rose-300 dark:hover:border-rose-700/50 transition-all duration-300">
      <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-3">{howDoTitle}</h2>
      <div class="text-sm text-surface-500 dark:text-surface-400 mb-5 prose prose-surface max-w-none" set:html={howDoIntro} />
      <div class="space-y-5">
        {howDoTi84Steps.length > 0 && (
          <div>
            <h3 class="text-base font-semibold text-surface-800 dark:text-surface-200 mb-2">{howDoTi84}</h3>
            <ol class="space-y-1.5 list-decimal list-inside">
              {howDoTi84Steps.map((step) => (
                <li class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={step} />
              ))}
            </ol>
          </div>
        )}
        {howDoTi83Steps.length > 0 && (
          <div>
            <h3 class="text-base font-semibold text-surface-800 dark:text-surface-200 mb-2">{howDoTi83}</h3>
            <ol class="space-y-1.5 list-decimal list-inside">
              {howDoTi83Steps.map((step) => (
                <li class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={step} />
              ))}
            </ol>
          </div>
        )}
        {howDoCasioSteps.length > 0 && (
          <div>
            <h3 class="text-base font-semibold text-surface-800 dark:text-surface-200 mb-2">{howDoCasio}</h3>
            <ol class="space-y-1.5 list-decimal list-inside">
              {howDoCasioSteps.map((step) => (
                <li class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={step} />
              ))}
            </ol>
          </div>
        )}
        {howDoTiNspireSteps.length > 0 && (
          <div>
            <h3 class="text-base font-semibold text-surface-800 dark:text-surface-200 mb-2">{howDoTiNspire}</h3>
            <ol class="space-y-1.5 list-decimal list-inside">
              {howDoTiNspireSteps.map((step) => (
                <li class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={step} />
              ))}
            </ol>
          </div>
        )}
      </div>
      <div class="mt-5 text-sm text-surface-500 dark:text-surface-400 italic prose prose-surface max-w-none" set:html={howDoNote} />
    </div>
  </section>

  <!-- H2: Quadratic Regression on Graphing Calculator -->
  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-purple-500/0 before:to-purple-500/0 hover:before:from-purple-500/5 hover:before:to-purple-500/8 dark:hover:before:from-purple-400/8 dark:hover:before:to-purple-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-purple-900/10 hover:-translate-y-1 hover:border-purple-300 dark:hover:border-purple-700/50 transition-all duration-300">
      <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-3">{graphCalcTitle}</h2>
      <p class="text-sm text-surface-500 dark:text-surface-400 mb-4">{graphCalcIntro}</p>
      {graphCalcSteps.length > 0 && (
        <ol class="space-y-3">
          {graphCalcSteps.map((step, i) => (
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-xs font-bold text-purple-700 dark:text-purple-400">{i + 1}</span>
              <div class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={step} />
            </li>
          ))}
        </ol>
      )}
    </div>
  </section>

  <!-- H2: When to Use / Avoid -->
  <section class="py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-green-500/0 before:to-emerald-500/0 hover:before:from-green-500/5 hover:before:to-emerald-500/5 dark:hover:before:from-green-400/8 dark:hover:before:to-emerald-400/8 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-green-900/10 hover:-translate-y-1 hover:border-green-300 dark:hover:border-green-700/50 transition-all duration-300">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{whenTitle}</h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-5" set:html={whenText} />
        {wnRows.length > 0 && (
          <div class="overflow-x-auto mb-5 rounded-lg border border-surface-200 dark:border-surface-700/50">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gradient-to-r from-green-600 to-emerald-500 dark:from-green-800 dark:to-emerald-700">
                  {wnHeaders.map((h) => (
                    <th class="px-4 py-2 text-left text-xs font-semibold text-white uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                {wnRows.map((row) => (
                  <tr class="hover:bg-green-50/30 dark:hover:bg-green-900/10 transition-colors">
                    {row.map((cell) => (
                      <td class="px-4 py-2 text-surface-600 dark:text-surface-400">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        <ul class="space-y-3 mb-6">
          {whenPoints.map((point, i) => (
            <li class="flex items-start gap-3 group/item translate-x-0 hover:translate-x-1 transition-transform duration-200" style={`transition-delay: ${i * 40}ms`}>
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center group-hover/item:bg-green-200 dark:group-hover/item:bg-green-800/40 group-hover/item:scale-110 transition-all duration-200">
                <svg class="w-3 h-3 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              </span>
              <div class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
            </li>
          ))}
        </ul>
      </div>
      <div class="content-box mt-6 rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-orange-500/0 before:to-amber-500/0 hover:before:from-orange-500/5 hover:before:to-amber-500/5 dark:hover:before:from-orange-400/8 dark:hover:before:to-amber-400/8 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-surface-950/40 hover:-translate-y-1 hover:border-orange-200 dark:hover:border-orange-700/50 transition-all duration-300">
        <h3 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{avoidTitle}</h3>
        <ul class="space-y-3">
          {avoidPoints.map((point, i) => (
            <li class="flex items-start gap-3 group/item translate-x-0 hover:translate-x-1 transition-transform duration-200" style={`transition-delay: ${i * 40}ms`}>
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center group-hover/item:bg-orange-200 dark:group-hover/item:bg-orange-800/40 group-hover/item:scale-110 transition-all duration-200">
                <svg class="w-3 h-3 text-orange-600 dark:text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
              </span>
              <div class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- H2: Frequently Asked Questions -->
  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 text-center mb-6">{faqTitle}</h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm overflow-hidden hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer text-sm font-semibold text-surface-800 dark:text-surface-200 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
              <span>{faq.q}</span>
              <svg class="w-4 h-4 flex-shrink-0 text-surface-400 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={faq.a} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- H2: Related Regression Calculators -->
  <section class="py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-6">{relatedTitle}</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {relatedItems.map((item, i) => {
          const themes = [
            { titleClass: 'text-accent-700 dark:text-accent-400 group-hover/card:text-accent-800 dark:group-hover/card:text-accent-300', before: 'before:from-accent-500/5 before:to-accent-500/8 dark:before:from-accent-400/8 dark:before:to-accent-400/12', shadow: 'dark:hover:shadow-accent-900/10', border: 'hover:border-accent-300 dark:hover:border-accent-700/50' },
            { titleClass: 'text-primary-700 dark:text-primary-400 group-hover/card:text-primary-800 dark:group-hover/card:text-primary-300', before: 'before:from-primary-500/5 before:to-primary-500/8 dark:before:from-primary-400/8 dark:before:to-primary-400/12', shadow: 'dark:hover:shadow-primary-900/10', border: 'hover:border-primary-300 dark:hover:border-primary-700/50' },
            { titleClass: 'text-emerald-700 dark:text-emerald-400 group-hover/card:text-emerald-800 dark:group-hover/card:text-emerald-300', before: 'before:from-emerald-500/5 before:to-emerald-500/8 dark:before:from-emerald-400/8 dark:before:to-emerald-400/12', shadow: 'dark:hover:shadow-emerald-900/10', border: 'hover:border-emerald-300 dark:hover:border-emerald-700/50' },
            { titleClass: 'text-violet-700 dark:text-violet-400 group-hover/card:text-violet-800 dark:group-hover/card:text-violet-300', before: 'before:from-violet-500/5 before:to-violet-500/8 dark:before:from-violet-400/8 dark:before:to-violet-400/12', shadow: 'dark:hover:shadow-violet-900/10', border: 'hover:border-violet-300 dark:hover:border-violet-700/50' },
            { titleClass: 'text-cyan-700 dark:text-cyan-400 group-hover/card:text-cyan-800 dark:group-hover/card:text-cyan-300', before: 'before:from-cyan-500/5 before:to-cyan-500/8 dark:before:from-cyan-400/8 dark:before:to-cyan-400/12', shadow: 'dark:hover:shadow-cyan-900/10', border: 'hover:border-cyan-300 dark:hover:border-cyan-700/50' },
            { titleClass: 'text-rose-700 dark:text-rose-400 group-hover/card:text-rose-800 dark:group-hover/card:text-rose-300', before: 'before:from-rose-500/5 before:to-rose-500/8 dark:before:from-rose-400/8 dark:before:to-rose-400/12', shadow: 'dark:hover:shadow-rose-900/10', border: 'hover:border-rose-300 dark:hover:border-rose-700/50' },
          ];
          const t = themes[i % themes.length];
          return (
            <a href={item.url} class={`content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br ${t.before} before:transition-all before:duration-500 hover:shadow-lg ${t.shadow} hover:-translate-y-1 ${t.border} transition-all duration-300 group/card`}>
              <h3 class={`text-base font-bold ${t.titleClass}`}>{item.name}</h3>
              <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">{item.desc}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
