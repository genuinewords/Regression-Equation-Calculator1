---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import GrubbsTestCalculator from 'theme/components/GrubbsTestCalculator.astro';
import ToolInfoBox from 'theme/components/ToolInfoBox.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

const locale = 'en';
const translations = await mergeTranslations(locale);
const gc = (translations as any).grubbs;

const canonicalUrl = new URL('/grubbs-test-calculator/', siteConfig.siteUrl).href;

const whatIsTitle = gc?.whatIsTitle || "What Is Grubbs' Test?";
const whatIsText = gc?.whatIsText || '';

const formulaTitle = gc?.formulaTitle || "Grubbs Test Formula Calculator Explained";
const formulaText = gc?.formulaText || '';
const formulaTable = gc?.formulaTable || '';
const formulas: string[] = gc?.formulas ?? [];

const howCalcTitle = gc?.howCalcTitle || "How to Calculate Grubbs Test";
const howCalcManual = gc?.howCalcManual || '';
const howCalcSteps: string[] = gc?.howCalcSteps ?? [];

const calcStepsTitle = gc?.calcStepsTitle || "Grubbs Test Calculator Steps";
const calcStepsIntro = gc?.calcStepsIntro || '';
const calcStepsPoints: string[] = gc?.calcStepsPoints ?? [];

const howItWorksTitle = gc?.howItWorksTitle || "How Grubbs' Test Works";
const howItWorksPoints: string[] = gc?.howItWorksPoints ?? [];

const assumptionsTitle = gc?.assumptionsTitle || "Assumptions";
const assumptionsPoints: string[] = gc?.assumptionsPoints ?? [];

const whenTitle = gc?.whenTitle || "When to Use Grubbs' Test";
const whenText = gc?.whenText || '';
const whenTable = gc?.whenTable || '';
const whenPoints: string[] = gc?.whenPoints ?? [];
const avoidTitle = gc?.avoidTitle || "When to Avoid Grubbs' Test";
const avoidPoints: string[] = gc?.avoidPoints ?? [];

const faqTitle = gc?.faqTitle || "Frequently Asked Questions";
const faqs: Array<{q: string; a: string}> = gc?.faqs ?? [];

const relatedTitle = gc?.relatedTitle || "Related Calculators";
const relatedItems: Array<{name: string; url: string; desc: string}> = gc?.relatedItems ?? [];

const fmHeaders = formulaTable ? formulaTable.split('|').slice(0, 3) : [];
const fmRows: string[][] = [];
if (formulaTable) {
  const fmParts = formulaTable.split('|');
  for (let i = 3; i + 2 < fmParts.length; i += 3) {
    fmRows.push([fmParts[i], fmParts[i+1], fmParts[i+2]]);
  }
}

const wnHeaders = whenTable ? whenTable.split('|').slice(0, 3) : [];
const wnRows: string[][] = [];
if (whenTable) {
  const wnParts = whenTable.split('|');
  for (let i = 3; i + 2 < wnParts.length; i += 3) {
    wnRows.push([wnParts[i], wnParts[i+1], wnParts[i+2]]);
  }
}

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Grubbs' Test Calculator",
  "description": "Free online Grubbs' test calculator. Detect outliers in your dataset with step-by-step solutions. Choose significance level, get G statistic, critical value, and p-value.",
  "url": "https://www.regressionequationcalculator.com/grubbs-test-calculator/",
  "applicationCategory": "MathCalculator",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": ["Grubbs G statistic", "Critical value", "p-value", "Outlier detection", "Step-by-step solutions", "Significance level selection"]
};

const faqSchema = faqs.length > 0
  ? { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) }
  : null;

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Calculate Grubbs' Test",
  "description": "Step-by-step guide to performing Grubbs' test for outlier detection",
  "totalTime": "PT3M",
  "step": [
    { "@type": "HowToStep", "name": "Enter Data", "text": "Input your univariate data points into the calculator." },
    { "@type": "HowToStep", "name": "Choose Significance Level", "text": "Select alpha (0.05 or 0.01) for the test." },
    { "@type": "HowToStep", "name": "Compute Mean and Std Dev", "text": "Calculate the sample mean and standard deviation." },
    { "@type": "HowToStep", "name": "Calculate G Statistic", "text": "Compute G = max|xi - x̄| / s." },
    { "@type": "HowToStep", "name": "Compare to Critical Value", "text": "If G > Gcrit, the extreme point is an outlier." }
  ]
};
---

<BaseLayout
  title={gc?.title || "Grubbs' Test Calculator"}
  description={gc?.description || "Detect outliers in your dataset using Grubbs' test with step-by-step solutions."}
  locale={locale}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
        <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] bg-amber-100/30 dark:bg-amber-900/10 blur-[100px] rounded-full animate-pulse"></div>
        <div class="absolute bottom-1/4 left-1/3 w-[350px] h-[350px] bg-primary-100/30 dark:bg-primary-900/10 blur-[90px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 text-center lg:text-left reveal-on-scroll">
          <nav class="mb-6 text-sm font-medium flex items-center justify-center lg:justify-start gap-2">
            <a href="/" class="text-surface-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Back to Main Regression Calculator</a>
          </nav>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-amber-700 via-primary-600 to-accent-600 dark:from-amber-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight mb-6">
            Grubbs' Test Calculator
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-8">
            Identify anomalies with statistical confidence. Detect significant outliers in your normally distributed datasets using the industry-standard Grubbs method.
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="#calculator-tool" class="px-8 py-3 rounded-xl bg-amber-600 text-white font-semibold shadow-lg shadow-amber-600/20 hover:bg-amber-700 hover:shadow-xl hover:shadow-amber-600/30 transition-all duration-300 hover:-translate-y-1">
              Test My Data
            </a>
            <a href="#how-to" class="px-8 py-3 rounded-xl bg-white dark:bg-surface-800 text-surface-700 dark:text-surface-200 font-semibold border border-surface-200 dark:border-surface-700 hover:border-amber-300 transition-all duration-300 hover:-translate-y-1">
              View Methodology
            </a>
          </div>
        </div>
        <div class="flex-1 w-full max-w-lg lg:max-w-none reveal-on-scroll" style="transition-delay: 200ms">
          <!-- Using pearson-hero as a placeholder for Grubbs since it has scattered points -->
          <div class="relative group" data-tilt>
            <div class="absolute -inset-4 bg-gradient-to-r from-amber-500/20 to-primary-500/20 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-500"></div>
            <div class="relative overflow-hidden rounded-3xl border border-white/20 shadow-2xl">
              <img
                src="/images/pearson-hero.png"
                alt="Outlier Detection Visualization"
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                width="600"
                height="400"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/20 via-transparent to-transparent opacity-40"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator Tool -->
  <section id="calculator-tool" class="py-12 md:py-16 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <GrubbsTestCalculator translations={translations} />
    </div>
  </section>

  <!-- Tool Info Box -->
  <ToolInfoBox
    toolName="Grubbs' Test Calculator"
    keyPoints={[
      {
        icon: "🎯",
        title: "Outlier Detection",
        description: "Identifies statistically significant outliers in univariate datasets using Grubbs' method."
      },
      {
        icon: "📥",
        title: "Input Your Data",
        description: "Enter comma-separated numbers and select a significance level (α = 0.05 or 0.01)."
      },
      {
        icon: "📊",
        title: "Instant Results",
        description: "Get G statistic, critical value, p-value, and a clear outlier verdict."
      },
      {
        icon: "🔬",
        title: "Best For",
        description: "Lab data, quality control, sensor readings, and any normally distributed sample."
      }
    ]}
    highlightTip="Always verify your data is approximately normal before applying Grubbs' test — non-normal data can produce misleading results."
  />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-12 py-16">
    <!-- What Is -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-amber-600 rounded-full"></span>
          {whatIsTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg" set:html={whatIsText} />
      </div>
    </section>

    <!-- Formula -->
    <section id="how-to" class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-accent-600 rounded-full"></span>
          {formulaTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={formulaText} />

        {fmRows.length > 0 && (
          <div class="overflow-hidden mb-8 rounded-2xl border border-surface-200 dark:border-surface-700/50 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gradient-to-r from-accent-600 to-accent-500 dark:from-accent-800 dark:to-accent-700">
                  {fmHeaders.map((h) => (
                    <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                {fmRows.map((row) => (
                  <tr class="hover:bg-accent-50/20 dark:hover:bg-accent-900/10 transition-colors">
                    {row.map((cell) => (
                      <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400 font-medium">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        <div class="grid sm:grid-cols-2 gap-4">
          {formulas.map((f, i) => (
            <div class="group flex items-start gap-4 p-4 rounded-xl bg-surface-50/50 dark:bg-surface-900/40 border border-surface-100 dark:border-surface-700/40 hover:border-accent-300 dark:hover:border-accent-700 transition-all duration-300">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center text-sm font-bold text-accent-700 dark:text-accent-400 group-hover:scale-110 transition-transform">{i + 1}</span>
              <span class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed pt-1" set:html={f} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How it Works & Assumptions -->
    <section class="reveal-on-scroll">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
            <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                {howItWorksTitle}
            </h2>
            <div class="space-y-4">
              {howItWorksPoints.map((point, i) => (
                <div class="flex items-start gap-3 p-3 rounded-xl bg-cyan-50/50 dark:bg-cyan-900/10 border border-cyan-100/50 dark:border-cyan-800/30">
                  <span class="flex-shrink-0 w-6 h-6 rounded-lg bg-cyan-100 dark:bg-cyan-900/30 flex items-center justify-center text-xs font-bold text-cyan-700 dark:text-cyan-400">{i + 1}</span>
                  <p class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed">{point}</p>
                </div>
              ))}
            </div>
        </div>

        <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
            <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                {assumptionsTitle}
            </h2>
            <div class="space-y-4">
              {assumptionsPoints.map((point, i) => (
                <div class="flex items-start gap-3 p-3 rounded-xl bg-violet-50/50 dark:bg-violet-900/10 border border-violet-100/50 dark:border-violet-800/30">
                  <span class="flex-shrink-0 w-6 h-6 rounded-lg bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center text-xs font-bold text-violet-700 dark:text-violet-400">{i + 1}</span>
                  <p class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed">{point}</p>
                </div>
              ))}
            </div>
        </div>
      </div>
    </section>

    <!-- When to Use Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg relative overflow-hidden group">
                <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-6">{whenTitle}</h2>
                <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 mb-8" set:html={whenText} />
                <div class="grid gap-4">
                  {whenPoints.map(point => (
                    <div class="flex items-start gap-4 p-4 rounded-2xl bg-emerald-50/50 dark:bg-emerald-900/10 border border-emerald-100/50 dark:border-emerald-800/30 hover:shadow-md transition-shadow">
                        <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-600 dark:text-emerald-400 flex-shrink-0">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <p class="text-sm text-surface-700 dark:text-surface-300" set:html={point} />
                    </div>
                  ))}
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50 text-center mb-10">{faqTitle}</h2>
            <div class="space-y-4">
                {faqs.map((faq, i) => (
                    <details class="group rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm overflow-hidden hover:shadow-lg transition-all duration-300">
                        <summary class="flex items-center justify-between px-6 py-5 cursor-pointer text-base font-bold text-surface-800 dark:text-surface-200 hover:text-amber-600 transition-colors list-none">
                            <span>{faq.q}</span>
                            <div class="w-8 h-8 rounded-full bg-surface-50 dark:bg-surface-900/50 flex items-center justify-center group-open:rotate-180 transition-transform">
                                <svg class="w-4 h-4 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </summary>
                        <div class="px-6 pb-6 text-base text-surface-600 dark:text-surface-400 leading-relaxed border-t border-surface-100 dark:border-surface-700/50 pt-4" set:html={faq.a} />
                    </details>
                ))}
            </div>
        </div>
    </section>

    <!-- Related Calculators -->
    <section class="reveal-on-scroll">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50">{relatedTitle}</h2>
        <p class="text-surface-500 mt-2">Discover more specialized statistical tools.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {relatedItems.map((item, i) => {
          const themes = [
            { accent: 'accent', icon: '📈' },
            { accent: 'primary', icon: '📐' },
            { accent: 'emerald', icon: '🧬' },
            { accent: 'violet', icon: '🔮' },
            { accent: 'cyan', icon: '🔬' },
            { accent: 'rose', icon: '📍' },
          ];
          const t = themes[i % themes.length];
          return (
            <a href={item.url} class="group/card relative p-6 rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 overflow-hidden">
              <div class={`absolute inset-0 bg-gradient-to-br from-${t.accent}-500/0 to-${t.accent}-500/0 group-hover/card:from-${t.accent}-500/5 group-hover/card:to-${t.accent}-500/10 transition-all duration-500`}></div>
              <div class="relative z-10">
                <div class={`w-12 h-12 rounded-xl bg-${t.accent}-100 dark:bg-${t.accent}-900/30 flex items-center justify-center mb-4 group-hover/card:scale-110 transition-transform duration-300 text-xl`}>
                  {t.icon}
                </div>
                <h3 class={`text-lg font-bold text-${t.accent}-700 dark:text-${t.accent}-400 mb-2`}>{item.name}</h3>
                <p class="text-sm text-surface-500 dark:text-surface-400">{item.desc}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // ── Reveal on Scroll (IntersectionObserver) ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── Interactive 3D Tilt Effect (Optimized) ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    let rect: DOMRect | null = null;
    el.addEventListener('mouseenter', () => { rect = el.getBoundingClientRect(); });
    el.addEventListener('mousemove', (e: MouseEvent) => {
      if (!rect) rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -10;
      const rotateY = ((x - centerX) / centerX) * 10;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave', () => {
      rect = null;
      el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
