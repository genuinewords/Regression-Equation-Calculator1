---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import { mergeTranslations } from 'theme/i18n/utils';

const locale = 'en';
const translations = await mergeTranslations(locale);
---

<BaseLayout
  title={translations.terms.title}
  description={translations.terms.description}
  locale={locale}
>
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 to-accent-600 bg-clip-text text-transparent">
        {translations.terms.title}
      </h1>

      {translations.terms.lastUpdated && (
        <p class="mt-3 text-sm text-surface-400">
          {translations.terms.lastUpdated}
        </p>
      )}

      <div class="mt-10 rounded-2xl border border-surface-200/60 bg-white p-8 md:p-12 shadow-sm">
        <p class="text-surface-600 leading-relaxed text-lg">
          {translations.terms.intro}
        </p>
        <div class="mt-6 text-surface-700 leading-relaxed prose-headings:text-surface-900">
          <p class="text-surface-600 leading-relaxed">{translations.terms.content}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
