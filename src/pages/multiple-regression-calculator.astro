---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import MultipleRegressionCalculator from 'theme/components/MultipleRegressionCalculator.astro';
import ToolInfoBox from 'theme/components/ToolInfoBox.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/multiple-hero.png';

const locale = 'en';
const translations = await mergeTranslations(locale);
const mc = (translations as any).multiCalc;

const canonicalUrl = new URL('/multiple-regression-calculator/', siteConfig.siteUrl).href;

const breadcrumb = mc?.breadcrumb || 'Back to Main Regression Calculator';

const whatIsTitle = mc?.whatIsTitle || 'How to Calculate Multiple Regression';
const whatIsText = mc?.whatIsText || '';

const formulaTitle = mc?.formulaTitle || 'Multiple Regression Formula Calculator Explained';
const formulaText = mc?.formulaText || '';
const formulaTable = mc?.formulaTable || '';
const formulas: string[] = mc?.formulas ?? [];

const howCalcTitle = mc?.howCalcTitle || 'How to Calculate Multiple Regression';
const howCalcManual = mc?.howCalcManual || '';
const howCalcSteps: string[] = mc?.howCalcSteps ?? [];

const calcStepsTitle = mc?.calcStepsTitle || 'Multiple Regression Calculator Steps';
const calcStepsIntro = mc?.calcStepsIntro || '';
const calcStepsPoints: string[] = mc?.calcStepsPoints ?? [];

const tableDataTitle = mc?.tableDataTitle || 'Multiple Regression Calculator from Table Data';
const tableDataIntro = mc?.tableDataIntro || '';
const tableDataTable = mc?.tableDataTable || '';
const tableDataSteps: string[] = mc?.tableDataSteps ?? [];

const coefficientsTitle = mc?.coefficientsTitle || 'Interpreting Multiple Regression Coefficients';
const coefficientsText = mc?.coefficientsText || '';
const coefficientsPoints: string[] = mc?.coefficientsPoints ?? [];

const howDoTitle = mc?.howDoTitle || 'How to Do Multiple Regression on Calculator';
const howDoIntro = mc?.howDoIntro || '';
const howDoTi84Steps: string[] = mc?.howDoTi84Steps ?? [];
const howDoTiNspireSteps: string[] = mc?.howDoTiNspireSteps ?? [];
const howDoNote = mc?.howDoNote || '';

const assumptionsTitle = mc?.assumptionsTitle || 'Assumptions of Multiple Regression';
const assumptionsText = mc?.assumptionsText || '';
const assumptionsPoints: string[] = mc?.assumptionsPoints ?? [];

const whenTitle = mc?.whenTitle || 'When to Use Multiple Regression';
const whenText = mc?.whenText || '';
const whenTable = mc?.whenTable || '';
const whenPoints: string[] = mc?.whenPoints ?? [];
const avoidTitle = mc?.avoidTitle || 'When to Avoid Multiple Regression';
const avoidPoints: string[] = mc?.avoidPoints ?? [];

const faqTitle = mc?.faqTitle || 'Frequently Asked Questions';
const faqs: Array<{q: string; a: string}> = mc?.faqs ?? [];

const relatedTitle = mc?.relatedTitle || 'Related Regression Calculators';
const relatedItems: Array<{name: string; url: string; desc: string}> = mc?.relatedItems ?? [];

const fmHeaders = formulaTable ? formulaTable.split('|').slice(0, 3) : [];
const fmRows: string[][] = [];
if (formulaTable) {
  const fmParts = formulaTable.split('|');
  for (let i = 3; i + 2 < fmParts.length; i += 3) {
    fmRows.push([fmParts[i], fmParts[i+1], fmParts[i+2]]);
  }
}

const wnHeaders = whenTable ? whenTable.split('|').slice(0, 3) : [];
const wnRows: string[][] = [];
if (whenTable) {
  const wnParts = whenTable.split('|');
  for (let i = 3; i + 2 < wnParts.length; i += 3) {
    wnRows.push([wnParts[i], wnParts[i+1], wnParts[i+2]]);
  }
}

const tdHeaders = tableDataTable ? tableDataTable.split('|').slice(0, 4) : [];
const tdRows: string[][] = [];
if (tableDataTable) {
  const tdParts = tableDataTable.split('|');
  for (let i = 4; i + 3 < tdParts.length; i += 4) {
    tdRows.push([tdParts[i], tdParts[i+1], tdParts[i+2], tdParts[i+3]]);
  }
}

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Multiple Regression Calculator",
  "description": "Free online multiple regression calculator. Compute y = b₀ + b₁x₁ + b₂x₂ with coefficients, adjusted R², F-test, and step-by-step solution.",
  "url": "https://www.regressionequationcalculator.com/multiple-regression-calculator/",
  "applicationCategory": "MathCalculator",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": ["Two predictor variables", "Adjusted R²", "F-test statistic", "Coefficient analysis", "Step-by-step solutions", "Prediction forecasting"]
};

const faqSchema = faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: { '@type': 'Answer', text: faq.a },
      })),
    }
  : null;

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Calculate Multiple Regression",
  "description": "Step-by-step guide to calculating multiple regression from your data",
  "totalTime": "PT8M",
  "step": [
    { "@type": "HowToStep", "name": "Enter Data", "text": "Input your X₁, X₂, and Y data into the calculator table." },
    { "@type": "HowToStep", "name": "Compute Sums", "text": "Calculate all required sums, cross-products, and squared terms." },
    { "@type": "HowToStep", "name": "Solve System", "text": "Solve the normal equations for coefficients b₀, b₁, b₂." },
    { "@type": "HowToStep", "name": "Evaluate Fit", "text": "Compute R², adjusted R², and the F-statistic." },
    { "@type": "HowToStep", "name": "Check Assumptions", "text": "Verify no multicollinearity and residuals meet OLS assumptions." },
    { "@type": "HowToStep", "name": "Make Predictions", "text": "Use the equation to predict Y for new X₁, X₂ values." }
  ]
};
---

<BaseLayout
  title={mc?.title || "Multiple Regression Calculator — Predict with Multiple Variables"}
  description={mc?.description || "Free online multiple regression calculator. Compute y = b₀ + b₁x₁ + b₂x₂ with coefficients, adjusted R², and standard error."}
  locale={locale}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] bg-violet-100/30 dark:bg-violet-900/10 blur-[120px] rounded-full animate-pulse"></div>
      <div class="absolute bottom-1/3 right-1/4 w-[420px] h-[420px] bg-primary-100/30 dark:bg-primary-900/10 blur-[110px] rounded-full animate-pulse" style="animation-delay: 3s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="flex-1 text-center lg:text-left reveal-on-scroll">
          <nav class="mb-6 text-sm font-medium flex items-center justify-center lg:justify-start gap-2">
            <a href="/" class="text-surface-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
          </nav>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-violet-700 via-primary-600 to-accent-600 dark:from-violet-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight mb-6">
            Multiple Regression Calculator
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-8">
            Analyze multi-variable relationships with laboratory precision. Predict outcomes influenced by multiple factors simultaneously using our high-performance multidimensional solver.
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="#calculator-tool" class="px-8 py-3 rounded-xl bg-violet-600 text-white font-semibold shadow-lg shadow-violet-600/20 hover:bg-violet-700 hover:shadow-xl hover:shadow-violet-600/30 transition-all duration-300 hover:-translate-y-1">
              Start Analysis
            </a>
            <a href="#how-to" class="px-8 py-3 rounded-xl bg-white dark:bg-surface-800 text-surface-700 dark:text-surface-200 font-semibold border border-surface-200 dark:border-surface-700 hover:border-violet-300 transition-all duration-300 hover:-translate-y-1">
              Learn Formula
            </a>
          </div>
        </div>
        <div class="flex-1 w-full max-w-lg lg:max-w-none reveal-on-scroll" style="transition-delay: 200ms">
          <div class="relative group" data-tilt>
            <div class="absolute -inset-4 bg-gradient-to-r from-violet-500/20 to-primary-500/20 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-500"></div>
            <div class="relative overflow-hidden rounded-3xl border border-white/20 shadow-2xl">
              <Image
                src={heroImage}
                alt="Multidimensional Data Visualization"
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                width={800}
                densities={[1, 2]}
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/20 via-transparent to-transparent opacity-40"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator Tool -->
  <section id="calculator-tool" class="py-12 md:py-16 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <MultipleRegressionCalculator translations={translations} />
    </div>
  </section>

  <!-- Tool Info Box -->
  <ToolInfoBox
    toolName="Multiple Regression Calculator"
    keyPoints={[
      {
        icon: "🧮",
        title: "Multi-Variable Model",
        description: "Fits a regression equation with two or more predictor variables."
      },
      {
        icon: "📥",
        title: "Input Variables",
        description: "Enter dependent (Y) and multiple independent (X) variables as data columns."
      },
      {
        icon: "📊",
        title: "Comprehensive Output",
        description: "Get coefficients, R², adjusted R², ANOVA table, and residual analysis."
      },
      {
        icon: "🔬",
        title: "Best For",
        description: "Predicting outcomes influenced by multiple factors simultaneously."
      }
    ]}
    highlightTip="Check for multicollinearity between predictors — highly correlated X variables can distort coefficient estimates."
  />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-12 py-16">
    <!-- H2: What Is Multiple Regression -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity">
            <svg class="w-32 h-32 text-violet-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-violet-600 rounded-full"></span>
          {whatIsTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg" set:html={whatIsText} />
      </div>
    </section>

    <!-- H2: Formula -->
    <section id="how-to" class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-accent-600 rounded-full"></span>
          {formulaTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={formulaText} />

        {fmRows.length > 0 && (
          <div class="overflow-hidden mb-8 rounded-2xl border border-surface-200 dark:border-surface-700/50 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gradient-to-r from-accent-600 to-accent-500 dark:from-accent-800 dark:to-accent-700">
                  {fmHeaders.map((h) => (
                    <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                {fmRows.map((row) => (
                  <tr class="hover:bg-accent-50/20 dark:hover:bg-accent-900/10 transition-colors">
                    {row.map((cell) => (
                      <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400 font-medium">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        <div class="grid sm:grid-cols-2 gap-4">
          {formulas.map((f, i) => (
            <div class="group flex items-start gap-4 p-4 rounded-xl bg-surface-50/50 dark:bg-surface-900/40 border border-surface-100 dark:border-surface-700/40 hover:border-accent-300 dark:hover:border-accent-700 transition-all duration-300">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center text-sm font-bold text-accent-700 dark:text-accent-400 group-hover:scale-110 transition-transform">{i + 1}</span>
              <span class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed pt-1" set:html={f} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Coefficients & Table Data -->
    <section class="reveal-on-scroll">
        <div class="grid md:grid-cols-2 gap-8">
          <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
              <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                  <svg class="w-6 h-6 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>
                  {coefficientsTitle}
              </h2>
              <div class="prose prose-surface max-w-none text-sm text-surface-600 dark:text-surface-400 mb-6" set:html={coefficientsText} />
              <ul class="space-y-3">
                {coefficientsPoints.map((point, i) => (
                  <li class="flex items-start gap-3 p-3 rounded-xl bg-violet-50/50 dark:bg-violet-900/10 border border-violet-100/50 dark:border-violet-800/30">
                    <span class="flex-shrink-0 w-6 h-6 rounded-lg bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center text-xs font-bold text-violet-700 dark:text-violet-400">{i + 1}</span>
                    <p class="text-sm text-surface-700 dark:text-surface-300" set:html={point} />
                  </li>
                ))}
              </ul>
          </div>
  
          <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
              <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                  <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  {tableDataTitle}
              </h2>
              <p class="text-sm text-surface-500 dark:text-surface-400 mb-6">{tableDataIntro}</p>
              {tdRows.length > 0 && (
                <div class="overflow-hidden mb-6 rounded-xl border border-surface-200 dark:border-surface-700/50">
                  <table class="w-full text-[10px] sm:text-xs">
                    <thead class="bg-amber-600 text-white">
                      <tr>
                        {tdHeaders.map(h => <th class="px-2 py-2 text-left font-bold">{h}</th>)}
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                      {tdRows.map(row => (
                        <tr class="hover:bg-amber-50/20 dark:hover:bg-amber-900/10">
                          {row.map(cell => <td class="px-2 py-2 text-surface-600 dark:text-surface-400">{cell}</td>)}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
              <ol class="space-y-2 list-decimal list-inside text-sm text-surface-600 dark:text-surface-400">
                {tableDataSteps.map(step => <li set:html={step} />)}
              </ol>
          </div>
        </div>
      </section>

    <!-- Assumptions Section -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
          <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
              <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              {assumptionsTitle}
          </h2>
          <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 mb-8" set:html={assumptionsText} />
          <div class="grid sm:grid-cols-2 gap-4">
            {assumptionsPoints.map((point, i) => (
              <div class="flex items-start gap-3 p-4 rounded-xl bg-indigo-50/30 dark:bg-indigo-900/10 border border-indigo-100/50 dark:border-indigo-800/30">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center text-xs font-bold text-indigo-700 dark:text-indigo-400">{i + 1}</span>
                <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
              </div>
            ))}
          </div>
      </div>
    </section>

    <!-- When to Use Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg relative overflow-hidden group">
                <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-6">{whenTitle}</h2>
                <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 mb-8" set:html={whenText} />
                <div class="grid gap-4">
                  {whenPoints.map(point => (
                    <div class="flex items-start gap-4 p-4 rounded-2xl bg-emerald-50/50 dark:bg-emerald-900/10 border border-emerald-100/50 dark:border-emerald-800/30 hover:shadow-md transition-shadow">
                        <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-600 dark:text-emerald-400 flex-shrink-0">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <p class="text-sm text-surface-700 dark:text-surface-300" set:html={point} />
                    </div>
                  ))}
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50 text-center mb-10">{faqTitle}</h2>
            <div class="space-y-4">
                {faqs.map((faq, i) => (
                    <details class="group rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm overflow-hidden hover:shadow-lg transition-all duration-300">
                        <summary class="flex items-center justify-between px-6 py-5 cursor-pointer text-base font-bold text-surface-800 dark:text-surface-200 hover:text-indigo-600 transition-colors list-none">
                            <span>{faq.q}</span>
                            <div class="w-8 h-8 rounded-full bg-surface-50 dark:bg-surface-900/50 flex items-center justify-center group-open:rotate-180 transition-transform">
                                <svg class="w-4 h-4 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </summary>
                        <div class="px-6 pb-6 text-base text-surface-600 dark:text-surface-400 leading-relaxed border-t border-surface-100 dark:border-surface-700/50 pt-4" set:html={faq.a} />
                    </details>
                ))}
            </div>
        </div>
    </section>

    <!-- Related Calculators -->
    <section class="reveal-on-scroll">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50">{relatedTitle}</h2>
        <p class="text-surface-500 mt-2">Discover more specialized regression modeling tools.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {relatedItems.map((item, i) => {
          const themes = [
            { accent: 'accent', icon: '📈' },
            { accent: 'primary', icon: '📐' },
            { accent: 'emerald', icon: '🧬' },
            { accent: 'violet', icon: '🔮' },
            { accent: 'cyan', icon: '🔬' },
            { accent: 'rose', icon: '📍' },
          ];
          const t = themes[i % themes.length];
          return (
            <a href={item.url} class="group/card relative p-6 rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 overflow-hidden">
              <div class={`absolute inset-0 bg-gradient-to-br from-${t.accent}-500/0 to-${t.accent}-500/0 group-hover/card:from-${t.accent}-500/5 group-hover/card:to-${t.accent}-500/10 transition-all duration-500`}></div>
              <div class="relative z-10">
                <div class={`w-12 h-12 rounded-xl bg-${t.accent}-100 dark:bg-${t.accent}-900/30 flex items-center justify-center mb-4 group-hover/card:scale-110 transition-transform duration-300 text-xl`}>
                  {t.icon}
                </div>
                <h3 class={`text-lg font-bold text-${t.accent}-700 dark:text-${t.accent}-400 mb-2`}>{item.name}</h3>
                <p class="text-sm text-surface-500 dark:text-surface-400">{item.desc}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // ── Reveal on Scroll (IntersectionObserver) ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── Interactive 3D Tilt Effect (Optimized) ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    let rect: DOMRect | null = null;
    el.addEventListener('mouseenter', () => { rect = el.getBoundingClientRect(); });
    el.addEventListener('mousemove', (e: MouseEvent) => {
      if (!rect) rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -10;
      const rotateY = ((x - centerX) / centerX) * 10;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave', () => {
      rect = null;
      el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
