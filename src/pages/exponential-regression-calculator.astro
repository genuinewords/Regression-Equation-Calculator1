---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import ExponentialRegressionCalculator from 'theme/components/ExponentialRegressionCalculator.astro';
import ToolInfoBox from 'theme/components/ToolInfoBox.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/exponential-hero.png';

const locale = 'en';
const translations = await mergeTranslations(locale);
const ec = (translations as any).expCalc;

const canonicalUrl = new URL('/exponential-regression-calculator/', siteConfig.siteUrl).href;

const breadcrumb = ec?.breadcrumb || 'Back to Main Regression Calculator';

const whatIsTitle = ec?.whatIsTitle || 'What Is Exponential Regression?';
const whatIsText = ec?.whatIsText || '';

const formulaTitle = ec?.formulaTitle || 'Exponential Regression Formula Calculator Explained';
const formulaText = ec?.formulaText || '';
const formulaTable = ec?.formulaTable || '';
const formulas: string[] = ec?.formulas ?? [];

const howCalcTitle = ec?.howCalcTitle || 'How to Calculate Exponential Regression';
const howCalcManual = ec?.howCalcManual || '';
const howCalcSteps: string[] = ec?.howCalcSteps ?? [];

const calcStepsTitle = ec?.calcStepsTitle || 'Exponential Regression Calculator Steps';
const calcStepsIntro = ec?.calcStepsIntro || '';
const calcStepsPoints: string[] = ec?.calcStepsPoints ?? [];

const tableDataTitle = ec?.tableDataTitle || 'Exponential Regression Calculator from Table Data';
const tableDataIntro = ec?.tableDataIntro || '';
const tableDataTable = ec?.tableDataTable || '';
const tableDataSteps: string[] = ec?.tableDataSteps ?? [];

const funcCalcTitle = ec?.funcCalcTitle || 'Exponential Regression Function Calculator Guide';
const funcCalcText = ec?.funcCalcText || '';

const modelCalcTitle = ec?.modelCalcTitle || 'Exponential Regression Model Calculator Overview';
const modelCalcText = ec?.modelCalcText || '';
const modelCalcPoints: string[] = ec?.modelCalcPoints ?? [];

const howDoTitle = ec?.howDoTitle || 'How to Do Exponential Regression on Calculator';
const howDoIntro = ec?.howDoIntro || '';
const howDoTi84 = ec?.howDoTi84 || 'TI-84 Plus';
const howDoTi84Steps: string[] = ec?.howDoTi84Steps ?? [];
const howDoTi83 = ec?.howDoTi83 || 'TI-83';
const howDoTi83Steps: string[] = ec?.howDoTi83Steps ?? [];
const howDoCasio = ec?.howDoCasio || 'Casio fx-9860 / fx-CG50';
const howDoCasioSteps: string[] = ec?.howDoCasioSteps ?? [];
const howDoTiNspire = ec?.howDoTiNspire || 'TI-Nspire';
const howDoTiNspireSteps: string[] = ec?.howDoTiNspireSteps ?? [];
const howDoNote = ec?.howDoNote || '';

const graphCalcTitle = ec?.graphCalcTitle || 'Exponential Regression on Graphing Calculator (TI-84, TI-83, Casio)';
const graphCalcIntro = ec?.graphCalcIntro || '';
const graphCalcSteps: string[] = ec?.graphCalcSteps ?? [];

const eqGraphCalcTitle = ec?.eqGraphCalcTitle || 'Exponential Regression Equation on Graphing Calculator';
const eqGraphCalcText = ec?.eqGraphCalcText || '';
const eqGraphCalcPoints: string[] = ec?.eqGraphCalcPoints ?? [];

const eqCalcTitle = ec?.eqCalcTitle || 'Exponential Regression Equation on Calculator';
const eqCalcText = ec?.eqCalcText || '';
const eqCalcTable = ec?.eqCalcTable || '';
const eqCalcNote = ec?.eqCalcNote || '';

const whenTitle = ec?.whenTitle || 'When to Use This Calculator for Exponential Regression';
const whenText = ec?.whenText || '';
const whenTable = ec?.whenTable || '';
const whenPoints: string[] = ec?.whenPoints ?? [];
const avoidTitle = ec?.avoidTitle || 'When to Avoid Exponential Regression';
const avoidPoints: string[] = ec?.avoidPoints ?? [];

const multiCalcTitle = ec?.multiCalcTitle || 'Multiple Exponential Regression Calculator';
const multiCalcText = ec?.multiCalcText || '';
const multiCalcPoints: string[] = ec?.multiCalcPoints ?? [];
const multiCalcNote = ec?.multiCalcNote || '';

const faqTitle = ec?.faqTitle || 'Frequently Asked Questions';
const faqs: Array<{q: string; a: string}> = ec?.faqs ?? [];

const relatedTitle = ec?.relatedTitle || 'Related Regression Calculators';
const relatedItems: Array<{name: string; url: string; desc: string}> = ec?.relatedItems ?? [];

const fmHeaders = formulaTable.split('|').slice(0, 3);
const fmRows: string[][] = [];
const fmParts = formulaTable.split('|');
for (let i = 3; i + 2 < fmParts.length; i += 3) {
  fmRows.push([fmParts[i], fmParts[i+1], fmParts[i+2]]);
}

const wnHeaders = whenTable.split('|').slice(0, 3);
const wnRows: string[][] = [];
const wnParts = whenTable.split('|');
for (let i = 3; i + 2 < wnParts.length; i += 3) {
  wnRows.push([wnParts[i], wnParts[i+1], wnParts[i+2]]);
}

const tdHeaders = tableDataTable.split('|').slice(0, 7);
const tdRows: string[][] = [];
const tdParts = tableDataTable.split('|');
for (let i = 7; i + 6 < tdParts.length; i += 7) {
  tdRows.push([tdParts[i], tdParts[i+1], tdParts[i+2], tdParts[i+3], tdParts[i+4], tdParts[i+5], tdParts[i+6]]);
}

const eqHeaders = eqCalcTable.split('|').slice(0, 5);
const eqRows: string[][] = [];
const eqParts = eqCalcTable.split('|');
for (let i = 5; i + 4 < eqParts.length; i += 5) {
  eqRows.push([eqParts[i], eqParts[i+1], eqParts[i+2], eqParts[i+3], eqParts[i+4]]);
}

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Exponential Regression Calculator",
  "description": "Free online exponential regression calculator with step-by-step solutions, R² calculation, graph visualization, table input, and prediction forecasting.",
  "url": "https://www.regressionequationcalculator.com/exponential-regression-calculator/",
  "applicationCategory": "MathCalculator",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": ["Step-by-step solutions", "R² calculation", "Graph visualization", "Table input", "Prediction forecasting", "Export results"]
};

const faqSchema = faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: { '@type': 'Answer', text: faq.a },
      })),
    }
  : null;

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Calculate Exponential Regression",
  "description": "Step-by-step guide to calculating exponential regression from your data",
  "totalTime": "PT5M",
  "step": [
    { "@type": "HowToStep", "name": "Prepare Data", "text": "Organize your X and Y data pairs. Ensure all Y values are positive." },
    { "@type": "HowToStep", "name": "Transform Data", "text": "Take the natural logarithm of each Y value: ln(Y)." },
    { "@type": "HowToStep", "name": "Perform Linear Regression", "text": "Apply least squares regression to the (X, ln Y) data pairs." },
    { "@type": "HowToStep", "name": "Recover Parameters", "text": "Exponentiate the intercept to find a, and use the slope as b." },
    { "@type": "HowToStep", "name": "Assess Model Fit", "text": "Calculate R² on the original data to evaluate goodness of fit." },
    { "@type": "HowToStep", "name": "Make Predictions", "text": "Use the equation y = a·e^(bx) to predict Y for new X values." },
    { "@type": "HowToStep", "name": "Interpret Results", "text": "Calculate doubling time or half-life from the growth rate b." }
  ]
};
---

<BaseLayout
  title={ec?.title || "Exponential Regression Calculator Online (Free) - Step-by-Step Solutions"}
  description={ec?.description || "Free exponential regression calculator online. Calculate y = a·e^(bx) from table data with step-by-step solutions, R², graphs."}
  locale={locale}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] bg-primary-100/30 dark:bg-primary-900/10 blur-[100px] rounded-full animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[350px] h-[350px] bg-accent-100/30 dark:bg-accent-900/10 blur-[90px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 text-center lg:text-left reveal-on-scroll">
          <nav class="mb-6 text-sm font-medium flex items-center justify-center lg:justify-start gap-2">
            <a href="/" class="text-surface-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
          </nav>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 via-primary-600 to-accent-600 dark:from-primary-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight mb-6">
            Exponential Regression Calculator Online
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-8">
            Model rapid growth and decay trends with institutional precision. Calculate growth rates, doubling times, and make accurate predictions with our high-performance solver.
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="#calculator-tool" class="px-8 py-3 rounded-xl bg-primary-600 text-white font-semibold shadow-lg shadow-primary-600/20 hover:bg-primary-700 hover:shadow-xl hover:shadow-primary-600/30 transition-all duration-300 hover:-translate-y-1">
              Start Calculating
            </a>
            <a href="#how-to" class="px-8 py-3 rounded-xl bg-white dark:bg-surface-800 text-surface-700 dark:text-surface-200 font-semibold border border-surface-200 dark:border-surface-700 hover:border-primary-300 transition-all duration-300 hover:-translate-y-1">
              Learn Formula
            </a>
          </div>
        </div>
        <div class="flex-1 w-full max-w-lg lg:max-w-none reveal-on-scroll" style="transition-delay: 200ms">
          <div class="relative group" data-tilt>
            <div class="absolute -inset-4 bg-gradient-to-r from-primary-500/20 to-accent-500/20 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-500"></div>
            <div class="relative overflow-hidden rounded-3xl border border-white/20 shadow-2xl">
              <Image
                src={heroImage}
                alt="Exponential Growth Visualization"
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                width={800}
                densities={[1, 2]}
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/20 via-transparent to-transparent opacity-40"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator Tool -->
  <section id="calculator-tool" class="py-12 md:py-16 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <ExponentialRegressionCalculator translations={translations} />
    </div>
  </section>

  <!-- Tool Info Box -->
  <ToolInfoBox
    toolName="Exponential Regression Calculator"
    keyPoints={[
      {
        icon: "📈",
        title: "Exponential Modeling",
        description: "Fits y = a·e^(bx) to your data using log-transformed least squares."
      },
      {
        icon: "📥",
        title: "Enter X & Y Data",
        description: "Input paired values — all Y values must be positive for valid results."
      },
      {
        icon: "📊",
        title: "Growth Analysis",
        description: "Get equation coefficients, R², doubling time, and prediction forecasts."
      },
      {
        icon: "🔬",
        title: "Best For",
        description: "Population growth, compound interest, radioactive decay, and viral spread."
      }
    ]}
    highlightTip="Exponential regression requires all Y values to be positive — zero or negative values will produce errors."
  />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-12 py-16">
    <!-- H2: What Is Exponential Regression? -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity">
            <svg class="w-32 h-32 text-primary-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-primary-600 rounded-full"></span>
          {whatIsTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg" set:html={whatIsText} />
      </div>
    </section>

    <!-- H2: Formula & Explained -->
    <section id="how-to" class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-accent-600 rounded-full"></span>
          {formulaTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={formulaText} />

        {fmRows.length > 0 && (
          <div class="overflow-hidden mb-8 rounded-2xl border border-surface-200 dark:border-surface-700/50 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gradient-to-r from-accent-600 to-accent-500 dark:from-accent-800 dark:to-accent-700">
                  {fmHeaders.map((h) => (
                    <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                {fmRows.map((row) => (
                  <tr class="hover:bg-accent-50/20 dark:hover:bg-accent-900/10 transition-colors">
                    {row.map((cell) => (
                      <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400 font-medium">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        <div class="grid sm:grid-cols-2 gap-4">
          {formulas.map((f, i) => (
            <div class="group flex items-start gap-4 p-4 rounded-xl bg-surface-50/50 dark:bg-surface-900/40 border border-surface-100 dark:border-surface-700/40 hover:border-accent-300 dark:hover:border-accent-700 transition-all duration-300">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center text-sm font-bold text-accent-700 dark:text-accent-400 group-hover:scale-110 transition-transform">{i + 1}</span>
              <span class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed pt-1" set:html={f} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- H2: Steps -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-emerald-600 rounded-full"></span>
          {howCalcTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={howCalcManual} />
        <div class="space-y-6">
          {howCalcSteps.map((step, i) => (
            <div class="flex gap-5 group">
                <div class="flex-shrink-0 flex flex-col items-center">
                    <span class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-700 dark:text-emerald-400 font-bold group-hover:scale-110 transition-transform">{i + 1}</span>
                    {i < howCalcSteps.length - 1 && <div class="w-0.5 h-full bg-surface-100 dark:bg-surface-700/50 mt-2"></div>}
                </div>
                <div class="pb-6">
                    <div class="text-base text-surface-600 dark:text-surface-400 leading-relaxed pt-1.5" set:html={step} />
                </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Detailed Guide Section -->
    <section class="reveal-on-scroll">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- TI-84/Graphing Guide -->
        <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
            <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-rose-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                Graphing Calculator Guide
            </h2>
            <div class="space-y-6">
                <div>
                    <h3 class="text-base font-bold text-surface-800 dark:text-surface-200 mb-3">{howDoTi84}</h3>
                    <ul class="space-y-2">
                        {howDoTi84Steps.map(step => (
                            <li class="text-sm text-surface-600 dark:text-surface-400 flex items-start gap-2">
                                <span class="text-rose-500 mt-1.5">•</span>
                                <span set:html={step} />
                            </li>
                        ))}
                    </ul>
                </div>
                <div class="pt-4 border-t border-surface-100 dark:border-surface-700">
                    <p class="text-xs text-surface-500 dark:text-surface-400 italic" set:html={howDoNote} />
                </div>
            </div>
        </div>

        <!-- When to Use -->
        <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
            <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Optimal Applications
            </h2>
            <div class="space-y-4">
                {whenPoints.map(point => (
                    <div class="flex items-start gap-3 p-3 rounded-xl bg-green-50/50 dark:bg-green-900/10 border border-green-100/50 dark:border-green-800/30">
                        <svg class="w-5 h-5 text-green-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 13l4 4L19 7"/></svg>
                        <p class="text-sm text-surface-700 dark:text-surface-300" set:html={point} />
                    </div>
                ))}
            </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50 text-center mb-10">{faqTitle}</h2>
            <div class="space-y-4">
                {faqs.map((faq, i) => (
                    <details class="group rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm overflow-hidden hover:shadow-lg transition-all duration-300">
                        <summary class="flex items-center justify-between px-6 py-5 cursor-pointer text-base font-bold text-surface-800 dark:text-surface-200 hover:text-primary-600 transition-colors list-none">
                            <span>{faq.q}</span>
                            <div class="w-8 h-8 rounded-full bg-surface-50 dark:bg-surface-900/50 flex items-center justify-center group-open:rotate-180 transition-transform">
                                <svg class="w-4 h-4 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </summary>
                        <div class="px-6 pb-6 text-base text-surface-600 dark:text-surface-400 leading-relaxed border-t border-surface-100 dark:border-surface-700/50 pt-4" set:html={faq.a} />
                    </details>
                ))}
            </div>
        </div>
    </section>

    <!-- Related Calculators -->
    <section class="reveal-on-scroll">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50">{relatedTitle}</h2>
        <p class="text-surface-500 mt-2">Discover more specialized regression modeling tools.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {relatedItems.map((item, i) => {
          const themes = [
            { accent: 'accent', icon: '📈' },
            { accent: 'primary', icon: '📐' },
            { accent: 'emerald', icon: '🧬' },
            { accent: 'violet', icon: '🔮' },
            { accent: 'cyan', icon: '🔬' },
            { accent: 'rose', icon: '📍' },
          ];
          const t = themes[i % themes.length];
          return (
            <a href={item.url} class="group/card relative p-6 rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 overflow-hidden">
              <div class={`absolute inset-0 bg-gradient-to-br from-${t.accent}-500/0 to-${t.accent}-500/0 group-hover/card:from-${t.accent}-500/5 group-hover/card:to-${t.accent}-500/10 transition-all duration-500`}></div>
              <div class="relative z-10">
                <div class={`w-12 h-12 rounded-xl bg-${t.accent}-100 dark:bg-${t.accent}-900/30 flex items-center justify-center mb-4 group-hover/card:scale-110 transition-transform duration-300 text-xl`}>
                  {t.icon}
                </div>
                <h3 class={`text-lg font-bold text-${t.accent}-700 dark:text-${t.accent}-400 mb-2`}>{item.name}</h3>
                <p class="text-sm text-surface-500 dark:text-surface-400">{item.desc}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // ── Reveal on Scroll (IntersectionObserver) ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── Interactive 3D Tilt Effect (Optimized) ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    let rect: DOMRect | null = null;
    el.addEventListener('mouseenter', () => { rect = el.getBoundingClientRect(); });
    el.addEventListener('mousemove', (e: MouseEvent) => {
      if (!rect) rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -10;
      const rotateY = ((x - centerX) / centerX) * 10;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave', () => {
      rect = null;
      el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
