---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import RegressionCurveCalculator from 'theme/components/RegressionCurveCalculator.astro';
import { mergeTranslations, getLocalizedUrl, extractLocaleFromParams, getLocaleStaticPaths } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const currentLocale = extractLocaleFromParams(Astro.params);
const translations = await mergeTranslations(currentLocale);
const rcc = (translations as any).rcCalc;

const canonicalUrl = new URL(getLocalizedUrl('/regression-curve-calculator/', currentLocale), siteConfig.siteUrl).href;

const whatIsTitle = rcc?.whatIsTitle || 'What Is Regression Curve Analysis?';
const whatIsText = rcc?.whatIsText || '';
const typesTitle = rcc?.typesTitle || 'Regression Model Types';
const typesPoints: string[] = rcc?.typesPoints ?? [];
const whenTitle = rcc?.whenTitle || 'When to Use This Calculator';
const whenPoints: string[] = rcc?.whenPoints ?? [];
const chooseTitle = rcc?.chooseTitle || 'Choosing the Right Model';
const choosePoints: string[] = rcc?.choosePoints ?? [];
const seeAlsoTitle = rcc?.seeAlsoTitle || 'See Also';
const breadcrumb = rcc?.breadcrumb || 'Back to Main Regression Calculator';

const pageTitle = rcc?.title || 'Regression Curve Calculator';
const pageDescription = rcc?.description || 'Analyze relationships between variables with multiple regression model types';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale={currentLocale}
  canonicalUrl={canonicalUrl}
>
  <section class="py-10 md:py-14">
    <div class="max-w-3xl mx-auto text-center">
      <nav class="mb-4 text-sm text-surface-500 dark:text-surface-400">
        <a href={getLocalizedUrl('/', currentLocale)} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
      </nav>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 via-primary-600 to-accent-600 dark:from-primary-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight">
        {pageTitle}
      </h1>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-3xl -mt-2">
    <div class="max-w-4xl mx-auto">
      <RegressionCurveCalculator translations={translations} />
    </div>
  </section>

  <section class="py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <p class="text-lg md:text-xl text-surface-600 dark:text-surface-400 leading-relaxed mb-6">
        {pageDescription}
      </p>
    </div>
  </section>

  <section class="py-8 md:py-12">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200/60 dark:border-surface-700/40 bg-white/60 dark:bg-surface-800/40 backdrop-blur-sm p-6 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-r before:from-primary-500/0 before:to-accent-500/0 hover:before:from-primary-500/5 hover:before:to-accent-500/5 dark:hover:before:from-primary-400/8 dark:hover:before:to-accent-400/8 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-surface-950/40 hover:-translate-y-1 hover:border-primary-200 dark:hover:border-primary-700/50 transition-all duration-300">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-4">{whatIsTitle}</h2>
      <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed" set:html={whatIsText} />
    </div>
  </section>

  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-primary-500/0 before:to-primary-500/0 hover:before:from-primary-500/5 hover:before:to-primary-500/8 dark:hover:before:from-primary-400/8 dark:hover:before:to-primary-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-primary-900/10 hover:-translate-y-1 hover:border-primary-300 dark:hover:border-primary-700/50 transition-all duration-300">
      <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{typesTitle}</h2>
      <ul class="space-y-3">
        {typesPoints.map((point, i) => (
          <li class="flex items-start gap-3 group/item translate-x-0 hover:translate-x-1 transition-transform duration-200" style={`transition-delay: ${i * 40}ms`}>
            <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center group-hover/item:bg-blue-200 dark:group-hover/item:bg-blue-800/40 group-hover/item:scale-110 transition-all duration-200">
              <svg class="w-3 h-3 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
            <div class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">
    <div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-6">
      <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-green-500/0 before:to-emerald-500/0 hover:before:from-green-500/5 hover:before:to-emerald-500/5 dark:hover:before:from-green-400/8 dark:hover:before:to-emerald-400/8 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-green-900/10 hover:-translate-y-1 hover:border-green-300 dark:hover:border-green-700/50 transition-all duration-300">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{whenTitle}</h2>
        <ul class="space-y-3">
          {whenPoints.map((point, i) => (
            <li class="flex items-start gap-3 group/item translate-x-0 hover:translate-x-1 transition-transform duration-200" style={`transition-delay: ${i * 40}ms`}>
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center group-hover/item:bg-green-200 dark:group-hover/item:bg-green-800/40 group-hover/item:scale-110 transition-all duration-200">
                <svg class="w-3 h-3 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
              </span>
              <div class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
            </li>
          ))}
        </ul>
      </div>
      <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-orange-500/0 before:to-amber-500/0 hover:before:from-orange-500/5 hover:before:to-amber-500/5 dark:hover:before:from-orange-400/8 dark:hover:before:to-amber-400/8 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-surface-950/40 hover:-translate-y-1 hover:border-orange-200 dark:hover:border-orange-700/50 transition-all duration-300">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{chooseTitle}</h2>
        <ul class="space-y-3">
          {choosePoints.map((point, i) => (
            <li class="flex items-start gap-3 group/item translate-x-0 hover:translate-x-1 transition-transform duration-200" style={`transition-delay: ${i * 40}ms`}>
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center group-hover/item:bg-orange-200 dark:group-hover/item:bg-orange-800/40 group-hover/item:scale-110 transition-all duration-200">
                <svg class="w-3 h-3 text-orange-600 dark:text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
              </span>
              <div class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-6">{seeAlsoTitle}</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href={getLocalizedUrl('/quadratic-regression-calculator/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-accent-500/0 before:to-accent-500/0 hover:before:from-accent-500/5 hover:before:to-accent-500/8 dark:hover:before:from-accent-400/8 dark:hover:before:to-accent-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-accent-900/10 hover:-translate-y-1 hover:border-accent-300 dark:hover:border-accent-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-accent-700 dark:text-accent-400 group-hover/card:text-accent-800 dark:group-hover/card:text-accent-300">{rcc?.seeAlsoQuad || 'Quadratic Regression Calculator'}</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">{rcc?.seeAlsoQuadDesc || 'Model curved relationships with y = ax² + bx + c'}</p>
        </a>
        <a href={getLocalizedUrl('/multiple-regression-calculator/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-primary-500/0 before:to-primary-500/0 hover:before:from-primary-500/5 hover:before:to-primary-500/8 dark:hover:before:from-primary-400/8 dark:hover:before:to-primary-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-primary-900/10 hover:-translate-y-1 hover:border-primary-300 dark:hover:border-primary-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-primary-700 dark:text-primary-400 group-hover/card:text-primary-800 dark:group-hover/card:text-primary-300">{rcc?.seeAlsoMulti || 'Multiple Regression Calculator'}</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">{rcc?.seeAlsoMultiDesc || 'Use two or more predictors'}</p>
        </a>
        <a href={getLocalizedUrl('/pearson-correlation-calculator/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-emerald-500/0 before:to-emerald-500/0 hover:before:from-emerald-500/5 hover:before:to-emerald-500/8 dark:hover:before:from-emerald-400/8 dark:hover:before:to-emerald-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-emerald-900/10 hover:-translate-y-1 hover:border-emerald-300 dark:hover:border-emerald-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-emerald-700 dark:text-emerald-400 group-hover/card:text-emerald-800 dark:group-hover/card:text-emerald-300">{rcc?.seeAlsoPearson || 'Pearson Correlation Calculator'}</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">{rcc?.seeAlsoPearsonDesc || 'Measure the strength of the linear relationship'}</p>
        </a>
        <a href={getLocalizedUrl('/grubbs-test-calculator/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-amber-500/0 before:to-amber-500/0 hover:before:from-amber-500/5 hover:before:to-amber-500/8 dark:hover:before:from-amber-400/8 dark:hover:before:to-amber-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-amber-900/10 hover:-translate-y-1 hover:border-amber-300 dark:hover:border-amber-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-amber-700 dark:text-amber-400 group-hover/card:text-amber-800 dark:group-hover/card:text-amber-300">{rcc?.seeAlsoGrubbs || "Grubbs' Test Calculator"}</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">{rcc?.seeAlsoGrubbsDesc || 'Detect outliers in your dataset'}</p>
        </a>
        <a href={getLocalizedUrl('/regression-assumptions-checker/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-rose-500/0 before:to-rose-500/0 hover:before:from-rose-500/5 hover:before:to-rose-500/8 dark:hover:before:from-rose-400/8 dark:hover:before:to-rose-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-rose-900/10 hover:-translate-y-1 hover:border-rose-300 dark:hover:border-rose-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-rose-700 dark:text-rose-400 group-hover/card:text-rose-800 dark:group-hover/card:text-rose-300">{rcc?.seeAlsoAssumptions || 'Regression Assumptions Checker'}</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">{rcc?.seeAlsoAssumptionsDesc || 'Verify that your data meets the four OLS assumptions'}</p>
        </a>
        <a href={getLocalizedUrl('/exponential-regression-calculator/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-accent-500/0 before:to-accent-500/0 hover:before:from-accent-500/5 hover:before:to-accent-500/8 dark:hover:before:from-accent-400/8 dark:hover:before:to-accent-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-accent-900/10 hover:-translate-y-1 hover:border-accent-300 dark:hover:border-accent-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-accent-700 dark:text-accent-400 group-hover/card:text-accent-800 dark:group-hover/card:text-accent-300">{rcc?.seeAlsoExp || 'Exponential Regression Calculator'}</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">{rcc?.seeAlsoExpDesc || 'Model growth and decay with y = a·e^(bx)'}</p>
        </a>
        <a href={getLocalizedUrl('/least-squares-regression-line-calculator/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-primary-500/0 before:to-primary-500/0 hover:before:from-primary-500/5 hover:before:to-primary-500/8 dark:hover:before:from-primary-400/8 dark:hover:before:to-primary-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-primary-900/10 hover:-translate-y-1 hover:border-primary-300 dark:hover:border-primary-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-primary-700 dark:text-primary-400 group-hover/card:text-primary-800 dark:group-hover/card:text-primary-300">{rcc?.seeAlsoLSRL || 'Least Squares Line Calculator'}</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">{rcc?.seeAlsoLSRLDesc || 'Compute the OLS best fit line'}</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
