---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import { mergeTranslations, getLocalizedUrl, extractLocaleFromParams, getLocaleStaticPaths } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const currentLocale = extractLocaleFromParams(Astro.params);
const translations = await mergeTranslations(currentLocale);
const canonicalUrl = new URL(getLocalizedUrl('/terms/', currentLocale), siteConfig.siteUrl).href;
---

<BaseLayout
  title={translations.terms.title}
  description={translations.terms.description}
  locale={currentLocale}
  canonicalUrl={canonicalUrl}
>
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 to-accent-600 bg-clip-text text-transparent">
        {translations.terms.title}
      </h1>

      {translations.terms.lastUpdated && (
        <p class="mt-3 text-sm text-surface-400">
          {translations.terms.lastUpdated}
        </p>
      )}

      <div class="mt-10 rounded-2xl border border-surface-200/60 bg-white p-8 md:p-12 shadow-sm">
        <p class="text-surface-600 leading-relaxed text-lg">
          {translations.terms.intro}
        </p>
        <div class="mt-6 text-surface-700 leading-relaxed">
          <p class="text-surface-600 leading-relaxed">{translations.terms.content}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
