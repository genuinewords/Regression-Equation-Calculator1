---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import PearsonCorrelationCalculator from 'theme/components/PearsonCorrelationCalculator.astro';
import { mergeTranslations, getLocalizedUrl, extractLocaleFromParams, getLocaleStaticPaths } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const currentLocale = extractLocaleFromParams(Astro.params);
const translations = await mergeTranslations(currentLocale);
const pc = (translations as any).pearson;

const canonicalUrl = new URL(getLocalizedUrl('/pearson-correlation-calculator/', currentLocale), siteConfig.siteUrl).href;

const whatIsTitle = pc?.whatIsTitle || 'What Is the Pearson Correlation Coefficient?';
const whatIsText = pc?.whatIsText || '';
const interpretTitle = pc?.interpretTitle || 'How to Interpret Pearson\'s r';
const interpretPoints: string[] = pc?.interpretPoints ?? [];
const whenTitle = pc?.whenTitle || 'When to Use Pearson Correlation';
const whenPoints: string[] = pc?.whenPoints ?? [];
const avoidTitle = pc?.avoidTitle || 'When to Avoid Pearson Correlation';
const avoidPoints: string[] = pc?.avoidPoints ?? [];

const pageTitle = pc?.title || 'Pearson Correlation Calculator';
const pageDescription = pc?.description || 'Calculate the Pearson correlation coefficient between two variables with step-by-step solutions.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale={currentLocale}
  canonicalUrl={canonicalUrl}
>
  <section class="py-10 md:py-14">
    <div class="max-w-3xl mx-auto text-center">
      <nav class="mb-4 text-sm text-surface-500 dark:text-surface-400">
        <a href={getLocalizedUrl('/', currentLocale)} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Back to Main Regression Calculator</a>
      </nav>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 via-primary-600 to-accent-600 dark:from-primary-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight">
        {pageTitle}
      </h1>
      <p class="mt-5 text-lg md:text-xl text-surface-600 dark:text-surface-400 max-w-2xl mx-auto leading-relaxed">
        {pageDescription}
      </p>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-3xl -mt-2">
    <div class="max-w-4xl mx-auto">
      <PearsonCorrelationCalculator translations={translations} />
    </div>
  </section>

  <section class="py-8 md:py-12">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200/60 dark:border-surface-700/40 bg-white/60 dark:bg-surface-800/40 backdrop-blur-sm p-6 relative overflow-hidden before:absolute before:inset-0 before:bg-gradient-to-r before:from-primary-500/0 before:to-accent-500/0 hover:before:from-primary-500/5 hover:before:to-accent-500/5 dark:hover:before:from-primary-400/8 dark:hover:before:to-accent-400/8 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-surface-950/40 hover:-translate-y-1 hover:border-primary-200 dark:hover:border-primary-700/50 transition-all duration-300">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-4">{whatIsTitle}</h2>
      <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed" set:html={whatIsText} />
    </div>
  </section>

  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">
    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-6">
      <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:absolute before:inset-0 before:bg-gradient-to-br before:from-primary-500/0 before:to-primary-500/0 hover:before:from-primary-500/5 hover:before:to-primary-500/8 dark:hover:before:from-primary-400/8 dark:hover:before:to-primary-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-primary-900/10 hover:-translate-y-1 hover:border-primary-300 dark:hover:border-primary-700/50 transition-all duration-300">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{interpretTitle}</h2>
        <ul class="space-y-3">
          {interpretPoints.map((point, i) => (
            <li class="flex items-start gap-3 group/item translate-x-0 hover:translate-x-1 transition-transform duration-200" style={`transition-delay: ${i * 40}ms`}>
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center group-hover/item:bg-primary-200 dark:group-hover/item:bg-primary-800/40 group-hover/item:scale-110 transition-all duration-200">
                <svg class="w-3 h-3 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">{point}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:absolute before:inset-0 before:bg-gradient-to-br before:from-accent-500/0 before:to-accent-500/0 hover:before:from-accent-500/5 hover:before:to-accent-500/8 dark:hover:before:from-accent-400/8 dark:hover:before:to-accent-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-accent-900/10 hover:-translate-y-1 hover:border-accent-300 dark:hover:border-accent-700/50 transition-all duration-300">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{whenTitle}</h2>
        <ul class="space-y-3">
          {whenPoints.map((point, i) => (
            <li class="flex items-start gap-3 group/item translate-x-0 hover:translate-x-1 transition-transform duration-200" style={`transition-delay: ${i * 40}ms`}>
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center group-hover/item:bg-accent-200 dark:group-hover/item:bg-accent-800/40 group-hover/item:scale-110 transition-all duration-200">
                <svg class="w-3 h-3 text-accent-600 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
              </span>
              <span class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">{point}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12">
    <div class="content-box max-w-3xl mx-auto rounded-2xl border border-surface-200/60 dark:border-surface-700/40 bg-white/60 dark:bg-surface-800/40 backdrop-blur-sm p-6 relative overflow-hidden before:absolute before:inset-0 before:bg-gradient-to-r before:from-red-500/0 before:to-orange-500/0 hover:before:from-red-500/5 hover:before:to-orange-500/5 dark:hover:before:from-red-400/8 dark:hover:before:to-orange-400/8 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-surface-950/40 hover:-translate-y-1 hover:border-red-200 dark:hover:border-red-700/50 transition-all duration-300">
      <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{avoidTitle}</h2>
      <ul class="space-y-3">
        {avoidPoints.map((point, i) => (
          <li class="flex items-start gap-3 group/item translate-x-0 hover:translate-x-1 transition-transform duration-200" style={`transition-delay: ${i * 40}ms`}>
            <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center group-hover/item:bg-red-200 dark:group-hover/item:bg-red-800/40 group-hover/item:scale-110 transition-all duration-200">
              <svg class="w-3 h-3 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </span>
            <span class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">{point}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-6">See Also</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href={getLocalizedUrl('/linear-regression-calculator/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-accent-500/0 before:to-accent-500/0 hover:before:from-accent-500/5 hover:before:to-accent-500/8 dark:hover:before:from-accent-400/8 dark:hover:before:to-accent-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-accent-900/10 hover:-translate-y-1 hover:border-accent-300 dark:hover:border-accent-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-accent-700 dark:text-accent-400 group-hover/card:text-accent-800 dark:group-hover/card:text-accent-300">Linear Regression Calculator</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">Calculate y = mx + b with step-by-step</p>
        </a>
        <a href={getLocalizedUrl('/quadratic-regression-calculator/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-primary-500/0 before:to-primary-500/0 hover:before:from-primary-500/5 hover:before:to-primary-500/8 dark:hover:before:from-primary-400/8 dark:hover:before:to-primary-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-primary-900/10 hover:-translate-y-1 hover:border-primary-300 dark:hover:border-primary-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-primary-700 dark:text-primary-400 group-hover/card:text-primary-800 dark:group-hover/card:text-primary-300">Quadratic Regression Calculator</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">Model curved relationships</p>
        </a>
        <a href={getLocalizedUrl('/multiple-regression-calculator/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-emerald-500/0 before:to-emerald-500/0 hover:before:from-emerald-500/5 hover:before:to-emerald-500/8 dark:hover:before:from-emerald-400/8 dark:hover:before:to-emerald-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-emerald-900/10 hover:-translate-y-1 hover:border-emerald-300 dark:hover:border-emerald-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-emerald-700 dark:text-emerald-400 group-hover/card:text-emerald-800 dark:group-hover/card:text-emerald-300">Multiple Regression Calculator</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">Use two or more predictors</p>
        </a>
        <a href={getLocalizedUrl('/regression-assumptions-checker/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-amber-500/0 before:to-amber-500/0 hover:before:from-amber-500/5 hover:before:to-amber-500/8 dark:hover:before:from-amber-400/8 dark:hover:before:to-amber-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-amber-900/10 hover:-translate-y-1 hover:border-amber-300 dark:hover:border-amber-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-amber-700 dark:text-amber-400 group-hover/card:text-amber-800 dark:group-hover/card:text-amber-300">Regression Assumptions Checker</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">Verify your data meets OLS assumptions</p>
        </a>
        <a href={getLocalizedUrl('/grubbs-test-calculator/', currentLocale)} class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-rose-500/0 before:to-rose-500/0 hover:before:from-rose-500/5 hover:before:to-rose-500/8 dark:hover:before:from-rose-400/8 dark:hover:before:to-rose-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-rose-900/10 hover:-translate-y-1 hover:border-rose-300 dark:hover:border-rose-700/50 transition-all duration-300 group/card">
          <h3 class="text-base font-bold text-rose-700 dark:text-rose-400 group-hover/card:text-rose-800 dark:group-hover/card:text-rose-300">Grubbs' Test Calculator</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400 mt-1">Detect outliers in your dataset</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
