---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import PearsonCorrelationCalculator from 'theme/components/PearsonCorrelationCalculator.astro';
import ToolInfoBox from 'theme/components/ToolInfoBox.astro';
import { mergeTranslations, getLocalizedUrl, extractLocaleFromParams, getLocaleStaticPaths } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/pearson-hero.png';

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const currentLocale = extractLocaleFromParams(Astro.params);
const translations = await mergeTranslations(currentLocale);
const pc = (translations as any).pearson;

const canonicalUrl = new URL(getLocalizedUrl('/pearson-correlation-calculator/', currentLocale), siteConfig.siteUrl).href;

const whatIsTitle = pc?.whatIsTitle || 'What Is Pearson Correlation?';
const whatIsText = pc?.whatIsText || '';
const howWorksTitle = pc?.howWorksTitle || 'How Pearson Correlation Works';
const howWorksPoints: string[] = pc?.howWorksPoints ?? [];
const interTitle = pc?.interTitle || 'Interpreting the Correlation Coefficient (r)';
const interPoints: string[] = pc?.interPoints ?? [];
const breadcrumb = pc?.breadcrumb || 'Back to Main Regression Calculator';

const pageTitle = pc?.title || 'Pearson Correlation Calculator';
const pageDescription = pc?.description || 'Measure the strength and direction of linear relationships between two variables';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale={currentLocale}
  canonicalUrl={canonicalUrl}
>
  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
        <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] bg-emerald-100/30 dark:bg-emerald-900/10 blur-[100px] rounded-full animate-pulse"></div>
        <div class="absolute bottom-1/4 left-1/3 w-[350px] h-[350px] bg-primary-100/30 dark:bg-primary-900/10 blur-[90px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 text-center lg:text-left reveal-on-scroll">
          <nav class="mb-6 text-sm font-medium flex items-center justify-center lg:justify-start gap-2">
            <a href={getLocalizedUrl('/', currentLocale)} class="text-surface-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
          </nav>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-emerald-700 via-emerald-600 to-primary-600 dark:from-emerald-400 dark:via-emerald-500 dark:to-primary-400 bg-clip-text text-transparent leading-tight mb-6">
            {pageTitle}
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-8">
            {pageDescription}
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="#calculator-tool" class="px-8 py-3 rounded-xl bg-emerald-600 text-white font-semibold shadow-lg shadow-emerald-600/20 hover:bg-emerald-700 hover:shadow-xl hover:shadow-emerald-600/30 transition-all duration-300 hover:-translate-y-1">
              {translations.common?.calculateNow || 'Calculate Now'}
            </a>
          </div>
        </div>
        <div class="flex-1 w-full max-w-lg lg:max-w-none reveal-on-scroll" style="transition-delay: 200ms">
          <div class="relative group" data-tilt>
            <div class="absolute -inset-4 bg-gradient-to-r from-emerald-500/20 to-primary-500/20 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-500"></div>
            <div class="relative overflow-hidden rounded-3xl border border-white/20 shadow-2xl">
              <Image
                src={heroImage}
                alt="Pearson Correlation Visualization"
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                width={800}
                densities={[1, 2]}
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/20 via-transparent to-transparent opacity-40"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator Tool -->
  <section id="calculator-tool" class="py-12 md:py-16 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <PearsonCorrelationCalculator translations={translations} />
    </div>
  </section>

  <!-- Tool Info Box -->
  <ToolInfoBox
    toolName={pageTitle}
    keyPoints={[
      {
        icon: "🧬",
        title: translations.common?.strengthTitle || "Relationship Strength",
        description: pc?.strengthPoint || "Measure how closely two variables move together using the 'r' coefficient."
      },
      {
        icon: "📊",
        title: translations.common?.statsTitle || "Statistical Output",
        description: pc?.statsPoint || "Get the correlation coefficient (r), coefficient of determination (r²), and p-value."
      },
      {
        icon: "🧪",
        title: translations.common?.significanceTitle || "Significance Testing",
        description: pc?.sigPoint || "Determine if the observed relationship is statistically significant or due to chance."
      }
    ]}
    highlightTip={pc?.tip || "Pearson correlation ranges from -1 to 1. A value of 0 indicates no linear relationship."}
  />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-12 py-16">
    <!-- What Is -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-emerald-600 rounded-full"></span>
          {whatIsTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg" set:html={whatIsText} />
      </div>
    </section>

    <!-- How It Works -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-primary-600 rounded-full"></span>
          {howWorksTitle}
        </h2>
        <ul class="space-y-4">
          {howWorksPoints.map((point, i) => (
            <li class="flex items-start gap-4 p-4 rounded-xl bg-surface-50/50 dark:bg-surface-900/40 border border-surface-100 dark:border-surface-700/40 hover:border-primary-300 transition-all">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-sm font-bold text-primary-700 dark:text-primary-400">{i + 1}</span>
              <div class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed pt-1" set:html={point} />
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Interpretation -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-accent-600 rounded-full"></span>
          {interTitle}
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {interPoints.map((point) => (
            <div class="flex items-start gap-3 p-4 rounded-xl border border-surface-100 dark:border-surface-700/50 bg-surface-50/30 dark:bg-surface-900/20">
              <div class="w-5 h-5 rounded-full bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center text-accent-600 dark:text-accent-400 flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // ── Reveal on Scroll ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── 3D Tilt ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    let rect: DOMRect | null = null;
    el.addEventListener('mouseenter', () => { rect = el.getBoundingClientRect(); });
    el.addEventListener('mousemove', (e: MouseEvent) => {
      if (!rect) rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -10;
      const rotateY = ((x - centerX) / centerX) * 10;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave', () => {
      rect = null;
      el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
