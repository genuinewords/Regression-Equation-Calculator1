---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import { mergeTranslations, getLocalizedUrl, extractLocaleFromParams, getLocaleStaticPaths } from 'theme/i18n/utils';
import { LOCALES } from 'theme/i18n/types';
import { getCollection } from 'astro:content';
import siteConfig from 'src/data/site-config.json';

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const locale = extractLocaleFromParams(Astro.params);
const translations = await mergeTranslations(locale);

const prefix = `/${locale}`;

const staticPages = [
  { href: `${prefix}/`, label: translations.nav?.home ?? 'Home' },
  { href: `${prefix}/exponential-regression-calculator/`, label: (translations as any).nav?.expCalc ?? 'Exponential Regression Calculator' },
  { href: `${prefix}/least-squares-regression-line-calculator/`, label: (translations as any).nav?.lsrlCalc ?? 'Least Squares Line Calculator' },
  { href: `${prefix}/regression-curve-calculator/`, label: (translations as any).nav?.rcCalc ?? 'Regression Curve Calculator' },
  { href: `${prefix}/quadratic-regression-calculator/`, label: (translations as any).nav?.quadCalc ?? 'Quadratic Regression Calculator' },
  { href: `${prefix}/multiple-regression-calculator/`, label: (translations as any).nav?.multiCalc ?? 'Multiple Regression Calculator' },
  { href: `${prefix}/pearson-correlation-calculator/`, label: (translations as any).nav?.pearsonCorrelation ?? 'Pearson r Calculator' },
  { href: `${prefix}/grubbs-test-calculator/`, label: (translations as any).nav?.grubbsTest ?? "Grubbs' Test" },
  { href: `${prefix}/regression-assumptions-checker/`, label: (translations as any).nav?.assumptionsChecker ?? 'Assumptions Checker' },
  { href: `${prefix}/about-us/`, label: translations.nav?.aboutUs ?? 'About Us' },
  { href: `${prefix}/contact-us/`, label: translations.nav?.contactUs ?? 'Contact Us' },
  { href: `${prefix}/terms/`, label: translations.nav?.terms ?? 'Terms' },
  { href: `${prefix}/privacy/`, label: translations.nav?.privacy ?? 'Privacy' },
  { href: `${prefix}/sitemap/`, label: translations.nav?.sitemap ?? 'Sitemap' },
];

const blogPosts = await getCollection('blog');
const sortedPosts = blogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const canonicalUrl = new URL(`${prefix}/sitemap/`, siteConfig.siteUrl).href;
---

<BaseLayout
  title={translations.sitemap.title}
  description={translations.sitemap.description}
  locale={locale}
  canonicalUrl={canonicalUrl}
>
  <section class="relative py-16 md:py-24 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary-100/30 dark:bg-primary-900/10 blur-[120px] rounded-full animate-pulse"></div>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="reveal-on-scroll">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 via-primary-600 to-accent-600 dark:from-primary-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight">
          {translations.sitemap.title}
        </h1>
        <p class="mt-4 text-lg text-surface-600 dark:text-surface-400 max-w-2xl leading-relaxed">
          {translations.sitemap.description}
        </p>
      </div>

      <div class="mt-16 space-y-20">
        <!-- Main Pages -->
        <div class="reveal-on-scroll">
          <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-8 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-primary-600 rounded-full"></span>
            {translations.common?.mainToolsTitle ?? 'Main Tools & Pages'}
          </h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {staticPages.map((page) => (
              <a
                href={page.href}
                class="group flex items-center gap-3 rounded-2xl border border-surface-200/60 dark:border-surface-700/40 bg-white/50 dark:bg-surface-800/50 backdrop-blur-sm px-6 py-4 text-surface-700 dark:text-surface-300 font-medium shadow-sm hover:shadow-xl hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300"
              >
                <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-primary-600 dark:text-primary-400 group-hover:scale-110 transition-transform">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                </span>
                {page.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Languages -->
        <div class="reveal-on-scroll">
          <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-8 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-accent-600 rounded-full"></span>
            {translations.common?.languagesTitle ?? 'Languages'}
          </h2>
          <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-4">
            {LOCALES.map((loc) => (
              <a
                href={getLocalizedUrl('/sitemap/', loc)}
                class={`flex items-center gap-3 rounded-2xl border px-6 py-4 font-bold shadow-sm hover:shadow-xl transition-all duration-300 ${loc === locale ? 'border-primary-400 bg-primary-50 dark:bg-primary-900/20 text-primary-700 dark:text-primary-400' : 'border-surface-200/60 dark:border-surface-700/40 bg-white/50 dark:bg-surface-800/50 text-surface-700 dark:text-surface-300'}`}
              >
                <span class="text-xl">🌐</span>
                {loc.toUpperCase()}
              </a>
            ))}
          </div>
        </div>

        <!-- Blog Posts -->
        <div class="reveal-on-scroll">
          <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-8 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-purple-600 rounded-full"></span>
            {translations.blog.title}
          </h2>
          <div class="grid gap-4">
            {sortedPosts.map((post) => {
              const slug = post.id.replace(/\.(md|mdx)$/, '');
              return (
                <a
                  href={`${prefix}/blog/${slug}/`}
                  class="flex items-center gap-4 rounded-2xl border border-surface-200/60 dark:border-surface-700/40 bg-white/50 dark:bg-surface-800/50 backdrop-blur-sm px-6 py-4 text-surface-700 dark:text-surface-300 font-medium shadow-sm hover:shadow-xl hover:border-purple-300 dark:hover:border-purple-700 transition-all duration-300"
                >
                  <span class="text-surface-400 dark:text-surface-500 text-xs shrink-0">{post.data.date.toLocaleDateString()}</span>
                  <span class="flex-grow">{post.data.title}</span>
                  <svg class="w-4 h-4 text-surface-400 group-hover:text-purple-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  revealElements.forEach((el) => revealObserver.observe(el));
</script>

<style>
  .reveal-on-scroll { opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1); }
  .reveal-on-scroll.revealed { opacity: 1; transform: translateY(0); }
</style>
