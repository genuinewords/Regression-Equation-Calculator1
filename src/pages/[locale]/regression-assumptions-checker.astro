---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import RegressionAssumptionsChecker from 'theme/components/RegressionAssumptionsChecker.astro';
import ToolInfoBox from 'theme/components/ToolInfoBox.astro';
import { mergeTranslations, getLocalizedUrl, extractLocaleFromParams, getLocaleStaticPaths } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const currentLocale = extractLocaleFromParams(Astro.params);
const translations = await mergeTranslations(currentLocale);
const rac = (translations as any).assumptionsChecker;

const canonicalUrl = new URL(getLocalizedUrl('/regression-assumptions-checker/', currentLocale), siteConfig.siteUrl).href;

const whatIsTitle = rac?.whatIsTitle || 'What are Regression Assumptions?';
const whatIsText = rac?.whatIsText || '';
const whyTitle = rac?.whyTitle || 'Why Check Regression Assumptions?';
const whyPoints: string[] = rac?.whyPoints ?? [];
const breadcrumb = rac?.breadcrumb || 'Back to Main Regression Calculator';

const pageTitle = rac?.title || 'Regression Assumptions Checker';
const pageDescription = rac?.description || 'Verify the four pillars of OLS regression: Linearity, Independence, Homoscedasticity, and Normality';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale={currentLocale}
  canonicalUrl={canonicalUrl}
>
  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
        <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] bg-rose-100/30 dark:bg-rose-900/10 blur-[100px] rounded-full animate-pulse"></div>
        <div class="absolute bottom-1/4 left-1/3 w-[350px] h-[350px] bg-primary-100/30 dark:bg-primary-900/10 blur-[90px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 text-center lg:text-left reveal-on-scroll">
          <nav class="mb-6 text-sm font-medium flex items-center justify-center lg:justify-start gap-2">
            <a href={getLocalizedUrl('/', currentLocale)} class="text-surface-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
          </nav>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-rose-700 via-rose-600 to-primary-600 dark:from-rose-400 dark:via-rose-500 dark:to-primary-400 bg-clip-text text-transparent leading-tight mb-6">
            {pageTitle}
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-8">
            {pageDescription}
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="#calculator-tool" class="px-8 py-3 rounded-xl bg-rose-600 text-white font-semibold shadow-lg shadow-rose-600/20 hover:bg-rose-700 hover:shadow-xl hover:shadow-rose-600/30 transition-all duration-300 hover:-translate-y-1">
              {translations.common?.checkNow || 'Check Now'}
            </a>
          </div>
        </div>
        <div class="flex-1 w-full max-w-lg lg:max-w-none reveal-on-scroll" style="transition-delay: 200ms">
          <div class="relative group" data-tilt>
            <div class="absolute -inset-4 bg-gradient-to-r from-rose-500/20 to-primary-500/20 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-500"></div>
            <div class="relative overflow-hidden rounded-3xl border border-white/20 shadow-2xl">
              <img
                src="/images/assumptions-hero.png"
                alt="Regression Assumptions Diagnostics Visualization"
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                width="600"
                height="400"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/20 via-transparent to-transparent opacity-40"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator Tool -->
  <section id="calculator-tool" class="py-12 md:py-16 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <RegressionAssumptionsChecker translations={translations} />
    </div>
  </section>

  <!-- Tool Info Box -->
  <ToolInfoBox
    toolName={pageTitle}
    keyPoints={[
      {
        icon: "✅",
        title: translations.common?.validityTitle || "Model Validity",
        description: rac?.validPoint || "Ensure your regression results are reliable and your p-values are accurate."
      },
      {
        icon: "📊",
        title: translations.common?.diagnosticsTitle || "Automated Tests",
        description: rac?.diagPoint || "Runs statistical tests for linearity, normality, and homoscedasticity."
      },
      {
        icon: "🛠️",
        title: translations.common?.fixTitle || "Remediation",
        description: rac?.fixPoint || "Get expert advice on how to fix violated assumptions in your dataset."
      }
    ]}
    highlightTip={rac?.tip || "Violating assumptions can lead to biased estimates and incorrect scientific conclusions."}
  />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-12 py-16">
    <!-- What Is -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-rose-600 rounded-full"></span>
          {whatIsTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg" set:html={whatIsText} />
      </div>
    </section>

    <!-- Why Check -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-primary-600 rounded-full"></span>
          {whyTitle}
        </h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {whyPoints.map((point) => (
            <div class="flex items-start gap-4 p-4 rounded-xl bg-surface-50/50 dark:bg-surface-900/40 border border-surface-100 dark:border-surface-700/40 hover:border-primary-300 transition-all">
              <div class="w-6 h-6 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-primary-600 dark:text-primary-400 flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed" set:html={point} />
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // ── Reveal on Scroll ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── 3D Tilt ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    let rect: DOMRect | null = null;
    el.addEventListener('mouseenter', () => { rect = el.getBoundingClientRect(); });
    el.addEventListener('mousemove', (e: MouseEvent) => {
      if (!rect) rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -10;
      const rotateY = ((x - centerX) / centerX) * 10;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave', () => {
      rect = null;
      el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
