---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import QuadraticRegressionCalculator from 'theme/components/QuadraticRegressionCalculator.astro';
import ToolInfoBox from 'theme/components/ToolInfoBox.astro';
import { mergeTranslations, getLocalizedUrl, extractLocaleFromParams, getLocaleStaticPaths } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/quadratic-hero.png';

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const currentLocale = extractLocaleFromParams(Astro.params);
const translations = await mergeTranslations(currentLocale);
const qc = (translations as any).quadCalc;

const canonicalUrl = new URL(getLocalizedUrl('/quadratic-regression-calculator/', currentLocale), siteConfig.siteUrl).href;

const whatIsTitle = qc?.whatIsTitle || 'What Is Quadratic Regression?';
const whatIsText = qc?.whatIsText || '';
const howWorksTitle = qc?.howWorksTitle || 'How Quadratic Regression Works';
const howWorksPoints: string[] = qc?.howWorksPoints ?? [];
const whenTitle = qc?.whenTitle || 'When to Use Quadratic Regression';
const whenPoints: string[] = qc?.whenPoints ?? [];
const avoidTitle = qc?.avoidTitle || 'When to Avoid Quadratic Regression';
const avoidPoints: string[] = qc?.avoidPoints ?? [];
const breadcrumb = qc?.breadcrumb || 'Back to Main Regression Calculator';

const pageTitle = qc?.title || 'Quadratic Regression Calculator';
const pageDescription = qc?.description || 'Model curved relationships with y = ax² + bx + c';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale={currentLocale}
  canonicalUrl={canonicalUrl}
>
  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
        <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] bg-accent-100/30 dark:bg-accent-900/10 blur-[100px] rounded-full animate-pulse"></div>
        <div class="absolute bottom-1/4 left-1/3 w-[350px] h-[350px] bg-primary-100/30 dark:bg-primary-900/10 blur-[90px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 text-center lg:text-left reveal-on-scroll">
          <nav class="mb-6 text-sm font-medium flex items-center justify-center lg:justify-start gap-2">
            <a href={getLocalizedUrl('/', currentLocale)} class="text-surface-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
          </nav>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-accent-700 via-accent-600 to-primary-600 dark:from-accent-400 dark:via-accent-500 dark:to-primary-400 bg-clip-text text-transparent leading-tight mb-6">
            {pageTitle}
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-8">
            {pageDescription}
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="#calculator-tool" class="px-8 py-3 rounded-xl bg-accent-600 text-white font-semibold shadow-lg shadow-accent-600/20 hover:bg-accent-700 hover:shadow-xl hover:shadow-accent-600/30 transition-all duration-300 hover:-translate-y-1">
              {translations.common?.calculateNow || 'Calculate Now'}
            </a>
          </div>
        </div>
        <div class="flex-1 w-full max-w-lg lg:max-w-none reveal-on-scroll" style="transition-delay: 200ms">
          <div class="relative group" data-tilt>
            <div class="absolute -inset-4 bg-gradient-to-r from-accent-500/20 to-primary-500/20 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-500"></div>
            <div class="relative overflow-hidden rounded-3xl border border-white/20 shadow-2xl">
              <Image
                src={heroImage}
                alt="Quadratic Regression Visualization"
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                width={800}
                densities={[1, 2]}
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/20 via-transparent to-transparent opacity-40"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator Tool -->
  <section id="calculator-tool" class="py-12 md:py-16 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <QuadraticRegressionCalculator translations={translations} />
    </div>
  </section>

  <!-- Tool Info Box -->
  <ToolInfoBox
    toolName={pageTitle}
    keyPoints={[
      {
        icon: "📐",
        title: translations.common?.curveModeling || "Curve Modeling",
        description: qc?.curvePoint || "Model non-linear relationships that follow a parabolic or U-shaped curve."
      },
      {
        icon: "🎯",
        title: translations.common?.vertexTitle || "Vertex Analysis",
        description: qc?.vertexPoint || "Calculate the peak or trough of the curve to find optimal values."
      },
      {
        icon: "📈",
        title: translations.common?.statsTitle || "Statistical Output",
        description: qc?.statsPoint || "Get the equation y = ax² + bx + c, R-squared value, and predictive diagnostics."
      }
    ]}
    highlightTip={qc?.tip || "Quadratic regression is perfect for modeling projectile motion, acceleration, and price-demand curves."}
    translations={translations}
  />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-12 py-16">
    <!-- What Is -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-accent-600 rounded-full"></span>
          {whatIsTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg" set:html={whatIsText} />
      </div>
    </section>

    <!-- How It Works -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-primary-600 rounded-full"></span>
          {howWorksTitle}
        </h2>
        <ul class="space-y-4">
          {howWorksPoints.map((point, i) => (
            <li class="flex items-start gap-4 p-4 rounded-xl bg-surface-50/50 dark:bg-surface-900/40 border border-surface-100 dark:border-surface-700/40 hover:border-primary-300 transition-all">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-sm font-bold text-primary-700 dark:text-primary-400">{i + 1}</span>
              <div class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed pt-1" set:html={point} />
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- When to Use / Avoid -->
    <section class="reveal-on-scroll">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="p-8 rounded-3xl border border-surface-200 dark:border-surface-700 bg-white dark:bg-surface-800 shadow-lg">
          <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-emerald-600 rounded-full"></span>
            {whenTitle}
          </h2>
          <ul class="space-y-3">
            {whenPoints.map(point => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-600 dark:text-emerald-400 flex-shrink-0 mt-0.5">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
              </li>
            ))}
          </ul>
        </div>
        <div class="p-8 rounded-3xl border border-surface-200 dark:border-surface-700 bg-white dark:bg-surface-800 shadow-lg">
          <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-orange-600 rounded-full"></span>
            {avoidTitle}
          </h2>
          <ul class="space-y-3">
            {avoidPoints.map(point => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-600 dark:text-orange-400 flex-shrink-0 mt-0.5">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M6 18L18 6M6 6l12 12"/></svg>
                </div>
                <span class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={point} />
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // ── Reveal on Scroll ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── 3D Tilt ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    let rect: DOMRect | null = null;
    el.addEventListener('mouseenter', () => { rect = el.getBoundingClientRect(); });
    el.addEventListener('mousemove', (e: MouseEvent) => {
      if (!rect) rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -10;
      const rotateY = ((x - centerX) / centerX) * 10;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave', () => {
      rect = null;
      el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
