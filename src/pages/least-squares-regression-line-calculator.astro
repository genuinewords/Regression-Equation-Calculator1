---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import LeastSquaresRegressionLineCalculator from 'theme/components/LeastSquaresRegressionLineCalculator.astro';
import ToolInfoBox from 'theme/components/ToolInfoBox.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/pearson-hero.png';

const locale = 'en';
const translations = await mergeTranslations(locale);
const lsc = (translations as any).lsrlCalc;

const canonicalUrl = new URL('/least-squares-regression-line-calculator/', siteConfig.siteUrl).href;

const breadcrumb = lsc?.breadcrumb || 'Back to Main Regression Calculator';

const whatIsTitle = lsc?.whatIsTitle || 'What Is the Least Squares Regression Line?';
const whatIsText = lsc?.whatIsText || '';

const formulaTitle = lsc?.formulaTitle || 'Least Squares Regression Line Formula Calculator Explained';
const formulaText = lsc?.formulaText || '';
const formulaTable = lsc?.formulaTable || '';
const formulas: string[] = lsc?.formulas ?? [];

const howCalcTitle = lsc?.howCalcTitle || 'How to Calculate Least Squares Regression Line';
const howCalcManual = lsc?.howCalcManual || '';
const howCalcSteps: string[] = lsc?.howCalcSteps ?? [];

const calcStepsTitle = lsc?.calcStepsTitle || 'Least Squares Regression Line Calculator Steps';
const calcStepsIntro = lsc?.calcStepsIntro || '';
const calcStepsPoints: string[] = lsc?.calcStepsPoints ?? [];

const tableDataTitle = lsc?.tableDataTitle || 'Least Squares Regression Calculator from Table Data';
const tableDataIntro = lsc?.tableDataIntro || '';
const tableDataTable = lsc?.tableDataTable || '';
const tableDataSteps: string[] = lsc?.tableDataSteps ?? [];

const residualsTitle = lsc?.residualsTitle || 'Residual Analysis and Diagnostics';
const residualsText = lsc?.residualsText || '';

const predictionTitle = lsc?.predictionTitle || 'Least Squares Regression Line Prediction Calculator';
const predictionText = lsc?.predictionText || '';
const predictionPoints: string[] = lsc?.predictionPoints ?? [];

const howDoTitle = lsc?.howDoTitle || 'How to Find Least Squares Regression Line on Calculator';
const howDoIntro = lsc?.howDoIntro || '';
const howDoTi84 = lsc?.howDoTi84 || 'TI-84 Plus';
const howDoTi84Steps: string[] = lsc?.howDoTi84Steps ?? [];
const howDoTi83 = lsc?.howDoTi83 || 'TI-83 Plus';
const howDoTi83Steps: string[] = lsc?.howDoTi83Steps ?? [];
const howDoCasio = lsc?.howDoCasio || 'Casio fx-9860GII';
const howDoCasioSteps: string[] = lsc?.howDoCasioSteps ?? [];
const howDoTiNspire = lsc?.howDoTiNspire || 'TI-Nspire';
const howDoTiNspireSteps: string[] = lsc?.howDoTiNspireSteps ?? [];
const howDoNote = lsc?.howDoNote || '';

const graphCalcTitle = lsc?.graphCalcTitle || 'Least Squares Regression on Graphing Calculator';
const graphCalcIntro = lsc?.graphCalcIntro || '';
const graphCalcSteps: string[] = lsc?.graphCalcSteps ?? [];

const assumptionsTitle = lsc?.assumptionsTitle || 'Assumptions of Least Squares Regression';
const assumptionsText = lsc?.assumptionsText || '';
const assumptionsPoints: string[] = lsc?.assumptionsPoints ?? [];

const whenTitle = lsc?.whenTitle || 'When to Use Least Squares Regression';
const whenText = lsc?.whenText || '';
const whenTable = lsc?.whenTable || '';
const whenPoints: string[] = lsc?.whenPoints ?? [];
const avoidTitle = lsc?.avoidTitle || 'When to Avoid Least Squares Regression';
const avoidPoints: string[] = lsc?.avoidPoints ?? [];

const faqTitle = lsc?.faqTitle || 'Frequently Asked Questions';
const faqs: Array<{q: string; a: string}> = lsc?.faqs ?? [];

const relatedTitle = lsc?.relatedTitle || 'Related Regression Calculators';
const relatedItems: Array<{name: string; url: string; desc: string}> = lsc?.relatedItems ?? [];

const fmHeaders = formulaTable ? formulaTable.split('|').slice(0, 3) : [];
const fmRows: string[][] = [];
if (formulaTable) {
  const fmParts = formulaTable.split('|');
  for (let i = 3; i + 2 < fmParts.length; i += 3) {
    fmRows.push([fmParts[i], fmParts[i+1], fmParts[i+2]]);
  }
}

const wnHeaders = whenTable ? whenTable.split('|').slice(0, 3) : [];
const wnRows: string[][] = [];
if (whenTable) {
  const wnParts = whenTable.split('|');
  for (let i = 3; i + 2 < wnParts.length; i += 3) {
    wnRows.push([wnParts[i], wnParts[i+1], wnParts[i+2]]);
  }
}

const tdHeaders = tableDataTable ? tableDataTable.split('|').slice(0, 6) : [];
const tdRows: string[][] = [];
if (tableDataTable) {
  const tdParts = tableDataTable.split('|');
  for (let i = 6; i + 5 < tdParts.length; i += 6) {
    tdRows.push([tdParts[i], tdParts[i+1], tdParts[i+2], tdParts[i+3], tdParts[i+4], tdParts[i+5]]);
  }
}

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Least Squares Regression Line Calculator",
  "description": "Free online least squares regression line calculator. Compute the OLS best-fit line y = mx + b with step-by-step solutions, R², intermediate calculations, and predictions.",
  "url": "https://www.regressionequationcalculator.com/least-squares-regression-line-calculator/",
  "applicationCategory": "MathCalculator",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": ["Step-by-step solutions", "R² calculation", "Intermediate sums", "Prediction forecasting", "Residual analysis", "Export results"]
};

const faqSchema = faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: { '@type': 'Answer', text: faq.a },
      })),
    }
  : null;

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Calculate the Least Squares Regression Line",
  "description": "Step-by-step guide to calculating the least squares regression line from your data",
  "totalTime": "PT5M",
  "step": [
    { "@type": "HowToStep", "name": "Enter Data", "text": "Input your X and Y data pairs into the calculator table." },
    { "@type": "HowToStep", "name": "Compute Means", "text": "Calculate x̄ = Σx/n and ȳ = Σy/n." },
    { "@type": "HowToStep", "name": "Calculate Sums", "text": "Compute SSxx = Σ(xi − x̄)² and SSxy = Σ(xi − x̄)(yi − ȳ)." },
    { "@type": "HowToStep", "name": "Find Slope", "text": "Calculate slope m = SSxy / SSxx." },
    { "@type": "HowToStep", "name": "Find Intercept", "text": "Calculate intercept b = ȳ − m·x̄." },
    { "@type": "HowToStep", "name": "Evaluate Fit", "text": "Compute R² = 1 − SSres/SStot to assess goodness of fit." },
    { "@type": "HowToStep", "name": "Make Predictions", "text": "Use ŷ = mx + b to predict Y for new X values." }
  ]
};
---

<BaseLayout
  title={lsc?.title || "Least Squares Regression Line Calculator — OLS Best Fit Line"}
  description={lsc?.description || "Calculate the least squares regression line (y = mx + b) with detailed intermediate calculations, R², and predictions."}
  locale={locale}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-[450px] h-[450px] bg-primary-100/30 dark:bg-primary-900/10 blur-[110px] rounded-full animate-pulse"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[380px] h-[380px] bg-accent-100/30 dark:bg-accent-900/10 blur-[100px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 text-center lg:text-left reveal-on-scroll">
          <nav class="mb-6 text-sm font-medium flex items-center justify-center lg:justify-start gap-2">
            <a href="/" class="text-surface-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
          </nav>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 via-primary-600 to-accent-600 dark:from-primary-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight mb-6">
            Least Squares Regression Line Calculator
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-8">
            The gold standard for linear modeling. Minimize residuals and maximize predictive accuracy with our professional-grade OLS best-fit engine.
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="#calculator-tool" class="px-8 py-3 rounded-xl bg-primary-600 text-white font-semibold shadow-lg shadow-primary-600/20 hover:bg-primary-700 hover:shadow-xl hover:shadow-primary-600/30 transition-all duration-300 hover:-translate-y-1">
              Analyze Now
            </a>
            <a href="#how-to" class="px-8 py-3 rounded-xl bg-white dark:bg-surface-800 text-surface-700 dark:text-surface-200 font-semibold border border-surface-200 dark:border-surface-700 hover:border-primary-300 transition-all duration-300 hover:-translate-y-1">
              View Guide
            </a>
          </div>
        </div>
        <div class="flex-1 w-full max-w-lg lg:max-w-none reveal-on-scroll" style="transition-delay: 200ms">
          <div class="relative group" data-tilt>
            <div class="absolute -inset-4 bg-gradient-to-r from-primary-500/20 to-accent-500/20 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-500"></div>
            <div class="relative overflow-hidden rounded-3xl border border-white/20 shadow-2xl">
              <Image
                src={heroImage}
                alt="Linear Regression Visualization"
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                width={800}
                densities={[1, 2]}
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/20 via-transparent to-transparent opacity-40"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator Tool -->
  <section id="calculator-tool" class="py-12 md:py-16 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <LeastSquaresRegressionLineCalculator translations={translations} />
    </div>
  </section>

  <!-- Tool Info Box -->
  <ToolInfoBox
    toolName="Least Squares Regression Line Calculator"
    keyPoints={[
      {
        icon: "📏",
        title: "Best-Fit Line",
        description: "Computes the OLS regression line y = mx + b that minimizes squared residuals."
      },
      {
        icon: "📥",
        title: "Enter X & Y Data",
        description: "Input paired data points as comma-separated values or paste from a spreadsheet."
      },
      {
        icon: "📊",
        title: "Step-by-Step Output",
        description: "Get slope, intercept, R², intermediate sums, and residual diagnostics."
      },
      {
        icon: "🔬",
        title: "Best For",
        description: "Linear trend analysis, prediction, and introductory statistics coursework."
      }
    ]}
    highlightTip="Check the residual plot for patterns — a clear pattern suggests a linear model may not be the best fit."
  />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-12 py-16">
    <!-- What Is -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-primary-600 rounded-full"></span>
          {whatIsTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg" set:html={whatIsText} />
      </div>
    </section>

    <!-- Formula -->
    <section id="how-to" class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-accent-600 rounded-full"></span>
          {formulaTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={formulaText} />

        {fmRows.length > 0 && (
          <div class="overflow-hidden mb-8 rounded-2xl border border-surface-200 dark:border-surface-700/50 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gradient-to-r from-accent-600 to-accent-500 dark:from-accent-800 dark:to-accent-700">
                  {fmHeaders.map((h) => (
                    <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                {fmRows.map((row) => (
                  <tr class="hover:bg-accent-50/20 dark:hover:bg-accent-900/10 transition-colors">
                    {row.map((cell) => (
                      <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400 font-medium">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        <div class="grid sm:grid-cols-2 gap-4">
          {formulas.map((f, i) => (
            <div class="group flex items-start gap-4 p-4 rounded-xl bg-surface-50/50 dark:bg-surface-900/40 border border-surface-100 dark:border-surface-700/40 hover:border-accent-300 dark:hover:border-accent-700 transition-all duration-300">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center text-sm font-bold text-accent-700 dark:text-accent-400 group-hover:scale-110 transition-transform">{i + 1}</span>
              <span class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed pt-1" set:html={f} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Calculation Guide -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-primary-600 rounded-full"></span>
          {howCalcTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={howCalcManual} />
        <div class="space-y-6">
          {howCalcSteps.map((step, i) => (
            <div class="flex gap-5 group">
                <div class="flex-shrink-0 flex flex-col items-center">
                    <span class="w-10 h-10 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-primary-700 dark:text-primary-400 font-bold group-hover:scale-110 transition-transform">{i + 1}</span>
                    {i < howCalcSteps.length - 1 && <div class="w-0.5 h-full bg-surface-100 dark:bg-surface-700/50 mt-2"></div>}
                </div>
                <div class="pb-6">
                    <div class="text-base text-surface-600 dark:text-surface-400 leading-relaxed pt-1.5" set:html={step} />
                </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Residuals & Predictions -->
    <section class="reveal-on-scroll">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
            <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>
                {residualsTitle}
            </h2>
            <div class="prose prose-surface max-w-none text-sm text-surface-600 dark:text-surface-400 leading-relaxed" set:html={residualsText} />
        </div>

        <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
            <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                {predictionTitle}
            </h2>
            <div class="prose prose-surface max-w-none text-sm text-surface-600 dark:text-surface-400 mb-6" set:html={predictionText} />
            <ul class="space-y-3">
              {predictionPoints.map((point, i) => (
                <li class="flex items-start gap-3 p-3 rounded-xl bg-cyan-50/50 dark:bg-cyan-900/10 border border-cyan-100/50 dark:border-cyan-800/30">
                  <span class="flex-shrink-0 w-6 h-6 rounded-lg bg-cyan-100 dark:bg-cyan-900/30 flex items-center justify-center text-xs font-bold text-cyan-700 dark:text-cyan-400">{i + 1}</span>
                  <p class="text-sm text-surface-700 dark:text-surface-300" set:html={point} />
                </li>
              ))}
            </ul>
        </div>
      </div>
    </section>

    <!-- Graphing Calculator Guide -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
          <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-8 text-center">{howDoTitle}</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
              {[
                { title: howDoTi84, steps: howDoTi84Steps, color: 'rose' },
                { title: howDoTi83, steps: howDoTi83Steps, color: 'blue' },
                { title: howDoCasio, steps: howDoCasioSteps, color: 'indigo' },
                { title: howDoTiNspire, steps: howDoTiNspireSteps, color: 'violet' }
              ].map(calc => (
                <div class="space-y-4">
                    <h3 class={`text-base font-bold text-${calc.color}-600 dark:text-${calc.color}-400 mb-2`}>{calc.title}</h3>
                    <ul class="space-y-2">
                        {calc.steps.map(step => (
                            <li class="text-sm text-surface-600 dark:text-surface-400 flex items-start gap-2">
                                <span class={`text-${calc.color}-500 mt-1.5 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-current`}></span>
                                <span set:html={step} />
                            </li>
                        ))}
                    </ul>
                </div>
              ))}
          </div>
          <div class="mt-8 pt-6 border-t border-surface-100 dark:border-surface-700 text-center">
            <p class="text-xs text-surface-500 dark:text-surface-400 italic" set:html={howDoNote} />
          </div>
      </div>
    </section>

    <!-- When to Use Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg relative overflow-hidden group">
                <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-6">{whenTitle}</h2>
                <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 mb-8" set:html={whenText} />
                <div class="grid gap-4">
                  {whenPoints.map(point => (
                    <div class="flex items-start gap-4 p-4 rounded-2xl bg-emerald-50/50 dark:bg-emerald-900/10 border border-emerald-100/50 dark:border-emerald-800/30 hover:shadow-md transition-shadow">
                        <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-600 dark:text-emerald-400 flex-shrink-0">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <p class="text-sm text-surface-700 dark:text-surface-300" set:html={point} />
                    </div>
                  ))}
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50 text-center mb-10">{faqTitle}</h2>
            <div class="space-y-4">
                {faqs.map((faq, i) => (
                    <details class="group rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm overflow-hidden hover:shadow-lg transition-all duration-300">
                        <summary class="flex items-center justify-between px-6 py-5 cursor-pointer text-base font-bold text-surface-800 dark:text-surface-200 hover:text-primary-600 transition-colors list-none">
                            <span>{faq.q}</span>
                            <div class="w-8 h-8 rounded-full bg-surface-50 dark:bg-surface-900/50 flex items-center justify-center group-open:rotate-180 transition-transform">
                                <svg class="w-4 h-4 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </summary>
                        <div class="px-6 pb-6 text-base text-surface-600 dark:text-surface-400 leading-relaxed border-t border-surface-100 dark:border-surface-700/50 pt-4" set:html={faq.a} />
                    </details>
                ))}
            </div>
        </div>
    </section>

    <!-- Related Calculators -->
    <section class="reveal-on-scroll">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50">{relatedTitle}</h2>
        <p class="text-surface-500 mt-2">Discover more specialized regression modeling tools.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {relatedItems.map((item, i) => {
          const themes = [
            { accent: 'accent', icon: '📈' },
            { accent: 'primary', icon: '📐' },
            { accent: 'emerald', icon: '🧬' },
            { accent: 'violet', icon: '🔮' },
            { accent: 'cyan', icon: '🔬' },
            { accent: 'rose', icon: '📍' },
          ];
          const t = themes[i % themes.length];
          return (
            <a href={item.url} class="group/card relative p-6 rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 overflow-hidden">
              <div class={`absolute inset-0 bg-gradient-to-br from-${t.accent}-500/0 to-${t.accent}-500/0 group-hover/card:from-${t.accent}-500/5 group-hover/card:to-${t.accent}-500/10 transition-all duration-500`}></div>
              <div class="relative z-10">
                <div class={`w-12 h-12 rounded-xl bg-${t.accent}-100 dark:bg-${t.accent}-900/30 flex items-center justify-center mb-4 group-hover/card:scale-110 transition-transform duration-300 text-xl`}>
                  {t.icon}
                </div>
                <h3 class={`text-lg font-bold text-${t.accent}-700 dark:text-${t.accent}-400 mb-2`}>{item.name}</h3>
                <p class="text-sm text-surface-500 dark:text-surface-400">{item.desc}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // ── Reveal on Scroll (IntersectionObserver) ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── Interactive 3D Tilt Effect (Optimized) ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    let rect: DOMRect | null = null;
    el.addEventListener('mouseenter', () => { rect = el.getBoundingClientRect(); });
    el.addEventListener('mousemove', (e: MouseEvent) => {
      if (!rect) rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -10;
      const rotateY = ((x - centerX) / centerX) * 10;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave', () => {
      rect = null;
      el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
