---
import { getCollection, render } from 'astro:content';
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import BlogCard from 'theme/components/BlogCard.astro';
import Pagination from 'theme/components/Pagination.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

export async function getStaticPaths({ paginate }) {
  const blogEntries = await getCollection('blog');
  const sortedPosts = blogEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(sortedPosts, { pageSize: 12 });
}

const { page } = Astro.props;
const locale = 'en';
const translations = await mergeTranslations(locale);

const totalItems = page.total;
const startIndex = (page.currentPage - 1) * page.size + 1;
const endIndex = Math.min(page.currentPage * page.size, totalItems);
const resultsMeta = translations.blog.resultsMeta
  ?.replace('{start}', String(startIndex))
  .replace('{end}', String(endIndex))
  .replace('{total}', String(totalItems))
  ?? `Showing ${startIndex}-${endIndex} of ${totalItems} articles`;

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: translations.blog.title,
  description: translations.blog.description,
  url: new URL('/blog/', siteConfig.siteUrl).href,
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: page.data.map((post, index) => {
    const slug = post.id.replace(/\.(md|mdx)$/, '');
    return {
      '@type': 'ListItem',
      position: index + 1 + (page.currentPage - 1) * 12,
      url: new URL(`/blog/${slug}/`, siteConfig.siteUrl).href,
      name: post.data.title,
    };
  }),
};
---

<BaseLayout
  title={page.currentPage > 1 ? `${translations.blog.title} — Page ${page.currentPage}` : translations.blog.title}
  description={translations.blog.description}
  locale={locale}
  canonicalUrl={new URL(page.url.pathname ?? '/blog/', siteConfig.siteUrl).href}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <!-- Hero Section -->
  <section class="relative pt-16 pb-12 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary-100/30 dark:bg-primary-900/10 blur-[120px] rounded-full animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-accent-100/30 dark:bg-accent-900/10 blur-[100px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center reveal-on-scroll">
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 via-primary-600 to-accent-600 dark:from-primary-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight mb-6">
          {translations.blog.title}
        </h1>
        <p class="text-xl text-surface-600 dark:text-surface-400 max-w-2xl mx-auto leading-relaxed">
          {resultsMeta}
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6 border-t border-surface-200/50 dark:border-surface-700/50 shadow-2xl">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {page.data.map((post, i) => {
          const slug = post.id.replace(/\.(md|mdx)$/, '');
          return (
            <div class="reveal-on-scroll" style={`transition-delay: ${i % 3 * 100}ms`}>
                <BlogCard
                  title={post.data.title}
                  description={post.data.description}
                  image={post.data.image}
                  href={`/blog/${slug}/`}
                  readMoreLabel={translations.blog.readMore}
                />
            </div>
          );
        })}
      </div>

      {page.lastPage > 1 && (
        <div class="mt-20 flex justify-center reveal-on-scroll">
          <Pagination
            currentPage={page.currentPage}
            totalPages={page.lastPage}
            basePath="/blog/"
            prevLabel={translations.common?.previous ?? 'Previous'}
            nextLabel={translations.common?.next ?? 'Next'}
          />
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  revealElements.forEach((el) => revealObserver.observe(el));
</script>

<style>
  .reveal-on-scroll { opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1); }
  .reveal-on-scroll.revealed { opacity: 1; transform: translateY(0); }
</style>
