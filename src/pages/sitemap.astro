---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import { mergeTranslations, getLocalizedUrl } from 'theme/i18n/utils';
import { LOCALES } from 'theme/i18n/types';
import { getCollection } from 'astro:content';
import siteConfig from 'src/data/site-config.json';

const locale = 'en';
const translations = await mergeTranslations(locale);

const staticPages = [
  { href: '/', label: translations.nav?.home ?? 'Home' },
  { href: '/linear-regression-calculator/', label: (translations as any).nav?.linearCalc ?? 'Linear Regression Calculator' },
  { href: '/quadratic-regression-calculator/', label: (translations as any).nav?.quadCalc ?? 'Quadratic Regression Calculator' },
  { href: '/multiple-regression-calculator/', label: (translations as any).nav?.multiCalc ?? 'Multiple Regression Calculator' },
  { href: '/pearson-correlation-calculator/', label: (translations as any).nav?.pearsonCorrelation ?? 'Pearson r Calculator' },
  { href: '/grubbs-test-calculator/', label: (translations as any).nav?.grubbsTest ?? "Grubbs' Test" },
  { href: '/regression-assumptions-checker/', label: (translations as any).nav?.assumptionsChecker ?? 'Assumptions Checker' },
  { href: '/about-us/', label: translations.nav?.aboutUs ?? 'About Us' },
  { href: '/contact-us/', label: translations.nav?.contactUs ?? 'Contact Us' },
  { href: '/terms/', label: translations.nav?.terms ?? 'Terms' },
  { href: '/privacy/', label: translations.nav?.privacy ?? 'Privacy' },
  { href: '/sitemap/', label: translations.nav?.sitemap ?? 'Sitemap' },
];

const blogPosts = await getCollection('blog');
const sortedPosts = blogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const PAGE_SIZE = 12;
const totalPages = Math.ceil(sortedPosts.length / PAGE_SIZE);

function fullUrl(path: string): string {
  return new URL(path, siteConfig.siteUrl).href;
}
---

<BaseLayout
  title={translations.sitemap.title}
  description={translations.sitemap.description}
  locale={locale}
>
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 to-accent-600 bg-clip-text text-transparent">
        {translations.sitemap.title}
      </h1>
      <p class="mt-4 text-lg text-surface-600">{translations.sitemap.description}</p>

      <div class="mt-12 space-y-12">
        <div>
          <h2 class="text-2xl font-bold text-surface-900 mb-4 pb-2 border-b border-surface-200">
            Pages
          </h2>
          <ul class="grid gap-3 sm:grid-cols-2">
            {staticPages.map((page) => (
              <li>
                <a
                  href={page.href}
                  class="flex items-center gap-2 rounded-xl border border-surface-200/60 bg-white px-5 py-3 text-surface-700 font-medium shadow-sm hover:shadow-md hover:border-primary-200 hover:text-primary-700 transition-all duration-200"
                >
                  <svg class="w-4 h-4 text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                  {page.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-surface-900 mb-4 pb-2 border-b border-surface-200">
            Languages
          </h2>
          <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {LOCALES.map((loc) => (
              <li>
                <a
                  href={getLocalizedUrl('/', loc)}
                  class="flex items-center gap-2 rounded-xl border border-surface-200/60 bg-white px-5 py-3 text-surface-700 font-medium shadow-sm hover:shadow-md hover:border-primary-200 hover:text-primary-700 transition-all duration-200"
                >
                  <svg class="w-4 h-4 text-accent-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
                  </svg>
                  {loc.toUpperCase()}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-surface-900 mb-4 pb-2 border-b border-surface-200">
            {translations.blog.title}
          </h2>
          <ul class="grid gap-3">
            {sortedPosts.map((post) => {
              const slug = post.id.replace(/\.(md|mdx)$/, '');
              return (
                <li>
                  <a
                    href={`/blog/${slug}/`}
                    class="flex items-center gap-2 rounded-xl border border-surface-200/60 bg-white px-5 py-3 text-surface-700 font-medium shadow-sm hover:shadow-md hover:border-primary-200 hover:text-primary-700 transition-all duration-200"
                  >
                    <svg class="w-4 h-4 text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                    {post.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>

        {totalPages > 1 && (
          <div>
            <h2 class="text-2xl font-bold text-surface-900 mb-4 pb-2 border-b border-surface-200">
              Blog Pages
            </h2>
            <ul class="grid gap-3 sm:grid-cols-3">
              {Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNum) => (
                <li>
                  <a
                    href={pageNum === 1 ? '/blog/' : `/blog/${pageNum}/`}
                    class="flex items-center justify-center gap-2 rounded-xl border border-surface-200/60 bg-white px-5 py-3 text-surface-700 font-medium shadow-sm hover:shadow-md hover:border-primary-200 hover:text-primary-700 transition-all duration-200"
                  >
                    Page {pageNum}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
