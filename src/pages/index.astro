---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import Calculator from 'theme/components/Calculator.astro';
import HowItWorks from 'theme/components/HowItWorks.astro';
import ChartTable from 'theme/components/ChartTable.astro';
import FAQ from 'theme/components/FAQ.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

const locale = 'en';
const translations = await mergeTranslations(locale);
const home = translations.home;

const displayFaqs = translations.faqs?.filter((faq) => faq.display) ?? [];

const faqSchema = displayFaqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: displayFaqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }
  : null;

const whyUsePoints: string[] = (home as any).whyUsePoints ?? [];
const useCasesPoints: string[] = (home as any).useCasesPoints ?? [];
const whatIsTitle: string = (home as any).whatIsTitle ?? 'What Is a Regression Equation?';
const whatIsText: string = (home as any).whatIsText ?? '';
const whyUseTitle: string = (home as any).whyUseTitle ?? 'Why Use Our Calculator?';
const useCasesTitle: string = (home as any).useCasesTitle ?? 'Common Use Cases';
const faqTitle: string = (home as any).faqTitle ?? 'Frequently Asked Questions';
---

<BaseLayout
  title={translations.home.title}
  description={translations.home.description}
  locale={locale}
  isHomePage={true}
>
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <!-- Hero Section -->
  <section class="pt-8 pb-4 md:pt-12 md:pb-6">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 via-primary-600 to-accent-600 dark:from-primary-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight">
        {translations.home.title}
      </h1>
      <p class="mt-5 text-lg md:text-xl text-surface-600 dark:text-surface-400 max-w-2xl mx-auto leading-relaxed">
        {translations.home.intro}
      </p>
    </div>
  </section>

  <!-- Calculator Section -->
  <section class="pt-2 pb-8 md:pt-4 md:pb-12 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-3xl border-t border-surface-200/50 dark:border-surface-700/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <Calculator locale={locale} translations={translations} />
    </div>
  </section>

  <!-- What Is a Regression Equation? -->
  <section class="py-8 md:py-12">
    <div class="content-box max-w-4xl mx-auto rounded-2xl border border-surface-200/60 dark:border-surface-700/40 bg-white/60 dark:bg-surface-800/40 backdrop-blur-sm p-6 relative overflow-hidden before:absolute before:inset-0 before:bg-gradient-to-r before:from-primary-500/0 before:to-accent-500/0 hover:before:from-primary-500/5 hover:before:to-accent-500/5 dark:hover:before:from-primary-400/8 dark:hover:before:to-accent-400/8 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-surface-950/40 hover:-translate-y-1 hover:border-primary-200 dark:hover:border-primary-700/50 transition-all duration-300">
      <div class="flex flex-col md:flex-row gap-6 items-center">
        <div class="flex-1">
          <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-4">{whatIsTitle}</h2>
          <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed" set:html={whatIsText} />
        </div>
        <div class="w-full md:w-2/5 flex-shrink-0">
          <div class="interactive-img-wrapper reveal-on-scroll" data-tilt>
            <div class="interactive-img-glow"></div>
            <img
              src="/images/what-is-regression.png"
              alt="Visual explanation of y = mx + b showing slope and intercept on a coordinate plane"
              class="interactive-img rounded-xl"
              loading="lazy"
              width="400"
              height="225"
            />
            <div class="interactive-img-shine"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Use / Use Cases -->
  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">

    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-6">
      <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:absolute before:inset-0 before:bg-gradient-to-br before:from-primary-500/0 before:to-primary-500/0 hover:before:from-primary-500/5 hover:before:to-primary-500/8 dark:hover:before:from-primary-400/8 dark:hover:before:to-primary-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-primary-900/10 hover:-translate-y-1 hover:border-primary-300 dark:hover:border-primary-700/50 transition-all duration-300">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{whyUseTitle}</h2>
        <ul class="space-y-3">
          {whyUsePoints.map((point, i) => (
            <li class="flex items-start gap-3 group/item translate-x-0 hover:translate-x-1 transition-transform duration-200" style={`transition-delay: ${i * 40}ms`}>
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center group-hover/item:bg-primary-200 dark:group-hover/item:bg-primary-800/40 group-hover/item:scale-110 transition-all duration-200">
                <svg class="w-3 h-3 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">{point}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:absolute before:inset-0 before:bg-gradient-to-br before:from-accent-500/0 before:to-accent-500/0 hover:before:from-accent-500/5 hover:before:to-accent-500/8 dark:hover:before:from-accent-400/8 dark:hover:before:to-accent-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-accent-900/10 hover:-translate-y-1 hover:border-accent-300 dark:hover:border-accent-700/50 transition-all duration-300">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-4">{useCasesTitle}</h2>
        <ul class="space-y-3">
          {useCasesPoints.map((point, i) => (
            <li class="flex items-start gap-3 group/item translate-x-0 hover:translate-x-1 transition-transform duration-200" style={`transition-delay: ${i * 40}ms`}>
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center group-hover/item:bg-accent-200 dark:group-hover/item:bg-accent-800/40 group-hover/item:scale-110 transition-all duration-200">
                <svg class="w-3 h-3 text-accent-600 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
              </span>
              <span class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">{point}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-8 md:py-10">

    <HowItWorks translations={translations} />
  </section>

  <!-- Statistics Reference Table -->
  <section class="py-8 md:py-10 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">

    <ChartTable translations={translations} />
  </section>

  <!-- FAQ -->
  <section class="py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 text-center mb-6">{faqTitle}</h2>
    </div>
    {displayFaqs.length > 0 && <FAQ translations={translations} />}
  </section>

  <!-- All Calculator Tools -->
  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 text-center mb-8">Our Regression &amp; Statistics Tools</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/linear-regression-calculator/" class="group/card rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-primary-500/0 before:to-primary-500/0 hover:before:from-primary-500/5 hover:before:to-primary-500/8 dark:hover:before:from-primary-400/8 dark:hover:before:to-primary-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-primary-900/10 hover:-translate-y-1 hover:border-primary-300 dark:hover:border-primary-700/50 transition-all duration-300">
          <div class="flex items-center gap-3 mb-2">
            <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center group-hover/card:scale-110 transition-transform duration-200">
              <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            </span>
            <h3 class="text-base font-bold text-primary-700 dark:text-primary-400">Linear Regression</h3>
          </div>
          <p class="text-sm text-surface-500 dark:text-surface-400">Calculate y = mx + b with slope, intercept, R²</p>
        </a>
        <a href="/quadratic-regression-calculator/" class="group/card rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-accent-500/0 before:to-accent-500/0 hover:before:from-accent-500/5 hover:before:to-accent-500/8 dark:hover:before:from-accent-400/8 dark:hover:before:to-accent-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-accent-900/10 hover:-translate-y-1 hover:border-accent-300 dark:hover:border-accent-700/50 transition-all duration-300">
          <div class="flex items-center gap-3 mb-2">
            <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center group-hover/card:scale-110 transition-transform duration-200">
              <svg class="w-5 h-5 text-accent-600 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg>
            </span>
            <h3 class="text-base font-bold text-accent-700 dark:text-accent-400">Quadratic Regression</h3>
          </div>
          <p class="text-sm text-surface-500 dark:text-surface-400">Model curves with y = ax² + bx + c</p>
        </a>
        <a href="/multiple-regression-calculator/" class="group/card rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-purple-500/0 before:to-purple-500/0 hover:before:from-purple-500/5 hover:before:to-purple-500/8 dark:hover:before:from-purple-400/8 dark:hover:before:to-purple-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-purple-900/10 hover:-translate-y-1 hover:border-purple-300 dark:hover:border-purple-700/50 transition-all duration-300">
          <div class="flex items-center gap-3 mb-2">
            <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center group-hover/card:scale-110 transition-transform duration-200">
              <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" /></svg>
            </span>
            <h3 class="text-base font-bold text-purple-700 dark:text-purple-400">Multiple Regression</h3>
          </div>
          <p class="text-sm text-surface-500 dark:text-surface-400">Use 2+ predictors with y = b₀ + b₁x₁ + b₂x₂</p>
        </a>
        <a href="/pearson-correlation-calculator/" class="group/card rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-emerald-500/0 before:to-emerald-500/0 hover:before:from-emerald-500/5 hover:before:to-emerald-500/8 dark:hover:before:from-emerald-400/8 dark:hover:before:to-emerald-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-emerald-900/10 hover:-translate-y-1 hover:border-emerald-300 dark:hover:border-emerald-700/50 transition-all duration-300">
          <div class="flex items-center gap-3 mb-2">
            <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center group-hover/card:scale-110 transition-transform duration-200">
              <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
            </span>
            <h3 class="text-base font-bold text-emerald-700 dark:text-emerald-400">Pearson Correlation</h3>
          </div>
          <p class="text-sm text-surface-500 dark:text-surface-400">Measure linear relationship strength with r and p-value</p>
        </a>
        <a href="/grubbs-test-calculator/" class="group/card rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-amber-500/0 before:to-amber-500/0 hover:before:from-amber-500/5 hover:before:to-amber-500/8 dark:hover:before:from-amber-400/8 dark:hover:before:to-amber-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-amber-900/10 hover:-translate-y-1 hover:border-amber-300 dark:hover:border-amber-700/50 transition-all duration-300">
          <div class="flex items-center gap-3 mb-2">
            <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center group-hover/card:scale-110 transition-transform duration-200">
              <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
            </span>
            <h3 class="text-base font-bold text-amber-700 dark:text-amber-400">Grubbs' Test</h3>
          </div>
          <p class="text-sm text-surface-500 dark:text-surface-400">Detect outliers with G statistic and critical value</p>
        </a>
        <a href="/regression-assumptions-checker/" class="group/card rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-5 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-rose-500/0 before:to-rose-500/0 hover:before:from-rose-500/5 hover:before:to-rose-500/8 dark:hover:before:from-rose-400/8 dark:hover:before:to-rose-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-rose-900/10 hover:-translate-y-1 hover:border-rose-300 dark:hover:border-rose-700/50 transition-all duration-300">
          <div class="flex items-center gap-3 mb-2">
            <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-rose-100 dark:bg-rose-900/30 flex items-center justify-center group-hover/card:scale-110 transition-transform duration-200">
              <svg class="w-5 h-5 text-rose-600 dark:text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </span>
            <h3 class="text-base font-bold text-rose-700 dark:text-rose-400">Assumptions Checker</h3>
          </div>
          <p class="text-sm text-surface-500 dark:text-surface-400">Verify linearity, independence, homoscedasticity, normality</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // ── Reveal on Scroll (IntersectionObserver) ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── Interactive 3D Tilt Effect ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    const img = el.querySelector<HTMLElement>('.interactive-img');
    const glow = el.querySelector<HTMLElement>('.interactive-img-glow');
    const shine = el.querySelector<HTMLElement>('.interactive-img-shine');

    el.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -8;
      const rotateY = ((x - centerX) / centerX) * 8;
      const percentX = (x / rect.width) * 100;
      const percentY = (y / rect.height) * 100;

      if (img) {
        img.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.03)`;
      }
      if (glow) {
        glow.style.opacity = '1';
        glow.style.background = `radial-gradient(circle at ${percentX}% ${percentY}%, rgba(99, 102, 241, 0.25), transparent 60%)`;
      }
      if (shine) {
        shine.style.opacity = '1';
        shine.style.background = `linear-gradient(${105 + rotateY * 3}deg, transparent 30%, rgba(255,255,255,0.12) 50%, transparent 70%)`;
      }
    });

    el.addEventListener('mouseleave', () => {
      if (img) {
        img.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
      }
      if (glow) {
        glow.style.opacity = '0';
      }
      if (shine) {
        shine.style.opacity = '0';
      }
    });
  });

  // ── Parallax on Scroll ──
  const parallaxImages = document.querySelectorAll<HTMLElement>('.interactive-img');
  let ticking = false;
  const onScroll = () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        parallaxImages.forEach((img) => {
          const rect = img.getBoundingClientRect();
          const viewH = window.innerHeight;
          if (rect.top < viewH && rect.bottom > 0) {
            const progress = (viewH - rect.top) / (viewH + rect.height);
            const offset = (progress - 0.5) * 20;
            // Only apply parallax if not being tilt-hovered
            if (!img.style.transform.includes('rotateX')) {
              img.style.transform = `translateY(${offset}px)`;
            }
          }
        });
        ticking = false;
      });
      ticking = true;
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
