---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import Calculator from 'theme/components/Calculator.astro';
import HowItWorks from 'theme/components/HowItWorks.astro';
import ChartTable from 'theme/components/ChartTable.astro';
import FAQ from 'theme/components/FAQ.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

const locale = 'en';
const translations = await mergeTranslations(locale);
const home = translations.home;

const displayFaqs = translations.faqs?.filter((faq) => faq.display) ?? [];

const faqSchema = displayFaqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: displayFaqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }
  : null;

const whyUsePoints: string[] = (home as any).whyUsePoints ?? [];
const useCasesPoints: string[] = (home as any).useCasesPoints ?? [];
const whatIsTitle: string = (home as any).whatIsTitle ?? 'What Is a Regression Equation?';
const whatIsText: string = (home as any).whatIsText ?? '';
const whyUseTitle: string = (home as any).whyUseTitle ?? 'Why Use Our Calculator?';
const useCasesTitle: string = (home as any).useCasesTitle ?? 'Common Use Cases';
const faqTitle: string = (home as any).faqTitle ?? 'Frequently Asked Questions';
---

<BaseLayout
  title={translations.home.title}
  description={translations.home.description}
  locale={locale}
  isHomePage={true}
>
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Regression Equation Calculator",
    "applicationCategory": "MathApplication",
    "operatingSystem": "Web Browser",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  })} />

  <!-- Hero Section -->
  <section class="pt-8 pb-4 md:pt-12 md:pb-6">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 via-primary-600 to-accent-600 dark:from-primary-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight">
        Regression Equation Calculator
      </h1>
      <p class="mt-3 text-lg md:text-xl text-surface-600 dark:text-surface-400 max-w-2xl mx-auto leading-relaxed">
        Find Linear, Exponential &amp; Polynomial Equations.
      </p>
    </div>
  </section>

  <!-- Calculator Section -->
  <section class="pt-2 pb-8 md:pt-4 md:pb-12 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-3xl border-t border-surface-200/50 dark:border-surface-700/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <Calculator locale={locale} translations={translations} />
    </div>
  </section>

  <!-- Understanding Regression Analysis -->
  <section class="py-8 md:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 text-center mb-8">Understanding Regression Analysis</h2>
      <div class="grid sm:grid-cols-2 gap-5">
        <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-primary-500/0 before:to-primary-500/0 hover:before:from-primary-500/5 hover:before:to-primary-500/8 dark:hover:before:from-primary-400/8 dark:hover:before:to-primary-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-primary-900/10 hover:-translate-y-1 hover:border-primary-300 dark:hover:border-primary-700/50 transition-all duration-300">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex-shrink-0 w-9 h-9 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center">
              <svg class="w-4 h-4 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            </span>
            <h3 class="text-lg font-bold text-primary-700 dark:text-primary-400">Linear Regression</h3>
          </div>
          <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">Models a straight-line relationship between variables using the equation <strong>y = a + bx</strong>. Best when data follows a constant rate of change — ideal for forecasting trends, analyzing sales growth, or estimating cost over time.</p>
        </div>
        <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-accent-500/0 before:to-accent-500/0 hover:before:from-accent-500/5 hover:before:to-accent-500/8 dark:hover:before:from-accent-400/8 dark:hover:before:to-accent-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-accent-900/10 hover:-translate-y-1 hover:border-accent-300 dark:hover:border-accent-700/50 transition-all duration-300">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex-shrink-0 w-9 h-9 rounded-lg bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center">
              <svg class="w-4 h-4 text-accent-600 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg>
            </span>
            <h3 class="text-lg font-bold text-accent-700 dark:text-accent-400">Polynomial Regression</h3>
          </div>
          <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">Fits a curved relationship using <strong>y = a + bx + cx²</strong> (or higher degrees). Perfect when data shows acceleration or deceleration — useful for projectile motion, population modeling, or price-demand curves.</p>
        </div>
        <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-emerald-500/0 before:to-emerald-500/0 hover:before:from-emerald-500/5 hover:before:to-emerald-500/8 dark:hover:before:from-emerald-400/8 dark:hover:before:to-emerald-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-emerald-900/10 hover:-translate-y-1 hover:border-emerald-300 dark:hover:border-emerald-700/50 transition-all duration-300">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex-shrink-0 w-9 h-9 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center">
              <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
            </span>
            <h3 class="text-lg font-bold text-emerald-700 dark:text-emerald-400">Exponential Regression</h3>
          </div>
          <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">Models rapid growth or decay with <strong>y = ae<sup>bx</sup></strong>. Ideal when values multiply at a constant rate — commonly used for compound interest, bacterial growth, radioactive decay, and viral spread analysis.</p>
        </div>
        <div class="content-box rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm p-6 shadow-sm dark:shadow-surface-950/20 relative overflow-hidden before:pointer-events-none before:absolute before:inset-0 before:bg-gradient-to-br before:from-amber-500/0 before:to-amber-500/0 hover:before:from-amber-500/5 hover:before:to-amber-500/8 dark:hover:before:from-amber-400/8 dark:hover:before:to-amber-400/12 before:transition-all before:duration-500 hover:shadow-lg dark:hover:shadow-amber-900/10 hover:-translate-y-1 hover:border-amber-300 dark:hover:border-amber-700/50 transition-all duration-300">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex-shrink-0 w-9 h-9 rounded-lg bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
              <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4" /></svg>
            </span>
            <h3 class="text-lg font-bold text-amber-700 dark:text-amber-400">Logarithmic Regression</h3>
          </div>
          <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">Fits diminishing-returns patterns with <strong>y = a + b·ln(x)</strong>. Great when growth starts fast then plateaus — fits learning curves, sensory perception, economic saturation, and diminishing marginal returns.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Advanced Features -->
  <section class="py-8 md:py-12 bg-surface-50/40 dark:bg-surface-900/40 rounded-t-3xl -mt-2">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 text-center mb-2">Advanced Features of Regression Equation Calculator</h2>
      <p class="text-center text-sm text-surface-500 dark:text-surface-400 mb-8">Built for accuracy, usability, and compliance</p>
      <div class="rounded-2xl border border-surface-200/60 dark:border-surface-700/40 bg-white/60 dark:bg-surface-800/40 backdrop-blur-sm overflow-hidden">
        <div class="divide-y divide-surface-100 dark:divide-surface-700/50">
          <div class="flex items-start gap-4 px-6 py-5 hover:bg-primary-50/40 dark:hover:bg-primary-900/10 transition-colors duration-200">
            <span class="flex-shrink-0 mt-0.5 w-8 h-8 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center">
              <svg class="w-4 h-4 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
            </span>
            <div>
              <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-50">Multiple Regression Models</h3>
              <p class="mt-1 text-sm text-surface-500 dark:text-surface-400 leading-relaxed">Support for linear, polynomial, exponential, and logarithmic relationship patterns — choose the model that best fits your data structure.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-6 py-5 hover:bg-accent-50/40 dark:hover:bg-accent-900/10 transition-colors duration-200">
            <span class="flex-shrink-0 mt-0.5 w-8 h-8 rounded-lg bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center">
              <svg class="w-4 h-4 text-accent-600 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg>
            </span>
            <div>
              <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-50">Graphical Visualization</h3>
              <p class="mt-1 text-sm text-surface-500 dark:text-surface-400 leading-relaxed">Interactive scatter plot with regression line overlay — instantly see how well your model fits the observed data points.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-6 py-5 hover:bg-emerald-50/40 dark:hover:bg-emerald-900/10 transition-colors duration-200">
            <span class="flex-shrink-0 mt-0.5 w-8 h-8 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center">
              <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
            </span>
            <div>
              <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-50">Prediction Capability</h3>
              <p class="mt-1 text-sm text-surface-500 dark:text-surface-400 leading-relaxed">Enter any X value to estimate Y with confidence intervals — make reliable forecasts from your regression model.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-6 py-5 hover:bg-purple-50/40 dark:hover:bg-purple-900/10 transition-colors duration-200">
            <span class="flex-shrink-0 mt-0.5 w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center">
              <svg class="w-4 h-4 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            </span>
            <div>
              <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-50">Statistical Diagnostics</h3>
              <p class="mt-1 text-sm text-surface-500 dark:text-surface-400 leading-relaxed">Complete output including R-squared, standard error, degrees of freedom, and confidence levels — assess model quality at a glance.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-6 py-5 hover:bg-amber-50/40 dark:hover:bg-amber-900/10 transition-colors duration-200">
            <span class="flex-shrink-0 mt-0.5 w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
              <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
            </span>
            <div>
              <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-50">Mobile-Responsive Design</h3>
              <p class="mt-1 text-sm text-surface-500 dark:text-surface-400 leading-relaxed">Fully adaptive layout for phones, tablets, and desktops — perform regression analysis anywhere without compromise.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-6 py-5 hover:bg-rose-50/40 dark:hover:bg-rose-900/10 transition-colors duration-200">
            <span class="flex-shrink-0 mt-0.5 w-8 h-8 rounded-lg bg-rose-100 dark:bg-rose-900/30 flex items-center justify-center">
              <svg class="w-4 h-4 text-rose-600 dark:text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </span>
            <div>
              <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-50">International Standards Compliance</h3>
              <p class="mt-1 text-sm text-surface-500 dark:text-surface-400 leading-relaxed">Calculations follow ISO 3534 and ASTM E2586 standards — trusted results valid for academic, professional, and regulatory use worldwide.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Data Requirements Table -->
  <section class="py-8 md:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 text-center mb-2">Data Requirements for Regression Equation Calculator</h2>
      <p class="text-center text-sm text-surface-500 dark:text-surface-400 mb-8">Ensure your dataset meets these standards for reliable results</p>
      <div class="overflow-hidden rounded-2xl border border-surface-200/60 dark:border-surface-700/40 bg-white/60 dark:bg-surface-800/40 backdrop-blur-sm shadow-sm dark:shadow-surface-950/20">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gradient-to-r from-primary-600 via-primary-500 to-accent-500 dark:from-primary-800 dark:via-primary-700 dark:to-accent-700">
              <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">Requirement</th>
              <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">Minimum Standard</th>
              <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">Recommended Standard</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Sample Size</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">3 data points</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">30+ data points</td>
            </tr>
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Observations per Parameter</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">2 per coefficient</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">10+ per coefficient</td>
            </tr>
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Independent Variable Range</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">2 distinct values</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Wide, evenly spaced coverage</td>
            </tr>
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Dependent Variable Type</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Continuous (interval/ratio)</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Continuous, no ceiling/floor effects</td>
            </tr>
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Data Distribution</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Approximately normal residuals</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Normal residuals, outliers removed</td>
            </tr>
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Linearity</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Scatter plot visual check</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Residual plot analysis + Lack-of-Fit test</td>
            </tr>
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Homoscedasticity</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Visual spread check</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Breusch-Pagan test p &gt; 0.05</td>
            </tr>
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Independence of Errors</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Random sampling</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Durbin-Watson statistic ≈ 2</td>
            </tr>
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Multicollinearity (Multiple Reg.)</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">VIF &lt; 10</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">VIF &lt; 5, condition index &lt; 30</td>
            </tr>
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Outlier Treatment</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">None required</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Grubbs' or Cook's distance applied</td>
            </tr>
            <tr class="hover:bg-primary-50/30 dark:hover:bg-primary-900/10 transition-colors duration-150">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-100">Missing Data</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Complete cases only</td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400">Listwise deletion or multiple imputation</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- What Is a Regression Equation? -->
  <section class="py-8 md:py-12">
