---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import RegressionAssumptionsChecker from 'theme/components/RegressionAssumptionsChecker.astro';
import ToolInfoBox from 'theme/components/ToolInfoBox.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

const locale = 'en';
const translations = await mergeTranslations(locale);
const ac = (translations as any).assumptionsChecker;

const canonicalUrl = new URL('/regression-assumptions-checker/', siteConfig.siteUrl).href;

const breadcrumb = ac?.breadcrumb || 'Back to Main Regression Calculator';

const whatIsTitle = ac?.whatIsTitle || 'Why Check Regression Assumptions?';
const whatIsText = ac?.whatIsText || '';

const formulaTitle = ac?.formulaTitle || 'Regression Assumptions Tests Explained';
const formulaText = ac?.formulaText || '';
const formulaTable = ac?.formulaTable || '';
const formulas: string[] = ac?.formulas ?? [];

const howCalcTitle = ac?.howCalcTitle || 'How to Check Regression Assumptions';
const howCalcManual = ac?.howCalcManual || '';
const howCalcSteps: string[] = ac?.howCalcSteps ?? [];

const calcStepsTitle = ac?.calcStepsTitle || 'Regression Assumptions Checker Steps';
const calcStepsIntro = ac?.calcStepsIntro || '';
const calcStepsPoints: string[] = ac?.calcStepsPoints ?? [];

const testsTitle = ac?.testsTitle || 'The Four Assumptions & How We Test Them';
const testsPoints: string[] = ac?.testsPoints ?? [];

const fixTitle = ac?.fixTitle || 'What to Do When Assumptions Fail';
const fixText = ac?.fixText || '';
const fixPoints: string[] = ac?.fixPoints ?? [];

const manualDemoTitle = ac?.manualDemoTitle || 'How to calculate Pearson correlation by hand (step‑by‑step)';
const manualDemoStep1 = ac?.manualDemoStep1 || '';
const manualDemoStep2 = ac?.manualDemoStep2 || '';
const manualDemoStep3 = ac?.manualDemoStep3 || '';
const manualDemoStep4 = ac?.manualDemoStep4 || '';
const manualDemoStep5 = ac?.manualDemoStep5 || '';
const manualDemoStep6 = ac?.manualDemoStep6 || '';
const manualDemoInterpretation = ac?.manualDemoInterpretation || '';
const manualDemoNote = ac?.manualDemoNote || '';

const whenTitle = ac?.whenTitle || 'When to Check Assumptions';
const whenText = ac?.whenText || '';
const whenTable = ac?.whenTable || '';
const whenPoints: string[] = ac?.whenPoints ?? [];

const faqTitle = ac?.faqTitle || 'Frequently Asked Questions';
const faqs: Array<{q: string; a: string}> = ac?.faqs ?? [];

const relatedTitle = ac?.relatedTitle || 'Related Regression Calculators';
const relatedItems: Array<{name: string; url: string; desc: string}> = ac?.relatedItems ?? [];

const fmHeaders = formulaTable ? formulaTable.split('|').slice(0, 3) : [];
const fmRows: string[][] = [];
if (formulaTable) {
  const fmParts = formulaTable.split('|');
  for (let i = 3; i + 2 < fmParts.length; i += 3) {
    fmRows.push([fmParts[i], fmParts[i+1], fmParts[i+2]]);
  }
}

const wnHeaders = whenTable ? whenTable.split('|').slice(0, 3) : [];
const wnRows: string[][] = [];
if (whenTable) {
  const wnParts = whenTable.split('|');
  for (let i = 3; i + 2 < wnParts.length; i += 3) {
    wnRows.push([wnParts[i], wnParts[i+1], wnParts[i+2]]);
  }
}

const manualDemoSteps = [manualDemoStep1, manualDemoStep2, manualDemoStep3, manualDemoStep4, manualDemoStep5, manualDemoStep6].filter(Boolean);

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Regression Assumptions Checker",
  "description": "Free online tool to check all four linear regression assumptions: linearity (RESET test), independence (Durbin-Watson), homoscedasticity (Breusch-Pagan), and normality (Jarque-Bera). With step-by-step details.",
  "url": "https://www.regressionequationcalculator.com/regression-assumptions-checker/",
  "applicationCategory": "MathCalculator",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": ["Linearity check (RESET test)", "Independence check (Durbin-Watson)", "Homoscedasticity check (Breusch-Pagan)", "Normality check (Jarque-Bera)", "Step-by-step details", "Remediation suggestions"]
};

const faqSchema = faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: { '@type': 'Answer', text: faq.a },
      })),
    }
  : null;

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Check Regression Assumptions",
  "description": "Step-by-step guide to checking all four OLS regression assumptions",
  "totalTime": "PT5M",
  "step": [
    { "@type": "HowToStep", "name": "Fit Regression Line", "text": "Compute the OLS regression equation ŷ = mx + b from your data." },
    { "@type": "HowToStep", "name": "Compute Residuals", "text": "Calculate residuals eᵢ = yᵢ − ŷᵢ for each data point." },
    { "@type": "HowToStep", "name": "Check Linearity", "text": "Examine residual-vs-fitted plot for patterns; run RESET test." },
    { "@type": "HowToStep", "name": "Check Independence", "text": "Compute Durbin-Watson statistic; values near 2 indicate no autocorrelation." },
    { "@type": "HowToStep", "name": "Check Homoscedasticity", "text": "Run Breusch-Pagan test for constant residual variance." },
    { "@type": "HowToStep", "name": "Check Normality", "text": "Run Shapiro-Wilk or Jarque-Bera test on residuals." }
  ]
};
---

<BaseLayout
  title={ac?.title || "Regression Assumptions Checker — Test Linearity, Normality & More"}
  description={ac?.description || "Check all four linear regression assumptions with formal statistical tests — free, instant, and private."}
  locale={locale}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] bg-emerald-100/30 dark:bg-emerald-900/10 blur-[100px] rounded-full animate-pulse"></div>
        <div class="absolute bottom-1/4 right-1/3 w-[350px] h-[350px] bg-primary-100/30 dark:bg-primary-900/10 blur-[90px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 text-center lg:text-left reveal-on-scroll">
          <nav class="mb-6 text-sm font-medium flex items-center justify-center lg:justify-start gap-2">
            <a href="/" class="text-surface-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
          </nav>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-emerald-700 via-primary-600 to-accent-600 dark:from-emerald-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight mb-6">
            Regression Assumptions Checker
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-8">
            Validate your model with mathematical rigor. Our diagnostic engine performs a comprehensive audit of all OLS assumptions, ensuring your insights are built on a solid statistical foundation.
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="#calculator-tool" class="px-8 py-3 rounded-xl bg-emerald-600 text-white font-semibold shadow-lg shadow-emerald-600/20 hover:bg-emerald-700 hover:shadow-xl hover:shadow-emerald-600/30 transition-all duration-300 hover:-translate-y-1">
              Check Now
            </a>
            <a href="#diagnostics" class="px-8 py-3 rounded-xl bg-white dark:bg-surface-800 text-surface-700 dark:text-surface-200 font-semibold border border-surface-200 dark:border-surface-700 hover:border-emerald-300 transition-all duration-300 hover:-translate-y-1">
              View Tests
            </a>
          </div>
        </div>
        <div class="flex-1 w-full max-w-lg lg:max-w-none reveal-on-scroll" style="transition-delay: 200ms">
          <div class="relative group" data-tilt>
            <div class="absolute -inset-4 bg-gradient-to-r from-emerald-500/20 to-primary-500/20 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-500"></div>
            <div class="relative overflow-hidden rounded-3xl border border-white/20 shadow-2xl">
              <img
                src="/images/multiple-hero.png"
                alt="Regression Diagnostics Visualization"
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                width="600"
                height="400"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/20 via-transparent to-transparent opacity-40"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator Tool -->
  <section id="calculator-tool" class="py-12 md:py-16 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <RegressionAssumptionsChecker translations={translations} />
    </div>
  </section>

  <!-- Tool Info Box -->
  <ToolInfoBox
    toolName="Regression Assumptions Checker"
    keyPoints={[
      {
        icon: "✅",
        title: "Assumption Validation",
        description: "Tests all four OLS assumptions: linearity, independence, homoscedasticity, normality."
      },
      {
        icon: "📥",
        title: "Enter X & Y Data",
        description: "Input paired data — the tool fits the regression and analyzes residuals automatically."
      },
      {
        icon: "📊",
        title: "Formal Test Results",
        description: "Get Durbin-Watson, Breusch-Pagan, RESET, and Jarque-Bera test statistics."
      },
      {
        icon: "🔬",
        title: "Best For",
        description: "Validating regression models before interpreting coefficients or making predictions."
      }
    ]}
    highlightTip="Always check assumptions before trusting regression results — violated assumptions can invalidate your conclusions."
  />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-12 py-16">
    <!-- What Is -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-emerald-600 rounded-full"></span>
          {whatIsTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg" set:html={whatIsText} />
      </div>
    </section>

    <!-- Formula / Tests -->
    <section id="diagnostics" class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-accent-600 rounded-full"></span>
          {formulaTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={formulaText} />

        {fmRows.length > 0 && (
          <div class="overflow-hidden mb-8 rounded-2xl border border-surface-200 dark:border-surface-700/50 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gradient-to-r from-accent-600 to-accent-500 dark:from-accent-800 dark:to-accent-700">
                  {fmHeaders.map((h) => (
                    <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                {fmRows.map((row) => (
                  <tr class="hover:bg-accent-50/20 dark:hover:bg-accent-900/10 transition-colors">
                    {row.map((cell) => (
                      <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400 font-medium">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        <div class="grid sm:grid-cols-2 gap-4">
          {formulas.map((f, i) => (
            <div class="group flex items-start gap-4 p-4 rounded-xl bg-surface-50/50 dark:bg-surface-900/40 border border-surface-100 dark:border-surface-700/40 hover:border-accent-300 dark:hover:border-accent-700 transition-all duration-300">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-accent-100 dark:bg-accent-900/30 flex items-center justify-center text-sm font-bold text-accent-700 dark:text-accent-400 group-hover:scale-110 transition-transform">{i + 1}</span>
              <span class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed pt-1" set:html={f} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Assumption Cards -->
    <section class="reveal-on-scroll">
      <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50 text-center mb-10">{testsTitle}</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {testsPoints.map((point, i) => {
          const colors = ['emerald', 'primary', 'violet', 'cyan'];
          const c = colors[i % colors.length];
          return (
            <div class={`content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg hover:-translate-y-1 transition-all duration-300`}>
              <div class="flex items-start gap-5">
                <div class={`w-12 h-12 rounded-2xl bg-${c}-100 dark:bg-${c}-900/30 flex items-center justify-center text-${c}-700 dark:text-${c}-400 font-bold text-xl flex-shrink-0`}>
                  {i + 1}
                </div>
                <div class="text-base text-surface-600 dark:text-surface-400 leading-relaxed pt-2" set:html={point} />
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Fix Guide -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-orange-600 rounded-full"></span>
          {fixTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg mb-8" set:html={fixText} />
        <div class="grid sm:grid-cols-2 gap-6">
          {fixPoints.map((point, i) => (
            <div class="flex items-start gap-4 p-5 rounded-2xl bg-orange-50/50 dark:bg-orange-900/10 border border-orange-100/50 dark:border-orange-800/30 hover:shadow-md transition-shadow">
                <div class="w-8 h-8 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-600 dark:text-orange-400 flex-shrink-0">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <p class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed" set:html={point} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- When to Check Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg relative overflow-hidden group">
                <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-6">{whenTitle}</h2>
                <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 mb-8" set:html={whenText} />
                <div class="grid gap-4">
                  {whenPoints.map(point => (
                    <div class="flex items-start gap-4 p-4 rounded-2xl bg-emerald-50/50 dark:bg-emerald-900/10 border border-emerald-100/50 dark:border-emerald-800/30 hover:shadow-md transition-shadow">
                        <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-600 dark:text-emerald-400 flex-shrink-0">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <p class="text-sm text-surface-700 dark:text-surface-300" set:html={point} />
                    </div>
                  ))}
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50 text-center mb-10">{faqTitle}</h2>
            <div class="space-y-4">
                {faqs.map((faq, i) => (
                    <details class="group rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm overflow-hidden hover:shadow-lg transition-all duration-300">
                        <summary class="flex items-center justify-between px-6 py-5 cursor-pointer text-base font-bold text-surface-800 dark:text-surface-200 hover:text-emerald-600 transition-colors list-none">
                            <span>{faq.q}</span>
                            <div class="w-8 h-8 rounded-full bg-surface-50 dark:bg-surface-900/50 flex items-center justify-center group-open:rotate-180 transition-transform">
                                <svg class="w-4 h-4 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </summary>
                        <div class="px-6 pb-6 text-base text-surface-600 dark:text-surface-400 leading-relaxed border-t border-surface-100 dark:border-surface-700/50 pt-4" set:html={faq.a} />
                    </details>
                ))}
            </div>
        </div>
    </section>

    <!-- Related Calculators -->
    <section class="reveal-on-scroll">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50">{relatedTitle}</h2>
        <p class="text-surface-500 mt-2">Discover more specialized regression modeling tools.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {relatedItems.map((item, i) => {
          const themes = [
            { accent: 'accent', icon: '📈' },
            { accent: 'primary', icon: '📐' },
            { accent: 'emerald', icon: '🧬' },
            { accent: 'violet', icon: '🔮' },
            { accent: 'cyan', icon: '🔬' },
            { accent: 'rose', icon: '📍' },
          ];
          const t = themes[i % themes.length];
          return (
            <a href={item.url} class="group/card relative p-6 rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 overflow-hidden">
              <div class={`absolute inset-0 bg-gradient-to-br from-${t.accent}-500/0 to-${t.accent}-500/0 group-hover/card:from-${t.accent}-500/5 group-hover/card:to-${t.accent}-500/10 transition-all duration-500`}></div>
              <div class="relative z-10">
                <div class={`w-12 h-12 rounded-xl bg-${t.accent}-100 dark:bg-${t.accent}-900/30 flex items-center justify-center mb-4 group-hover/card:scale-110 transition-transform duration-300 text-xl`}>
                  {t.icon}
                </div>
                <h3 class={`text-lg font-bold text-${t.accent}-700 dark:text-${t.accent}-400 mb-2`}>{item.name}</h3>
                <p class="text-sm text-surface-500 dark:text-surface-400">{item.desc}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // ── Reveal on Scroll (IntersectionObserver) ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── Interactive 3D Tilt Effect (Optimized) ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    let rect: DOMRect | null = null;
    el.addEventListener('mouseenter', () => { rect = el.getBoundingClientRect(); });
    el.addEventListener('mousemove', (e: MouseEvent) => {
      if (!rect) rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -10;
      const rotateY = ((x - centerX) / centerX) * 10;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave', () => {
      rect = null;
      el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
