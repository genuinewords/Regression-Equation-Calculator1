---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import RegressionCurveCalculator from 'theme/components/RegressionCurveCalculator.astro';
import ToolInfoBox from 'theme/components/ToolInfoBox.astro';
import { mergeTranslations } from 'theme/i18n/utils';
import siteConfig from 'src/data/site-config.json';

const locale = 'en';
const translations = await mergeTranslations(locale);
const rcc = (translations as any).rcCalc;

const canonicalUrl = new URL('/regression-curve-calculator/', siteConfig.siteUrl).href;

const breadcrumb = rcc?.breadcrumb || 'Back to Main Regression Calculator';

const whatIsTitle = rcc?.whatIsTitle || 'What Is Regression Curve Analysis?';
const whatIsText = rcc?.whatIsText || '';

const modelTypesTitle = rcc?.modelTypesTitle || 'Regression Model Types Compared';
const modelTypesText = rcc?.modelTypesText || '';
const modelTypesTable = rcc?.modelTypesTable || '';

const howWorksTitle = rcc?.howWorksTitle || 'How the Regression Curve Calculator Works';
const howWorksText = rcc?.howWorksText || '';
const howWorksSteps: string[] = rcc?.howWorksSteps ?? [];

const howUseTitle = rcc?.howUseTitle || 'How to Use This Regression Curve Calculator';
const howUseText = rcc?.howUseText || '';
const howUseSteps: string[] = rcc?.howUseSteps ?? [];

const rSquaredTitle = rcc?.rSquaredTitle || 'Understanding R-Squared and Model Comparison';
const rSquaredText = rcc?.rSquaredText || '';
const rSquaredTable = rcc?.rSquaredTable || '';

const chooseRightTitle = rcc?.chooseRightTitle || 'Choosing the Right Regression Model for Your Data';
const chooseRightText = rcc?.chooseRightText || '';
const chooseRightTable = rcc?.chooseRightTable || '';

const exampleTitle = rcc?.exampleTitle || 'Regression Curve Calculator Step-by-Step Example';
const exampleText = rcc?.exampleText || '';

const whenCurveTitle = rcc?.whenCurveTitle || 'When to Use Regression Curve Analysis';
const whenCurveText = rcc?.whenCurveText || '';
const whenCurveTable = rcc?.whenCurveTable || '';

const mistakesTitle = rcc?.mistakesTitle || 'Common Mistakes in Regression Model Selection';
const mistakesText = rcc?.mistakesText || '';

const comparisonTitle = rcc?.comparisonTitle || 'Linear vs Quadratic vs Exponential vs Logarithmic Regression';
const comparisonText = rcc?.comparisonText || '';
const comparisonTable = rcc?.comparisonTable || '';

const polynomialTitle = rcc?.polynomialTitle || 'Polynomial Regression and Higher-Order Curves';
const polynomialText = rcc?.polynomialText || '';

const vizTitle = rcc?.vizTitle || 'Interpreting Regression Curve Visualization';
const vizText = rcc?.vizText || '';

const exportTitle = rcc?.exportTitle || 'Exporting and Using Your Regression Results';
const exportText = rcc?.exportText || '';

const faqTitle = rcc?.faqTitle || 'Frequently Asked Questions';
const faqs: Array<{q: string; a: string}> = rcc?.faqs ?? [];

const relatedTitle = rcc?.relatedTitle || 'Related Regression Calculators';
const relatedItems: Array<{name: string; url: string; desc: string}> = rcc?.relatedItems ?? [];

const mtHeaders = modelTypesTable ? modelTypesTable.split('|').slice(0, 4) : [];
const mtRows: string[][] = [];
if (modelTypesTable) {
  const mtParts = modelTypesTable.split('|');
  for (let i = 4; i + 3 < mtParts.length; i += 4) {
    mtRows.push([mtParts[i], mtParts[i+1], mtParts[i+2], mtParts[i+3]]);
  }
}

const rsHeaders = rSquaredTable ? rSquaredTable.split('|').slice(0, 2) : [];
const rsRows: string[][] = [];
if (rSquaredTable) {
  const rsParts = rSquaredTable.split('|');
  for (let i = 2; i + 1 < rsParts.length; i += 2) {
    rsRows.push([rsParts[i], rsParts[i+1]]);
  }
}

const crHeaders = chooseRightTable ? chooseRightTable.split('|').slice(0, 3) : [];
const crRows: string[][] = [];
if (chooseRightTable) {
  const crParts = chooseRightTable.split('|');
  for (let i = 3; i + 2 < crParts.length; i += 3) {
    crRows.push([crParts[i], crParts[i+1], crParts[i+2]]);
  }
}

const wcHeaders = whenCurveTable ? whenCurveTable.split('|').slice(0, 3) : [];
const wcRows: string[][] = [];
if (whenCurveTable) {
  const wcParts = whenCurveTable.split('|');
  for (let i = 3; i + 2 < wcParts.length; i += 3) {
    wcRows.push([wcParts[i], wcParts[i+1], wcParts[i+2]]);
  }
}

const cmpHeaders = comparisonTable ? comparisonTable.split('|').slice(0, 5) : [];
const cmpRows: string[][] = [];
if (comparisonTable) {
  const cmpParts = comparisonTable.split('|');
  for (let i = 5; i + 4 < cmpParts.length; i += 5) {
    cmpRows.push([cmpParts[i], cmpParts[i+1], cmpParts[i+2], cmpParts[i+3], cmpParts[i+4]]);
  }
}

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Regression Curve Calculator",
  "description": "Free online regression curve calculator. Compare linear, quadratic, exponential, and logarithmic models side-by-side with R² comparison and visual graphs.",
  "url": "https://www.regressionequationcalculator.com/regression-curve-calculator/",
  "applicationCategory": "MathCalculator",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": ["4 model comparison", "R² ranking", "Best fit detection", "Visual graph overlay", "Prediction forecasting", "Step-by-step solutions"]
};

const faqSchema = faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: { '@type': 'Answer', text: faq.a },
      })),
    }
  : null;

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Compare Regression Curves",
  "description": "Step-by-step guide to comparing regression models and finding the best fit curve",
  "totalTime": "PT5M",
  "step": [
    { "@type": "HowToStep", "name": "Enter Data", "text": "Input your X and Y data pairs into the calculator." },
    { "@type": "HowToStep", "name": "Run All Models", "text": "The calculator simultaneously fits linear, quadratic, exponential, and logarithmic models." },
    { "@type": "HowToStep", "name": "Compare R²", "text": "Review R² values for each model to see which explains the most variance." },
    { "@type": "HowToStep", "name": "Select Best Fit", "text": "Choose the model with the highest R² that also makes theoretical sense." },
    { "@type": "HowToStep", "name": "Make Predictions", "text": "Use the best-fit equation to predict Y for new X values." }
  ]
};
---

<BaseLayout
  title={rcc?.title || "Regression Curve Calculator — Compare Multiple Models & Find Best Fit"}
  description={rcc?.description || "Free regression curve calculator. Compare linear, quadratic, exponential, and logarithmic models side-by-side. Find the best fit curve with R² comparison and visual graphs."}
  locale={locale}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
        <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] bg-primary-100/30 dark:bg-primary-900/10 blur-[100px] rounded-full animate-pulse"></div>
        <div class="absolute bottom-1/4 left-1/3 w-[350px] h-[350px] bg-accent-100/30 dark:bg-accent-900/10 blur-[90px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 text-center lg:text-left reveal-on-scroll">
          <nav class="mb-6 text-sm font-medium flex items-center justify-center lg:justify-start gap-2">
            <a href="/" class="text-surface-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{breadcrumb}</a>
          </nav>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 via-primary-600 to-accent-600 dark:from-primary-400 dark:via-primary-500 dark:to-accent-400 bg-clip-text text-transparent leading-tight mb-6">
            Regression Curve Calculator
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-8">
            Find the perfect model for your data. Simultaneously analyze linear, quadratic, exponential, and logarithmic curves to identify the optimal mathematical fit with unparalleled precision.
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="#calculator-tool" class="px-8 py-3 rounded-xl bg-primary-600 text-white font-semibold shadow-lg shadow-primary-600/20 hover:bg-primary-700 hover:shadow-xl hover:shadow-primary-600/30 transition-all duration-300 hover:-translate-y-1">
              Compare Models
            </a>
            <a href="#types" class="px-8 py-3 rounded-xl bg-white dark:bg-surface-800 text-surface-700 dark:text-surface-200 font-semibold border border-surface-200 dark:border-surface-700 hover:border-primary-300 transition-all duration-300 hover:-translate-y-1">
              View Model Types
            </a>
          </div>
        </div>
        <div class="flex-1 w-full max-w-lg lg:max-w-none reveal-on-scroll" style="transition-delay: 200ms">
          <div class="relative group" data-tilt>
            <div class="absolute -inset-4 bg-gradient-to-r from-primary-500/20 to-accent-500/20 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-500"></div>
            <div class="relative overflow-hidden rounded-3xl border border-white/20 shadow-2xl">
              <img
                src="/images/exponential-hero.png"
                alt="Regression Curve Comparison Visualization"
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                width="600"
                height="400"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/20 via-transparent to-transparent opacity-40"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator Tool -->
  <section id="calculator-tool" class="py-12 md:py-16 bg-surface-50/60 dark:bg-surface-800/40 rounded-t-[3rem] -mt-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <RegressionCurveCalculator translations={translations} />
    </div>
  </section>

  <!-- Tool Info Box -->
  <ToolInfoBox
    toolName="Regression Curve Calculator"
    keyPoints={[
      {
        icon: "📉",
        title: "Model Comparison",
        description: "Fits linear, quadratic, exponential, and logarithmic curves simultaneously."
      },
      {
        icon: "📥",
        title: "Enter X & Y Data",
        description: "Input paired data points — the calculator runs all four models at once."
      },
      {
        icon: "📊",
        title: "Best-Fit Ranking",
        description: "Compare R² values side-by-side and identify the best-fitting model."
      },
      {
        icon: "🔬",
        title: "Best For",
        description: "Exploratory analysis when you're unsure which regression model fits best."
      }
    ]}
    highlightTip="The highest R² doesn't always mean the best model — consider theoretical justification and simplicity too."
  />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-12 py-16">
    <!-- What Is -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-primary-600 rounded-full"></span>
          {whatIsTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed text-lg" set:html={whatIsText} />
      </div>
    </section>

    <!-- Model Types Compared -->
    <section id="types" class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-accent-600 rounded-full"></span>
          {modelTypesTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={modelTypesText} />

        {mtRows.length > 0 && (
          <div class="overflow-hidden mb-8 rounded-2xl border border-surface-200 dark:border-surface-700/50 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gradient-to-r from-accent-600 to-accent-500 dark:from-accent-800 dark:to-accent-700">
                  {mtHeaders.map((h) => (
                    <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                {mtRows.map((row) => (
                  <tr class="hover:bg-accent-50/20 dark:hover:bg-accent-900/10 transition-colors">
                    {row.map((cell) => (
                      <td class="px-5 py-3.5 text-surface-600 dark:text-surface-400 font-medium">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="reveal-on-scroll">
      <div class="content-box rounded-3xl border border-surface-200/60 dark:border-surface-700/40 bg-white dark:bg-surface-800/60 backdrop-blur-md p-8 md:p-10 shadow-xl shadow-surface-200/20 dark:shadow-surface-950/40 relative overflow-hidden group">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-primary-600 rounded-full"></span>
          {comparisonTitle}
        </h2>
        <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 leading-relaxed mb-8" set:html={comparisonText} />
        {cmpRows.length > 0 && (
          <div class="overflow-hidden rounded-2xl border border-surface-200 dark:border-surface-700/50 shadow-sm">
            <table class="w-full text-xs">
              <thead>
                <tr class="bg-gradient-to-r from-primary-600 to-primary-500 dark:from-primary-800 dark:to-primary-700">
                  {cmpHeaders.map((h) => (
                    <th class="px-3 py-3 text-left font-semibold text-white uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                {cmpRows.map((row) => (
                  <tr class="hover:bg-primary-50/20 dark:hover:bg-primary-900/10 transition-colors">
                    {row.map((cell) => (
                      <td class="px-3 py-3 text-surface-600 dark:text-surface-400 font-medium">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </section>

    <!-- R-Squared & Selection -->
    <section class="reveal-on-scroll">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
            <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                {rSquaredTitle}
            </h2>
            <div class="prose prose-surface max-w-none text-sm text-surface-600 dark:text-surface-400 leading-relaxed mb-6" set:html={rSquaredText} />
            {rsRows.length > 0 && (
              <div class="overflow-hidden rounded-xl border border-surface-200 dark:border-surface-700/50">
                <table class="w-full text-xs">
                  <thead class="bg-surface-50 dark:bg-surface-900/50">
                    <tr>
                      {rsHeaders.map(h => <th class="px-3 py-2 text-left font-semibold text-surface-700 dark:text-surface-300 uppercase">{h}</th>)}
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                    {rsRows.map(row => (
                      <tr class="hover:bg-amber-50/10 transition-colors">
                        {row.map(cell => <td class="px-3 py-2 text-surface-600 dark:text-surface-400">{cell}</td>)}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
        </div>

        <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg">
            <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                {chooseRightTitle}
            </h2>
            <div class="prose prose-surface max-w-none text-sm text-surface-600 dark:text-surface-400 leading-relaxed mb-6" set:html={chooseRightText} />
            {crRows.length > 0 && (
              <div class="overflow-hidden rounded-xl border border-surface-200 dark:border-surface-700/50">
                <table class="w-full text-xs">
                  <thead class="bg-surface-50 dark:bg-surface-900/50">
                    <tr>
                      {crHeaders.map(h => <th class="px-3 py-2 text-left font-semibold text-surface-700 dark:text-surface-300 uppercase">{h}</th>)}
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                    {crRows.map(row => (
                      <tr class="hover:bg-violet-50/10 transition-colors">
                        {row.map(cell => <td class="px-3 py-2 text-surface-600 dark:text-surface-400">{cell}</td>)}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
        </div>
      </div>
    </section>

    <!-- When to Use Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <div class="content-box rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white dark:bg-surface-800/60 p-8 shadow-lg relative overflow-hidden group">
                <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 mb-6">{whenCurveTitle}</h2>
                <div class="prose prose-surface max-w-none text-surface-600 dark:text-surface-400 mb-8" set:html={whenCurveText} />
                {wcRows.length > 0 && (
                  <div class="overflow-hidden rounded-2xl border border-surface-200 dark:border-surface-700/50 shadow-sm mb-8">
                    <table class="w-full text-sm">
                      <thead>
                        <tr class="bg-gradient-to-r from-emerald-600 to-emerald-500 dark:from-emerald-800 dark:to-emerald-700">
                          {wcHeaders.map((h) => (
                            <th class="px-4 py-3 text-left font-semibold text-white uppercase tracking-wider">{h}</th>
                          ))}
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-surface-100 dark:divide-surface-700/40">
                        {wcRows.map((row) => (
                          <tr class="hover:bg-emerald-50/20 dark:hover:bg-emerald-900/10 transition-colors">
                            {row.map((cell) => (
                              <td class="px-4 py-3 text-surface-600 dark:text-surface-400 font-medium">{cell}</td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="reveal-on-scroll">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50 text-center mb-10">{faqTitle}</h2>
            <div class="space-y-4">
                {faqs.map((faq, i) => (
                    <details class="group rounded-2xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm overflow-hidden hover:shadow-lg transition-all duration-300">
                        <summary class="flex items-center justify-between px-6 py-5 cursor-pointer text-base font-bold text-surface-800 dark:text-surface-200 hover:text-primary-600 transition-colors list-none">
                            <span>{faq.q}</span>
                            <div class="w-8 h-8 rounded-full bg-surface-50 dark:bg-surface-900/50 flex items-center justify-center group-open:rotate-180 transition-transform">
                                <svg class="w-4 h-4 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </summary>
                        <div class="px-6 pb-6 text-base text-surface-600 dark:text-surface-400 leading-relaxed border-t border-surface-100 dark:border-surface-700/50 pt-4" set:html={faq.a} />
                    </details>
                ))}
            </div>
        </div>
    </section>

    <!-- Related Calculators -->
    <section class="reveal-on-scroll">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-surface-900 dark:text-surface-50">{relatedTitle}</h2>
        <p class="text-surface-500 mt-2">Discover more specialized regression modeling tools.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {relatedItems.map((item, i) => {
          const themes = [
            { accent: 'accent', icon: '📈' },
            { accent: 'primary', icon: '📐' },
            { accent: 'emerald', icon: '🧬' },
            { accent: 'violet', icon: '🔮' },
            { accent: 'cyan', icon: '🔬' },
            { accent: 'rose', icon: '📍' },
            { accent: 'amber', icon: '⚖️' },
          ];
          const t = themes[i % themes.length];
          return (
            <a href={item.url} class="group/card relative p-6 rounded-3xl border border-surface-200 dark:border-surface-700/60 bg-white/70 dark:bg-surface-800/60 backdrop-blur-sm shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 overflow-hidden">
              <div class={`absolute inset-0 bg-gradient-to-br from-${t.accent}-500/0 to-${t.accent}-500/0 group-hover/card:from-${t.accent}-500/5 group-hover/card:to-${t.accent}-500/10 transition-all duration-500`}></div>
              <div class="relative z-10">
                <div class={`w-12 h-12 rounded-xl bg-${t.accent}-100 dark:bg-${t.accent}-900/30 flex items-center justify-center mb-4 group-hover/card:scale-110 transition-transform duration-300 text-xl`}>
                  {t.icon}
                </div>
                <h3 class={`text-lg font-bold text-${t.accent}-700 dark:text-${t.accent}-400 mb-2`}>{item.name}</h3>
                <p class="text-sm text-surface-500 dark:text-surface-400">{item.desc}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // ── Reveal on Scroll (IntersectionObserver) ──
  const revealElements = document.querySelectorAll('.reveal-on-scroll');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));

  // ── Interactive 3D Tilt Effect (Optimized) ──
  const tiltElements = document.querySelectorAll<HTMLElement>('[data-tilt]');
  tiltElements.forEach((el) => {
    let rect: DOMRect | null = null;
    el.addEventListener('mouseenter', () => { rect = el.getBoundingClientRect(); });
    el.addEventListener('mousemove', (e: MouseEvent) => {
      if (!rect) rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -10;
      const rotateY = ((x - centerX) / centerX) * 10;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave', () => {
      rect = null;
      el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
