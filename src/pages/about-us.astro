---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import { mergeTranslations } from 'theme/i18n/utils';

const locale = 'en';
const translations = await mergeTranslations(locale);
---

<BaseLayout
  title={translations.about.title}
  description={translations.about.description}
  locale={locale}
  isAboutPage={true}
>
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight bg-gradient-to-r from-primary-700 to-accent-600 bg-clip-text text-transparent">
        {translations.about.title}
      </h1>

      <div class="mt-10 grid gap-8 md:grid-cols-3">
        <div class="rounded-2xl border border-surface-200/60 bg-white p-8 shadow-sm hover:shadow-md transition-shadow duration-300">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-primary-100 text-primary-600">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-surface-900">{translations.about.mission}</h2>
          </div>
          <p class="text-surface-600 leading-relaxed">{translations.about.missionText}</p>
        </div>

        <div class="rounded-2xl border border-surface-200/60 bg-white p-8 shadow-sm hover:shadow-md transition-shadow duration-300">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-accent-100 text-accent-600">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-surface-900">{translations.about.values}</h2>
          </div>
          <p class="text-surface-600 leading-relaxed">{translations.about.valuesText}</p>
        </div>

        <div class="rounded-2xl border border-surface-200/60 bg-white p-8 shadow-sm hover:shadow-md transition-shadow duration-300">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-primary-100 text-primary-600">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-surface-900">{translations.about.team}</h2>
          </div>
          <p class="text-surface-599 leading-relaxed">{translations.about.teamText}</p>
        </div>
      </div>

      <div class="mt-12 rounded-2xl bg-gradient-to-r from-primary-50 to-accent-50 border border-primary-100/60 p-8">
        <p class="text-surface-700 leading-relaxed text-lg">{translations.about.content}</p>
      </div>

      <div class="mt-12">
        <h2 class="text-2xl font-bold text-surface-900 mb-6">Explore Our Tools</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/linear-regression-calculator/" class="rounded-2xl border border-surface-200/60 bg-white p-5 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 group/card">
            <h3 class="text-base font-bold text-accent-700 group-hover/card:text-accent-800">Linear Regression Calculator</h3>
            <p class="text-sm text-surface-500 mt-1">Calculate y = mx + b with step-by-step</p>
          </a>
          <a href="/quadratic-regression-calculator/" class="rounded-2xl border border-surface-200/60 bg-white p-5 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 group/card">
            <h3 class="text-base font-bold text-primary-700 group-hover/card:text-primary-800">Quadratic Regression Calculator</h3>
            <p class="text-sm text-surface-500 mt-1">Model curved relationships</p>
          </a>
          <a href="/multiple-regression-calculator/" class="rounded-2xl border border-surface-200/60 bg-white p-5 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 group/card">
            <h3 class="text-base font-bold text-emerald-700 group-hover/card:text-emerald-800">Multiple Regression Calculator</h3>
            <p class="text-sm text-surface-500 mt-1">Use two or more predictors</p>
          </a>
          <a href="/pearson-correlation-calculator/" class="rounded-2xl border border-surface-200/60 bg-white p-5 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 group/card">
            <h3 class="text-base font-bold text-amber-700 group-hover/card:text-amber-800">Pearson Correlation Calculator</h3>
            <p class="text-sm text-surface-500 mt-1">Measure linear relationship strength</p>
          </a>
          <a href="/grubbs-test-calculator/" class="rounded-2xl border border-surface-200/60 bg-white p-5 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 group/card">
            <h3 class="text-base font-bold text-rose-700 group-hover/card:text-rose-800">Grubbs' Test Calculator</h3>
            <p class="text-sm text-surface-500 mt-1">Detect outliers in your dataset</p>
          </a>
          <a href="/regression-assumptions-checker/" class="rounded-2xl border border-surface-200/60 bg-white p-5 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 group/card">
            <h3 class="text-base font-bold text-primary-700 group-hover/card:text-primary-800">Regression Assumptions Checker</h3>
            <p class="text-sm text-surface-500 mt-1">Verify your data meets OLS assumptions</p>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
