---
import type { MergedTranslations } from 'theme/i18n/types';

interface Props {
  translations: MergedTranslations;
}

const { translations } = Astro.props;
const ra = (translations as any).assumptionsChecker;

const title = ra?.manualDemoTitle || 'How to calculate Pearson correlation by hand (step‑by‑step)';
const step1 = ra?.manualDemoStep1 || 'Calculate means (x̄, ȳ)';
const step2 = ra?.manualDemoStep2 || 'Calculate deviations (xᵢ – x̄) and (yᵢ – ȳ)';
const step3 = ra?.manualDemoStep3 || 'Multiply deviations (cross‑products)';
const step4 = ra?.manualDemoStep4 || 'Square deviations (for x and y)';
const step5 = ra?.manualDemoStep5 || 'Sum everything';
const step6 = ra?.manualDemoStep6 || 'Apply Pearson formula';
const interpretation = ra?.manualDemoInterpretation || 'r ≈ 0.77 → strong positive correlation.';
const note = ra?.manualDemoNote || 'This manual calculation helps you understand the correlation that underlies regression. Your regression assumptions (linearity, etc.) depend on this strength of relationship.';
const sumLabel = ra?.manualDemoSumLabel || 'Sum (Σ)';

const data = [
  { x: 1, y: 2, dx: -2, dy: -2, cross: 4, sqDx: 4, sqDy: 4 },
  { x: 2, y: 4, dx: -1, dy:  0, cross: 0, sqDx: 1, sqDy: 0 },
  { x: 3, y: 5, dx:  0, dy:  1, cross: 0, sqDx: 0, sqDy: 1 },
  { x: 4, y: 4, dx:  1, dy:  0, cross: 0, sqDx: 1, sqDy: 0 },
  { x: 5, y: 5, dx:  2, dy:  1, cross: 2, sqDx: 4, sqDy: 1 },
];
const sums = { cross: 6, sqDx: 10, sqDy: 6 };
---

<div>
  <h2 class="text-xl font-bold text-primary-700 dark:text-primary-400 mb-6">{title}</h2>

  <div class="space-y-6">
    <div class="p-4 rounded-xl bg-surface-50 dark:bg-surface-700/40 border border-surface-200 dark:border-surface-600/50">
      <p class="text-sm text-surface-600 dark:text-surface-400 mb-1">Dataset</p>
      <p class="font-mono text-sm text-surface-800 dark:text-surface-200">X: 1, 2, 3, 4, 5 &nbsp;&nbsp;|&nbsp;&nbsp; Y: 2, 4, 5, 4, 5 &nbsp;&nbsp;|&nbsp;&nbsp; n = 5</p>
    </div>

    <div class="space-y-3 text-sm text-surface-700 dark:text-surface-300">
      <div class="p-3 rounded-lg bg-primary-50 dark:bg-primary-900/20 border-l-4 border-primary-400 dark:border-primary-600">
        <p class="font-semibold text-primary-700 dark:text-primary-400"><span class="font-mono">Step 1</span> — {step1}</p>
        <p class="font-mono mt-1 text-surface-800 dark:text-surface-200">x̄ = (1+2+3+4+5) / 5 = <strong>3.0</strong> &nbsp;&nbsp; ȳ = (2+4+5+4+5) / 5 = <strong>4.0</strong></p>
      </div>

      <div class="p-3 rounded-lg bg-primary-50 dark:bg-primary-900/20 border-l-4 border-primary-400 dark:border-primary-600">
        <p class="font-semibold text-primary-700 dark:text-primary-400"><span class="font-mono">Step 2</span> — {step2}</p>
        <p class="font-mono mt-1 text-surface-800 dark:text-surface-200">Subtract x̄ from each xᵢ, and ȳ from each yᵢ (see table below)</p>
      </div>

      <div class="p-3 rounded-lg bg-primary-50 dark:bg-primary-900/20 border-l-4 border-primary-400 dark:border-primary-600">
        <p class="font-semibold text-primary-700 dark:text-primary-400"><span class="font-mono">Step 3</span> — {step3}</p>
        <p class="font-mono mt-1 text-surface-800 dark:text-surface-200">(xᵢ – x̄)(yᵢ – ȳ) for each row (see table below)</p>
      </div>

      <div class="p-3 rounded-lg bg-primary-50 dark:bg-primary-900/20 border-l-4 border-primary-400 dark:border-primary-600">
        <p class="font-semibold text-primary-700 dark:text-primary-400"><span class="font-mono">Step 4</span> — {step4}</p>
        <p class="font-mono mt-1 text-surface-800 dark:text-surface-200">(xᵢ – x̄)² and (yᵢ – ȳ)² for each row (see table below)</p>
      </div>

      <div class="p-3 rounded-lg bg-primary-50 dark:bg-primary-900/20 border-l-4 border-primary-400 dark:border-primary-600">
        <p class="font-semibold text-primary-700 dark:text-primary-400"><span class="font-mono">Step 5</span> — {step5}</p>
        <p class="font-mono mt-1 text-surface-800 dark:text-surface-200">Σ(xᵢ–x̄)(yᵢ–ȳ) = <strong>{sums.cross}</strong> &nbsp;&nbsp; Σ(xᵢ–x̄)² = <strong>{sums.sqDx}</strong> &nbsp;&nbsp; Σ(yᵢ–ȳ)² = <strong>{sums.sqDy}</strong></p>
      </div>

      <div class="p-3 rounded-lg bg-accent-50 dark:bg-accent-900/20 border-l-4 border-accent-400 dark:border-accent-600">
        <p class="font-semibold text-accent-700 dark:text-accent-400"><span class="font-mono">Step 6</span> — {step6}</p>
        <p class="font-mono mt-1 text-surface-800 dark:text-surface-200 leading-relaxed">
          r = Σ(xᵢ–x̄)(yᵢ–ȳ) / √[ Σ(xᵢ–x̄)² × Σ(yᵢ–ȳ)² ]<br />
          r = {sums.cross} / √[{sums.sqDx} × {sums.sqDy}]<br />
          r = {sums.cross} / √{sums.sqDx * sums.sqDy}<br />
          r = {sums.cross} / {(Math.sqrt(sums.sqDx * sums.sqDy)).toFixed(4)}<br />
          r ≈ <strong>0.7746</strong>
        </p>
      </div>
    </div>

    <div class="overflow-x-auto rounded-xl border border-surface-200 dark:border-surface-600/60">
      <table class="w-full text-sm font-mono">
        <thead>
          <tr class="bg-gradient-to-r from-primary-600 to-accent-600 text-white">
            <th class="px-3 py-2.5 text-left font-semibold text-xs uppercase tracking-wider">x</th>
            <th class="px-3 py-2.5 text-left font-semibold text-xs uppercase tracking-wider">y</th>
            <th class="px-3 py-2.5 text-right font-semibold text-xs uppercase tracking-wider">(xᵢ–x̄)</th>
            <th class="px-3 py-2.5 text-right font-semibold text-xs uppercase tracking-wider">(yᵢ–ȳ)</th>
            <th class="px-3 py-2.5 text-right font-semibold text-xs uppercase tracking-wider">(xᵢ–x̄)(yᵢ–ȳ)</th>
            <th class="px-3 py-2.5 text-right font-semibold text-xs uppercase tracking-wider">(xᵢ–x̄)²</th>
            <th class="px-3 py-2.5 text-right font-semibold text-xs uppercase tracking-wider">(yᵢ–ȳ)²</th>
          </tr>
        </thead>
        <tbody>
          {data.map((row, i) => (
            <tr class={`border-b border-surface-100 dark:border-surface-700/40 ${i % 2 === 0 ? 'bg-white dark:bg-surface-800/30' : 'bg-surface-50 dark:bg-surface-800/50'} hover:bg-primary-50/40 dark:hover:bg-primary-900/10 transition-colors`}>
              <td class="px-3 py-2 text-surface-800 dark:text-surface-200">{row.x}</td>
              <td class="px-3 py-2 text-surface-800 dark:text-surface-200">{row.y}</td>
              <td class="px-3 py-2 text-right text-surface-600 dark:text-surface-400">{row.dx}</td>
              <td class="px-3 py-2 text-right text-surface-600 dark:text-surface-400">{row.dy}</td>
              <td class="px-3 py-2 text-right text-primary-700 dark:text-primary-400 font-semibold">{row.cross}</td>
              <td class="px-3 py-2 text-right text-surface-600 dark:text-surface-400">{row.sqDx}</td>
              <td class="px-3 py-2 text-right text-surface-600 dark:text-surface-400">{row.sqDy}</td>
            </tr>
          ))}
          <tr class="bg-primary-50 dark:bg-primary-900/20 font-bold border-t-2 border-primary-200 dark:border-primary-700/50">
            <td class="px-3 py-2.5 text-primary-700 dark:text-primary-400" colspan="2">{sumLabel}</td>
            <td class="px-3 py-2.5 text-right text-surface-500">0</td>
            <td class="px-3 py-2.5 text-right text-surface-500">0</td>
            <td class="px-3 py-2.5 text-right text-primary-700 dark:text-primary-300">{sums.cross}</td>
            <td class="px-3 py-2.5 text-right text-primary-700 dark:text-primary-300">{sums.sqDx}</td>
            <td class="px-3 py-2.5 text-right text-primary-700 dark:text-primary-300">{sums.sqDy}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="p-4 rounded-xl bg-gradient-to-r from-emerald-50 to-primary-50 dark:from-emerald-900/25 dark:to-primary-900/25 border border-emerald-200 dark:border-emerald-800/40">
      <p class="text-sm font-semibold text-emerald-700 dark:text-emerald-400">{interpretation}</p>
    </div>

    <div class="p-4 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800/50 flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-500 dark:text-amber-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20 10 10 0 000-20z" /></svg>
      <p class="text-sm text-amber-700 dark:text-amber-300 leading-relaxed">{note}</p>
    </div>
  </div>
</div>
