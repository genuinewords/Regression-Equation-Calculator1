---
import type { MergedTranslations } from 'theme/i18n/types';

interface Props {
  translations: MergedTranslations;
}

const { translations } = Astro.props;
const home = translations.home;
---

<section>
  <div class="mx-auto max-w-3xl">
    <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 text-center mb-8">{home.howItWorksTitle}</h2>

    <div class="relative">
      <div class="absolute left-6 top-8 bottom-8 w-px bg-gradient-to-b from-primary-300 dark:from-primary-700 via-accent-300 dark:via-accent-700 to-primary-300 dark:to-primary-700 hidden sm:block" aria-hidden="true"></div>

      <div class="space-y-6">
        <div class="flex gap-5 items-start group">
          <div class="relative flex-shrink-0">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-primary-500/20 dark:shadow-primary-500/30 group-hover:shadow-primary-500/40 dark:group-hover:shadow-primary-400/30 group-hover:scale-110 transition-all duration-300">
              1
            </div>
          </div>
          <div class="pt-1 group-hover:translate-x-1 transition-transform duration-200">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-5 h-5 text-primary-500 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6z" /></svg>
              <h3 class="text-base font-semibold text-surface-800 dark:text-surface-200">{home.howItWorksStep1Title}</h3>
            </div>
            <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">{home.howItWorksStep1}</p>
          </div>
        </div>

        <div class="flex gap-5 items-start group">
          <div class="relative flex-shrink-0">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-primary-500/20 dark:shadow-primary-500/30 group-hover:shadow-primary-500/40 dark:group-hover:shadow-primary-400/30 group-hover:scale-110 transition-all duration-300">
              2
            </div>
          </div>
          <div class="pt-1 group-hover:translate-x-1 transition-transform duration-200">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-5 h-5 text-accent-500 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
              <h3 class="text-base font-semibold text-surface-800 dark:text-surface-200">{home.howItWorksStep2Title}</h3>
            </div>
            <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">{home.howItWorksStep2}</p>
          </div>
        </div>

        <div class="flex gap-5 items-start group">
          <div class="relative flex-shrink-0">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-primary-500/20 dark:shadow-primary-500/30 group-hover:shadow-primary-500/40 dark:group-hover:shadow-primary-400/30 group-hover:scale-110 transition-all duration-300">
              3
            </div>
          </div>
          <div class="pt-1 group-hover:translate-x-1 transition-transform duration-200">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-5 h-5 text-primary-500 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg>
              <h3 class="text-base font-semibold text-surface-800 dark:text-surface-200">{home.howItWorksStep3Title}</h3>
            </div>
            <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">{home.howItWorksStep3}</p>
          </div>
        </div>

        <div class="flex gap-5 items-start group">
          <div class="relative flex-shrink-0">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-primary-500/20 dark:shadow-primary-500/30 group-hover:shadow-primary-500/40 dark:group-hover:shadow-primary-400/30 group-hover:scale-110 transition-all duration-300">
              4
            </div>
          </div>
          <div class="pt-1 group-hover:translate-x-1 transition-transform duration-200">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-5 h-5 text-accent-500 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
              <h3 class="text-base font-semibold text-surface-800 dark:text-surface-200">{home.howItWorksStep4Title}</h3>
            </div>
            <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">{home.howItWorksStep4}</p>
          </div>
        </div>

        <div class="flex gap-5 items-start group">
          <div class="relative flex-shrink-0">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-primary-500/20 dark:shadow-primary-500/30 group-hover:shadow-primary-500/40 dark:group-hover:shadow-primary-400/30 group-hover:scale-110 transition-all duration-300">
              5
            </div>
          </div>
          <div class="pt-1 group-hover:translate-x-1 transition-transform duration-200">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-5 h-5 text-primary-500 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
              <h3 class="text-base font-semibold text-surface-800 dark:text-surface-200">{home.howItWorksStep5Title}</h3>
            </div>
            <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">{home.howItWorksStep5}</p>
          </div>
        </div>
      </div>
    </div>

    <slot />
  </div>
</section>
