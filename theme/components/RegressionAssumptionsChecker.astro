---
import type { MergedTranslations } from 'theme/i18n/types';

interface Props {
  translations: MergedTranslations;
}

const { translations } = Astro.props;
const ra = (translations as any).assumptionsChecker;
---

<section class="py-8" id="assumptions-checker" data-invalid-data={ra?.invalidData || 'Please enter at least 5 valid data points'}>
  <div class="mx-auto max-w-3xl">
    <div class="rounded-2xl shadow-lg dark:shadow-surface-950/40 shadow-primary-900/5 border border-surface-200/80 dark:border-surface-700/60 overflow-hidden bg-white dark:bg-surface-800/80 backdrop-blur-sm transition-colors duration-300">
      <div class="bg-gradient-to-r from-primary-600 to-accent-600 px-6 py-5">
        <h2 class="text-xl font-bold text-white">{ra?.title || 'Regression Assumptions Checker'}</h2>
        <p class="text-primary-100 text-sm mt-1">{ra?.description || 'Check all four linear regression assumptions for your data'}</p>
      </div>

      <div class="p-6 bg-surface-50/50 dark:bg-surface-800/50">
        <div class="mb-4">
          <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-300 mb-3">{ra?.enterData || 'Enter your data points'}</h3>
          <div class="overflow-x-auto rounded-lg border border-surface-200 dark:border-surface-600">
            <table class="w-full" id="assumptions-data-table">
              <thead>
                <tr class="bg-surface-100 dark:bg-surface-700/50 border-b border-surface-200 dark:border-surface-600">
                  <th class="px-3 py-2 text-left text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider w-12">#</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider">{ra?.xLabel || 'X Values'}</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider">{ra?.yLabel || 'Y Values'}</th>
                  <th class="px-3 py-2 w-10"></th>
                </tr>
              </thead>
              <tbody id="assumptions-data-rows">
              </tbody>
            </table>
          </div>
        </div>

        <div class="mb-6">
          <label class="text-sm font-semibold text-surface-700 dark:text-surface-300 mb-2 block">{ra?.significanceLevel || 'Significance Level (α)'}</label>
          <div class="flex gap-3">
            <label class="flex items-center gap-2 px-4 py-2 rounded-lg border border-surface-200 dark:border-surface-600 bg-white dark:bg-surface-700 cursor-pointer transition-all duration-200 hover:border-primary-300 dark:hover:border-primary-700 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 dark:has-[:checked]:bg-primary-900/30 has-[:checked]:ring-2 has-[:checked]:ring-primary-500/20">
              <input type="radio" name="assumptions-alpha" value="0.05" checked class="accent-primary-600" />
              <span class="text-sm font-medium text-surface-700 dark:text-surface-300">0.05</span>
            </label>
            <label class="flex items-center gap-2 px-4 py-2 rounded-lg border border-surface-200 dark:border-surface-600 bg-white dark:bg-surface-700 cursor-pointer transition-all duration-200 hover:border-primary-300 dark:hover:border-primary-700 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 dark:has-[:checked]:bg-primary-900/30 has-[:checked]:ring-2 has-[:checked]:ring-primary-500/20">
              <input type="radio" name="assumptions-alpha" value="0.01" class="accent-primary-600" />
              <span class="text-sm font-medium text-surface-700 dark:text-surface-300">0.01</span>
            </label>
            <label class="flex items-center gap-2 px-4 py-2 rounded-lg border border-surface-200 dark:border-surface-600 bg-white dark:bg-surface-700 cursor-pointer transition-all duration-200 hover:border-primary-300 dark:hover:border-primary-700 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 dark:has-[:checked]:bg-primary-900/30 has-[:checked]:ring-2 has-[:checked]:ring-primary-500/20">
              <input type="radio" name="assumptions-alpha" value="0.10" class="accent-primary-600" />
              <span class="text-sm font-medium text-surface-700 dark:text-surface-300">0.10</span>
            </label>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 mb-6">
          <button
            id="assumptions-add-row-btn"
            type="button"
            class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/25 border border-primary-200 dark:border-primary-800/50 rounded-lg transition-all duration-200 hover:bg-primary-100 dark:hover:bg-primary-900/40 hover:border-primary-300 dark:hover:border-primary-700 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary-500/30"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            {ra?.addRow || 'Add Row'}
          </button>
          <button
            id="assumptions-calculate-btn"
            type="button"
            class="inline-flex items-center gap-1.5 px-6 py-2 text-sm font-semibold text-white bg-gradient-to-r from-primary-600 to-accent-600 rounded-lg shadow-md shadow-primary-600/20 dark:shadow-primary-900/40 transition-all duration-200 hover:shadow-lg hover:shadow-primary-600/30 dark:hover:shadow-primary-900/50 hover:brightness-110 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary-500/30"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
            {ra?.checkAssumptions || 'Check Assumptions'}
          </button>
          <button
            id="assumptions-clear-btn"
            type="button"
            class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-surface-600 dark:text-surface-400 bg-surface-100 dark:bg-surface-700 border border-surface-200 dark:border-surface-600 rounded-lg transition-all duration-200 hover:bg-surface-200 dark:hover:bg-surface-600 hover:border-surface-300 dark:hover:border-surface-500 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-surface-400/30"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            {ra?.clear || 'Clear'}
          </button>
        </div>

        <div id="assumptions-error-msg" class="hidden mb-4 p-3 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/50 text-red-700 dark:text-red-400 text-sm"></div>

        <div id="assumptions-results-section" class="hidden animate-[fadeIn_0.3s_ease-out]">
          <div class="mb-6">
            <h3 class="text-lg font-bold text-surface-800 dark:text-surface-200 mb-4">{ra?.result || 'Results'}</h3>

            <div class="mb-6 p-4 rounded-xl border border-surface-200 dark:border-surface-600/50 bg-white dark:bg-surface-700/50">
              <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-2">{ra?.summary || 'Summary'}</p>
              <p id="assumptions-result-summary" class="text-base font-bold"></p>
              <p id="assumptions-result-summary-detail" class="text-sm text-surface-500 dark:text-surface-400 mt-1"></p>
            </div>

            <div class="space-y-4">
              <div id="assumption-card-linearity" class="p-5 rounded-xl border-2 transition-all duration-200">
                <div class="flex items-center gap-3 mb-3">
                  <span id="linearity-icon" class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center"></span>
                  <div>
                    <h4 class="font-bold text-base">{ra?.linearity || '1. Linearity'}</h4>
                    <p id="linearity-verdict" class="text-sm font-semibold"></p>
                  </div>
                </div>
                <div class="ml-11 space-y-2 text-sm text-surface-600 dark:text-surface-400">
                  <p id="linearity-detail"></p>
                  <p id="linearity-fix" class="text-surface-500 dark:text-surface-500 italic"></p>
                </div>
              </div>

              <div id="assumption-card-independence" class="p-5 rounded-xl border-2 transition-all duration-200">
                <div class="flex items-center gap-3 mb-3">
                  <span id="independence-icon" class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center"></span>
                  <div>
                    <h4 class="font-bold text-base">{ra?.independence || '2. Independence of Errors'}</h4>
                    <p id="independence-verdict" class="text-sm font-semibold"></p>
                  </div>
                </div>
                <div class="ml-11 space-y-2 text-sm text-surface-600 dark:text-surface-400">
                  <p id="independence-detail"></p>
                  <p id="independence-fix" class="text-surface-500 dark:text-surface-500 italic"></p>
                </div>
              </div>

              <div id="assumption-card-homoscedasticity" class="p-5 rounded-xl border-2 transition-all duration-200">
                <div class="flex items-center gap-3 mb-3">
                  <span id="homoscedasticity-icon" class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center"></span>
                  <div>
                    <h4 class="font-bold text-base">{ra?.homoscedasticity || '3. Homoscedasticity'}</h4>
                    <p id="homoscedasticity-verdict" class="text-sm font-semibold"></p>
                  </div>
                </div>
                <div class="ml-11 space-y-2 text-sm text-surface-600 dark:text-surface-400">
                  <p id="homoscedasticity-detail"></p>
                  <p id="homoscedasticity-fix" class="text-surface-500 dark:text-surface-500 italic"></p>
                </div>
              </div>

              <div id="assumption-card-normality" class="p-5 rounded-xl border-2 transition-all duration-200">
                <div class="flex items-center gap-3 mb-3">
                  <span id="normality-icon" class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center"></span>
                  <div>
                    <h4 class="font-bold text-base">{ra?.normality || '4. Normality of Residuals'}</h4>
                    <p id="normality-verdict" class="text-sm font-semibold"></p>
                  </div>
                </div>
                <div class="ml-11 space-y-2 text-sm text-surface-600 dark:text-surface-400">
                  <p id="normality-detail"></p>
                  <p id="normality-fix" class="text-surface-500 dark:text-surface-500 italic"></p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
            <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md transition-all duration-200 hover:scale-[1.01]">
              <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{ra?.nPoints || 'Data Points (n)'}</p>
              <p id="assumptions-result-n" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
            </div>
            <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md transition-all duration-200 hover:scale-[1.01]">
              <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{ra?.rSquared || 'R²'}</p>
              <p id="assumptions-result-rsquared" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
            </div>
            <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md transition-all duration-200 hover:scale-[1.01]">
              <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{ra?.equation || 'Equation'}</p>
              <p id="assumptions-result-equation" class="text-sm font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
            </div>
          </div>

          <details class="group mt-6">
            <summary class="flex items-center gap-2 cursor-pointer text-sm font-semibold text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors select-none">
              <svg class="w-4 h-4 transition-transform duration-200 group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              {ra?.stepByStep || 'Step-by-Step Details'}
            </summary>
            <div id="assumptions-steps-content" class="mt-4 p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 text-sm text-surface-700 dark:text-surface-300 space-y-3 font-mono leading-relaxed"></div>
          </details>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.querySelectorAll('#assumptions-checker').forEach((calcEl) => {
    const tbody = calcEl.querySelector('#assumptions-data-rows');
    const addBtn = calcEl.querySelector('#assumptions-add-row-btn');
    const calcBtn = calcEl.querySelector('#assumptions-calculate-btn');
    const clearBtn = calcEl.querySelector('#assumptions-clear-btn');
    const errorEl = calcEl.querySelector('#assumptions-error-msg');
    const resultsSection = calcEl.querySelector('#assumptions-results-section');
    const invalidData = calcEl.getAttribute('data-invalid-data') || 'Please enter at least 5 valid data points';
    let rowCounter = 0;

    function createRow(xVal = '', yVal = '') {
      rowCounter++;
      const tr = document.createElement('tr');
      tr.className = 'border-b border-surface-200 dark:border-surface-600 transition-colors duration-150 hover:bg-primary-50/30 dark:hover:bg-primary-900/10';
      tr.innerHTML = `
        <td class="px-3 py-2 text-xs text-surface-400 dark:text-surface-500 font-mono">${rowCounter}</td>
        <td class="px-3 py-2"><input type="number" step="any" class="data-x w-full px-3 py-1.5 text-sm rounded-lg border border-surface-200 dark:border-surface-600 bg-white dark:bg-surface-700 dark:text-surface-200 dark:placeholder-surface-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-300 dark:focus:border-primary-600 transition-all duration-150 hover:border-primary-300 dark:hover:border-primary-700" placeholder="X" value="${xVal}" /></td>
        <td class="px-3 py-2"><input type="number" step="any" class="data-y w-full px-3 py-1.5 text-sm rounded-lg border border-surface-200 dark:border-surface-600 bg-white dark:bg-surface-700 dark:text-surface-200 dark:placeholder-surface-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-300 dark:focus:border-primary-600 transition-all duration-150 hover:border-primary-300 dark:hover:border-primary-700" placeholder="Y" value="${yVal}" /></td>
        <td class="px-3 py-2"><button type="button" class="remove-row text-surface-300 dark:text-surface-600 hover:text-red-500 dark:hover:text-red-400 transition-colors duration-150" aria-label="Remove row"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button></td>
      `;
      tr.querySelector('.remove-row')?.addEventListener('click', () => {
        tr.style.opacity = '0';
        tr.style.transform = 'translateX(10px)';
        tr.style.transition = 'all 0.15s ease';
        setTimeout(() => { tr.remove(); renumberRows(); }, 150);
      });
      tbody?.appendChild(tr);
    }

    function renumberRows() {
      const rows = tbody?.querySelectorAll('tr') ?? [];
      rows.forEach((row, i) => { row.querySelector('td')!.textContent = String(i + 1); });
      rowCounter = rows.length;
    }

    function getData() {
      const rows = tbody?.querySelectorAll('tr') ?? [];
      const points = [];
      for (const row of rows) {
        const x = parseFloat((row.querySelector('.data-x') as HTMLInputElement)?.value ?? '');
        const y = parseFloat((row.querySelector('.data-y') as HTMLInputElement)?.value ?? '');
        if (!isNaN(x) && !isNaN(y)) points.push({ x, y });
      }
      return points;
    }

    function getAlpha() {
      const checked = calcEl.querySelector('input[name="assumptions-alpha"]:checked') as HTMLInputElement | null;
      return checked ? parseFloat(checked.value) : 0.05;
    }

    function showError(msg) {
      if (errorEl) { errorEl.textContent = msg; errorEl.classList.remove('hidden'); }
      if (resultsSection) resultsSection.classList.add('hidden');
    }

    function hideError() { if (errorEl) errorEl.classList.add('hidden'); }

    function chiSqPValue(chiSq, df) {
      if (df <= 0 || chiSq <= 0) return 1;
      const x = chiSq / 2;
      const a = df / 2;
      return 1 - gammaIncLower(a, x);
    }

    function gammaIncLower(a, x) {
      if (x <= 0) return 0;
      if (x < a + 1) {
        let sum = 1, term = 1;
        for (let n = 1; n < 200; n++) {
          term *= x / (a + n);
          sum += term;
          if (Math.abs(term) < 1e-10 * Math.abs(sum)) break;
        }
        return Math.exp(-x + a * Math.log(x) - lnGamma(a)) * sum / a;
      }
      let b = x + 1 - a, c = 1e30, d = 1 / b, h = d;
      for (let i = 1; i <= 200; i++) {
        const an = -i * (i - a);
        b += 2;
        d = an * d + b;
        if (Math.abs(d) < 1e-30) d = 1e-30;
        c = b + an / c;
        if (Math.abs(c) < 1e-30) c = 1e-30;
        d = 1 / d;
        const del = d * c;
        h *= del;
        if (Math.abs(del - 1) < 1e-10) break;
      }
      return Math.exp(-x + a * Math.log(x) - lnGamma(a)) * h;
    }

    function lnGamma(z) {
      const c = [76.18009172947146, -86.50532032941677, 24.01409824083091, -1.231739572450155, 0.1208650973866179e-2, -0.5395239384953e-5];
      let x = z, y = z, tmp = 1.000000000190015;
      for (let j = 0; j < 6; j++) tmp += c[j] / ++y;
      return Math.log(2.5066282746310005 * tmp / x) + (--x) * Math.log(x) - x;
    }

    function fPValue(f, df1, df2) {
      if (f <= 0 || df1 <= 0 || df2 <= 0) return 1;
      const x = df1 * f / (df1 * f + df2);
      return 1 - betaInc(df1 / 2, df2 / 2, x);
    }

    function betaInc(a, b, x) {
      if (x <= 0) return 0;
      if (x >= 1) return 1;
      const lnB = lnGamma(a) + lnGamma(b) - lnGamma(a + b);
      const prefix = Math.exp(Math.log(x) * a + Math.log(1 - x) * b - lnB);
      if (x < (a + 1) / (a + b + 2)) return prefix * cfBeta(a, b, x) / a;
      return 1 - prefix * cfBeta(b, a, 1 - x) / b;
    }

    function cfBeta(a, b, x) {
      let am = 1, bm = 1, ax = 1, bz = 1 - (a + b) * x / (a + 1);
      for (let m = 1; m <= 200; m++) {
        const d = m * (b - m) * x / ((a + 2 * m - 1) * (a + 2 * m));
        const d2 = -(a + m) * (a + b + m) * x / ((a + 2 * m) * (a + 2 * m + 1));
        const ap = am + ax * d, bp = bm + bz * d;
        const app = ap + ax * d2, bpp = bp + bz * d2;
        const aold = ax;
        ax = app * bpp;
        am = ap / bpp;
        bm = bp / bpp;
        bz = 1;
        if (Math.abs(ax - aold) < 1e-10 * Math.abs(ax)) break;
      }
      return ax;
    }

    function durbinWatsonPValue(dw, n, k) {
      const dl = n < 15 ? 0.6 : n < 30 ? 1.1 : n < 60 ? 1.4 : 1.5;
      const du = n < 15 ? 1.4 : n < 30 ? 1.6 : n < 60 ? 1.7 : 1.8;
      return { dl, du };
    }

    function checkAssumptions(points) {
      const n = points.length;
      if (n < 5) { showError(invalidData); return null; }

      const alpha = getAlpha();
      const sumX = points.reduce((s, p) => s + p.x, 0);
      const sumY = points.reduce((s, p) => s + p.y, 0);
      const meanX = sumX / n;
      const meanY = sumY / n;

      let ssXX = 0, ssXY = 0, ssYY = 0;
      for (const p of points) {
        const dx = p.x - meanX, dy = p.y - meanY;
        ssXX += dx * dx;
        ssXY += dx * dy;
        ssYY += dy * dy;
      }

      if (ssXX === 0 || ssYY === 0) { showError(invalidData); return null; }

      const slope = ssXY / ssXX;
      const intercept = meanY - slope * meanX;

      const predicted = points.map(p => slope * p.x + intercept);
      const residuals = points.map((p, i) => p.y - predicted[i]);
      const ssRes = residuals.reduce((s, r) => s + r * r, 0);
      const rSquared = 1 - ssRes / ssYY;

      const linearity = checkLinearity(points, predicted, residuals, meanY, ssYY, n, alpha);
      const independence = checkIndependence(residuals, n, alpha);
      const homoscedasticity = checkHomoscedasticity(predicted, residuals, n, alpha);
      const normality = checkNormality(residuals, n, alpha);

      const passed = [linearity, independence, homoscedasticity, normality].filter(a => a.passed).length;

      const steps = [
        `<strong>Regression:</strong> y = ${slope.toFixed(4)}x + ${intercept.toFixed(4)}, R² = ${rSquared.toFixed(4)}`,
        `<strong>Residuals:</strong> [${residuals.map(r => r.toFixed(3)).join(', ')}]`,
        '',
        `<strong>1. Linearity (RESET test)</strong>`,
        `&nbsp;&nbsp;F-statistic = ${linearity.statistic.toFixed(4)}, p-value = ${linearity.pValue.toFixed(4)}`,
        `&nbsp;&nbsp;${linearity.passed ? 'PASSED' : 'FAILED'} at α = ${alpha}`,
        '',
        `<strong>2. Independence (Durbin-Watson)</strong>`,
        `&nbsp;&nbsp;DW = ${independence.statistic.toFixed(4)}`,
        `&nbsp;&nbsp;${independence.passed ? 'PASSED' : 'INCONCLUSIVE / FAILED'} (dL = ${independence.dl.toFixed(2)}, dU = ${independence.du.toFixed(2)})`,
        '',
        `<strong>3. Homoscedasticity (Breusch-Pagan)</strong>`,
        `&nbsp;&nbsp;LM = ${homoscedasticity.statistic.toFixed(4)}, p-value = ${homoscedasticity.pValue.toFixed(4)}`,
        `&nbsp;&nbsp;${homoscedasticity.passed ? 'PASSED' : 'FAILED'} at α = ${alpha}`,
        '',
        `<strong>4. Normality (Jarque-Bera)</strong>`,
        `&nbsp;&nbsp;JB = ${normality.statistic.toFixed(4)}, p-value = ${normality.pValue.toFixed(4)}`,
        `&nbsp;&nbsp;Skewness = ${normality.skewness.toFixed(4)}, Kurtosis = ${normality.kurtosis.toFixed(4)}`,
        `&nbsp;&nbsp;${normality.passed ? 'PASSED' : 'FAILED'} at α = ${alpha}`,
      ];

      return { n, rSquared, slope, intercept, linearity, independence, homoscedasticity, normality, passed, total: 4, steps };
    }

    function checkLinearity(points, predicted, residuals, meanY, ssYY, n, alpha) {
      const yHat2 = predicted.map(p => p * p);
      const yHat3 = predicted.map(p => p * p * p);
      const meanYH2 = yHat2.reduce((s, v) => s + v, 0) / n;
      const meanYH3 = yHat3.reduce((s, v) => s + v, 0) / n;
      const meanRes = 0;

      let ssYH2Y = 0, ssYH3Y = 0, ssYH22 = 0, ssYH33 = 0, ssYH2H3 = 0;
      for (let i = 0; i < n; i++) {
        const d2 = yHat2[i] - meanYH2, d3 = yHat3[i] - meanYH3;
        const dr = residuals[i];
        ssYH2Y += d2 * dr;
        ssYH3Y += d3 * dr;
        ssYH22 += d2 * d2;
        ssYH33 += d3 * d3;
        ssYH2H3 += d2 * d3;
      }

      const ssExtra = (ssYH2Y * ssYH3Y > 0)
        ? (ssYH2Y * ssYH2Y / ssYH22 + ssYH3Y * ssYH3Y / ssYH33)
        : ssYH2Y * ssYH2Y / Math.max(ssYH22, 1e-10);

      const ssRes = residuals.reduce((s, r) => s + r * r, 0);
      const ssResRestricted = ssRes;
      const ssResFull = Math.max(0, ssRes - ssExtra);

      const df1 = 2;
      const df2 = Math.max(1, n - 4);
      const msExtra = ssExtra / df1;
      const msRes = ssResFull / df2;
      const fStat = msRes > 0 ? msExtra / msRes : 0;
      const pValue = fPValue(fStat, df1, df2);

      return {
        name: 'linearity',
        passed: pValue > alpha,
        statistic: fStat,
        pValue,
        detail: `RESET F = ${fStat.toFixed(4)}, p = ${pValue.toFixed(4)}. ${pValue > alpha ? 'No evidence of non-linearity.' : 'Evidence of non-linearity detected.'}`,
        fix: pValue <= alpha ? 'Try polynomial terms (x²), transformations (log, sqrt), or non-linear models.' : ''
      };
    }

    function checkIndependence(residuals, n, alpha) {
      let dwNum = 0, dwDen = 0;
      for (let i = 1; i < n; i++) dwNum += (residuals[i] - residuals[i - 1]) ** 2;
      for (let i = 0; i < n; i++) dwDen += residuals[i] ** 2;
      const dw = dwDen > 0 ? dwNum / dwDen : 2;

      const { dl, du } = durbinWatsonPValue(dw, n, 1);
      const passed = dw >= dl && dw <= 4 - dl;
      const inconclusive = (dw > dl && dw < du) || (dw > 4 - du && dw < 4 - dl);

      return {
        name: 'independence',
        passed: dw >= du && dw <= 4 - du,
        statistic: dw,
        pValue: 0,
        dl, du,
        detail: `Durbin-Watson d = ${dw.toFixed(4)}. dL = ${dl.toFixed(2)}, dU = ${du.toFixed(2)}. ${dw >= du && dw <= 4 - du ? 'No autocorrelation detected.' : dw <= dl || dw >= 4 - dl ? 'Autocorrelation detected.' : 'Inconclusive range.'}`,
        fix: (dw < du || dw > 4 - du) ? 'For time-series: add lag terms, use ARIMA. For spatial: use mixed-effects models.' : ''
      };
    }

    function checkHomoscedasticity(predicted, residuals, n, alpha) {
      const residSq = residuals.map(r => r * r);
      const meanResidSq = residSq.reduce((s, v) => s + v, 0) / n;
      const meanPred = predicted.reduce((s, v) => s + v, 0) / n;

      let ssXX = 0, ssXY = 0;
      for (let i = 0; i < n; i++) {
        const dx = predicted[i] - meanPred;
        const dy = residSq[i] - meanResidSq;
        ssXX += dx * dx;
        ssXY += dx * dy;
      }

      const bpSlope = ssXX > 0 ? ssXY / ssXX : 0;
      const ssExplained = ssXX > 0 ? bpSlope * ssXY : 0;
      const lm = n * ssExplained / (residSq.reduce((s, v) => s + (v - meanResidSq) ** 2, 0) + 1e-30);
      const pValue = chiSqPValue(lm, 1);

      const corr = Math.abs(residuals.reduce((s, r, i) => s + Math.abs(r) * predicted[i], 0)) /
        (Math.sqrt(residuals.reduce((s, r) => s + r * r, 0)) * Math.sqrt(predicted.reduce((s, p) => s + p * p, 0)) + 1e-30);

      return {
        name: 'homoscedasticity',
        passed: pValue > alpha,
        statistic: lm,
        pValue,
        detail: `Breusch-Pagan LM = ${lm.toFixed(4)}, p = ${pValue.toFixed(4)}. ${pValue > alpha ? 'Constant variance assumed.' : 'Heteroscedasticity detected — variance of residuals changes with predicted values.'}`,
        fix: pValue <= alpha ? 'Transform y (log, sqrt), use weighted least squares, or robust standard errors.' : ''
      };
    }

    function checkNormality(residuals, n, alpha) {
      const mean = residuals.reduce((s, r) => s + r, 0) / n;
      const variance = residuals.reduce((s, r) => s + (r - mean) ** 2, 0) / n;
      const sd = Math.sqrt(variance);
      const m3 = residuals.reduce((s, r) => s + ((r - mean) / sd) ** 3, 0) / n;
      const m4 = residuals.reduce((s, r) => s + ((r - mean) / sd) ** 4, 0) / n;

      const skewness = m3;
      const kurtosis = m4;
      const jb = (n / 6) * (skewness ** 2 + ((kurtosis - 3) ** 2) / 4);
      const pValue = chiSqPValue(jb, 2);

      return {
        name: 'normality',
        passed: pValue > alpha,
        statistic: jb,
        pValue,
        skewness,
        kurtosis,
        detail: `Jarque-Bera JB = ${jb.toFixed(4)}, p = ${pValue.toFixed(4)}. Skewness = ${skewness.toFixed(4)} (ideal: 0), Kurtosis = ${kurtosis.toFixed(4)} (ideal: 3). ${pValue > alpha ? 'Residuals appear approximately normal.' : 'Residuals deviate significantly from normality.'}`,
        fix: pValue <= alpha ? 'Transform y, remove outliers, or rely on CLT for large samples (n > 30).' : ''
      };
    }

    function setCardState(id, passed, inconclusive) {
      const card = calcEl.querySelector(`#assumption-card-${id}`);
      const icon = calcEl.querySelector(`#${id}-icon`);
      const verdict = calcEl.querySelector(`#${id}-verdict`);
      if (!card || !icon || !verdict) return;

      if (passed) {
        card.className = 'p-5 rounded-xl border-2 border-green-300 dark:border-green-700 bg-green-50/50 dark:bg-green-900/20 transition-all duration-200';
        icon.className = 'flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center bg-green-100 dark:bg-green-900/50';
        icon.innerHTML = '<svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>';
        verdict.className = 'text-sm font-semibold text-green-700 dark:text-green-400';
        verdict.textContent = 'PASSED';
      } else if (inconclusive) {
        card.className = 'p-5 rounded-xl border-2 border-yellow-300 dark:border-yellow-700 bg-yellow-50/50 dark:bg-yellow-900/20 transition-all duration-200';
        icon.className = 'flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center bg-yellow-100 dark:bg-yellow-900/50';
        icon.innerHTML = '<svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
        verdict.className = 'text-sm font-semibold text-yellow-700 dark:text-yellow-400';
        verdict.textContent = 'INCONCLUSIVE';
      } else {
        card.className = 'p-5 rounded-xl border-2 border-red-300 dark:border-red-700 bg-red-50/50 dark:bg-red-900/20 transition-all duration-200';
        icon.className = 'flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center bg-red-100 dark:bg-red-900/50';
        icon.innerHTML = '<svg class="w-5 h-5 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>';
        verdict.className = 'text-sm font-semibold text-red-700 dark:text-red-400';
        verdict.textContent = 'FAILED';
      }
    }

    addBtn?.addEventListener('click', () => createRow());
    for (let i = 0; i < 5; i++) createRow();

    calcBtn?.addEventListener('click', () => {
      hideError();
      const points = getData();
      const result = checkAssumptions(points);
      if (!result) return;

      const l = result.linearity, ind = result.independence, h = result.homoscedasticity, nr = result.normality;

      setCardState('linearity', l.passed, false);
      setCardState('independence', ind.passed, (ind.statistic > ind.dl && ind.statistic < ind.du) || (ind.statistic > 4 - ind.du && ind.statistic < 4 - ind.dl));
      setCardState('homoscedasticity', h.passed, false);
      setCardState('normality', nr.passed, false);

      calcEl.querySelector('#linearity-detail')!.textContent = l.detail;
      calcEl.querySelector('#linearity-fix')!.textContent = l.fix;
      calcEl.querySelector('#independence-detail')!.textContent = ind.detail;
      calcEl.querySelector('#independence-fix')!.textContent = ind.fix;
      calcEl.querySelector('#homoscedasticity-detail')!.textContent = h.detail;
      calcEl.querySelector('#homoscedasticity-fix')!.textContent = h.fix;
      calcEl.querySelector('#normality-detail')!.textContent = nr.detail;
      calcEl.querySelector('#normality-fix')!.textContent = nr.fix;

      const summaryEl = calcEl.querySelector('#assumptions-result-summary')!;
      const detailEl = calcEl.querySelector('#assumptions-result-summary-detail')!;
      if (result.passed === 4) {
        summaryEl.textContent = `All ${result.total} assumptions passed ✓`;
        summaryEl.className = 'text-base font-bold text-green-700 dark:text-green-400';
        detailEl.textContent = 'Your data appears to meet all regression assumptions.';
      } else {
        summaryEl.textContent = `${result.passed} of ${result.total} assumptions passed`;
        summaryEl.className = 'text-base font-bold text-red-700 dark:text-red-400';
        detailEl.textContent = `${result.total - result.passed} assumption(s) may be violated. See details below for remediation.`;
      }

      calcEl.querySelector('#assumptions-result-n')!.textContent = String(result.n);
      calcEl.querySelector('#assumptions-result-rsquared')!.textContent = result.rSquared.toFixed(4);
      calcEl.querySelector('#assumptions-result-equation')!.textContent = `y = ${result.slope.toFixed(4)}x + ${result.intercept.toFixed(4)}`;

      const stepsEl = calcEl.querySelector('#assumptions-steps-content');
      if (stepsEl) stepsEl.innerHTML = result.steps.map((s) => `<p>${s}</p>`).join('');

      if (resultsSection) {
        resultsSection.classList.remove('hidden');
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });

    clearBtn?.addEventListener('click', () => {
      hideError();
      if (resultsSection) resultsSection.classList.add('hidden');
      if (tbody) tbody.innerHTML = '';
      rowCounter = 0;
      for (let i = 0; i < 5; i++) createRow();
    });
  });
</script>
