---
import { LOCALES, DEFAULT_LOCALE } from 'theme/i18n/types';
import { getLocalizedUrl } from 'theme/i18n/utils';

interface Props {
  locale: string;
  translations: any;
}

const { locale, translations } = Astro.props;

const LOCALE_NAMES: Record<string, string> = {
  en: 'English',
  hi: 'हिन्दी',
  es: 'Español',
  ru: 'Русский',
  fr: 'Français',
  de: 'Deutsch',
  it: 'Italiano',
  pt: 'Português',
  bn: 'বাংলা',
  ja: '日本語',
  ko: '한국어',
  ms: 'Bahasa Melayu',
  pl: 'Polski',
  id: 'Bahasa Indonesia',
  ar: 'العربية',
  bg: 'Български',
  tr: 'Türkçe',
  sv: 'Svenska',
};

const currentName = LOCALE_NAMES[locale] ?? locale;
const otherLocales = LOCALES.filter((l) => l !== locale);
---

<div class="relative" data-language-switcher>
  <button
    id="lang-toggle"
    type="button"
    class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-surface-300 rounded-lg border border-surface-700 bg-surface-800 transition-colors duration-200 hover:bg-surface-700 hover:border-surface-600"
    aria-expanded="false"
    aria-haspopup="listbox"
    aria-label={translations.common?.selectLanguage ?? "Select language"}
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
    </svg>
    {currentName}
    <svg class="w-3.5 h-3.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <ul
    id="lang-list"
    class="absolute top-full mt-2 left-0 z-50 w-48 max-h-64 overflow-y-auto rounded-xl border border-surface-700 bg-surface-800 py-1 shadow-xl opacity-0 pointer-events-none transition-all duration-200"
    role="listbox"
    aria-label={translations.common?.availableLanguages ?? "Available languages"}
  >
    <li role="option" aria-selected="true">
      <a
        href={getLocalizedUrl('/', locale)}
        class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-primary-400 bg-primary-900/20"
      >
        <span class="w-5 text-center">{locale.toUpperCase()}</span>
        {currentName}
      </a>
    </li>
    {otherLocales.map((l) => (
      <li role="option" aria-selected="false">
        <a
          href={getLocalizedUrl('/', l)}
          class="flex items-center gap-2 px-3 py-2 text-sm text-surface-400 transition-colors duration-150 hover:bg-surface-700 hover:text-white"
        >
          <span class="w-5 text-center">{l.toUpperCase()}</span>
          {LOCALE_NAMES[l] ?? l}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  const container = document.querySelector('[data-language-switcher]');
  const toggle = container?.querySelector('#lang-toggle') as HTMLButtonElement | null;
  const list = container?.querySelector('#lang-list');

  function openList() {
    list?.classList.remove('opacity-0', 'pointer-events-none');
    list?.classList.add('opacity-100', 'pointer-events-auto');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeList() {
    list?.classList.add('opacity-0', 'pointer-events-none');
    list?.classList.remove('opacity-100', 'pointer-events-auto');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeList() : openList();
  });

  document.addEventListener('click', (e) => {
    if (container && !container.contains(e.target as Node)) {
      closeList();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeList();
  });
</script>
