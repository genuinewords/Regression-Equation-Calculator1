---
import type { MergedTranslations } from 'theme/i18n/types';

interface Props {
  translations: MergedTranslations;
}

const { translations } = Astro.props;
const pc = (translations as any).pearson;
---

<section class="py-8" id="pearson-calculator" data-x-label={pc?.xLabel || 'X Values'} data-y-label={pc?.yLabel || 'Y Values'} data-invalid-data={pc?.invalidData || 'Please enter at least 2 valid data points'} data-p-value={pc?.pValue || 'P-value'} data-std-dev-x={pc?.stdDevX || 'Std. Dev. of X (sₓ)'} data-std-dev-y={pc?.stdDevY || 'Std. Dev. of Y (sᵧ)'} data-regression-slope={pc?.regressionSlope || 'Regression Slope (from r)'} data-causation-warning={pc?.causationWarning || 'Remember: Correlation does not imply causation. A significant correlation only indicates association, not that one variable causes the other.'} data-alt-formula={pc?.alternativeFormula || 'Alternative Formula (using raw sums)'} data-significant={pc?.significant || 'Significant at α = 0.05'} data-not-significant={pc?.notSignificant || 'Not significant at α = 0.05'}>
  <div class="mx-auto max-w-3xl">
    <div class="rounded-2xl shadow-lg dark:shadow-surface-950/40 shadow-primary-900/5 border border-surface-200/80 dark:border-surface-700/60 overflow-hidden bg-white dark:bg-surface-800/80 backdrop-blur-sm transition-colors duration-300">
      <div class="bg-gradient-to-r from-primary-600 to-accent-600 px-6 py-5">
        <h2 class="text-xl font-bold text-white">{pc?.title || 'Pearson Correlation Calculator'}</h2>
        <p class="text-primary-100 text-sm mt-1">{pc?.description || 'Enter your data points to calculate the Pearson correlation coefficient'}</p>
      </div>

      <div class="p-6 bg-surface-50/50 dark:bg-surface-800/50">
        <div class="mb-4">
          <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-300 mb-3">{pc?.enterData || 'Enter your data points'}</h3>
          <div class="overflow-x-auto rounded-lg border border-surface-200 dark:border-surface-600">
            <table class="w-full" id="pearson-data-table">
              <thead>
                <tr class="bg-surface-100 dark:bg-surface-700/50 border-b border-surface-200 dark:border-surface-600">
                  <th class="px-3 py-2 text-left text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider w-12">#</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider">{pc?.xLabel || 'X Values'}</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider">{pc?.yLabel || 'Y Values'}</th>
                  <th class="px-3 py-2 w-10"></th>
                </tr>
              </thead>
              <tbody id="pearson-data-rows">
              </tbody>
            </table>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 mb-6">
          <button
            id="pearson-add-row-btn"
            type="button"
            class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/25 border border-primary-200 dark:border-primary-800/50 rounded-lg transition-all duration-200 hover:bg-primary-100 dark:hover:bg-primary-900/40 hover:border-primary-300 dark:hover:border-primary-700 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary-500/30"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            {pc?.addRow || 'Add Row'}
          </button>
          <button
            id="pearson-calculate-btn"
            type="button"
            class="inline-flex items-center gap-1.5 px-6 py-2 text-sm font-semibold text-white bg-gradient-to-r from-primary-600 to-accent-600 rounded-lg shadow-md shadow-primary-600/20 dark:shadow-primary-900/40 transition-all duration-200 hover:shadow-lg hover:shadow-primary-600/30 dark:hover:shadow-primary-900/50 hover:brightness-110 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary-500/30"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
            {pc?.calculate || 'Calculate'}
          </button>
          <button
            id="pearson-clear-btn"
            type="button"
            class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-surface-600 dark:text-surface-400 bg-surface-100 dark:bg-surface-700 border border-surface-200 dark:border-surface-600 rounded-lg transition-all duration-200 hover:bg-surface-200 dark:hover:bg-surface-600 hover:border-surface-300 dark:hover:border-surface-500 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-surface-400/30"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            {pc?.clear || 'Clear'}
          </button>
        </div>

        <div id="pearson-error-msg" class="hidden mb-4 p-3 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/50 text-red-700 dark:text-red-400 text-sm"></div>

        <div id="pearson-results-section" class="hidden animate-[fadeIn_0.3s_ease-out]">
          <div class="mb-6">
            <h3 class="text-lg font-bold text-surface-800 dark:text-surface-200 mb-4">{pc?.result || 'Results'}</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="p-4 rounded-xl bg-gradient-to-br from-primary-50 dark:from-primary-900/30 to-accent-50 dark:to-accent-900/30 border border-primary-100 dark:border-primary-800/40 hover:shadow-md dark:hover:shadow-primary-900/20 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-primary-500 dark:text-primary-400 uppercase tracking-wider mb-1">{pc?.correlation || 'Pearson Correlation (r)'}</p>
                <p id="pearson-result-r" class="text-lg font-bold text-primary-800 dark:text-primary-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-gradient-to-br from-accent-50 dark:from-accent-900/30 to-primary-50 dark:to-primary-900/30 border border-accent-100 dark:border-accent-800/40 hover:shadow-md dark:hover:shadow-accent-900/20 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-accent-500 dark:text-accent-400 uppercase tracking-wider mb-1">{pc?.rSquared || 'R-Squared (r²)'}</p>
                <p id="pearson-result-rsquared" class="text-lg font-bold text-accent-800 dark:text-accent-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-gradient-to-br from-amber-50 dark:from-amber-900/30 to-primary-50 dark:to-primary-900/30 border border-amber-100 dark:border-amber-800/40 hover:shadow-md dark:hover:shadow-amber-900/20 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-amber-600 dark:text-amber-400 uppercase tracking-wider mb-1">{pc?.pValue || 'P-value'}</p>
                <p id="pearson-result-pvalue" class="text-lg font-bold text-amber-800 dark:text-amber-200 font-mono"></p>
                <p id="pearson-result-pvalue-note" class="text-xs font-medium mt-1"></p>
              </div>
              <div class="p-4 rounded-xl bg-gradient-to-br from-emerald-50 dark:from-emerald-900/30 to-primary-50 dark:to-primary-900/30 border border-emerald-100 dark:border-emerald-800/40 hover:shadow-md dark:hover:shadow-emerald-900/20 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-emerald-600 dark:text-emerald-400 uppercase tracking-wider mb-1">{pc?.regressionSlope || 'Regression Slope (from r)'}</p>
                <p id="pearson-result-slope" class="text-lg font-bold text-emerald-800 dark:text-emerald-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{pc?.strength || 'Strength'}</p>
                <p id="pearson-result-strength" class="text-lg font-bold text-surface-800 dark:text-surface-200"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{pc?.direction || 'Direction'}</p>
                <p id="pearson-result-direction" class="text-lg font-bold text-surface-800 dark:text-surface-200"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{pc?.stdDevX || 'Std. Dev. of X (sₓ)'}</p>
                <p id="pearson-result-sdx" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{pc?.stdDevY || 'Std. Dev. of Y (sᵧ)'}</p>
                <p id="pearson-result-sdy" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{pc?.meanX || 'Mean of X'}</p>
                <p id="pearson-result-meanx" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{pc?.meanY || 'Mean of Y'}</p>
                <p id="pearson-result-meany" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{pc?.covariance || 'Covariance'}</p>
                <p id="pearson-result-covariance" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{pc?.nPoints || 'Data Points (n)'}</p>
                <p id="pearson-result-n" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
            </div>
          </div>

          <div id="pearson-causation-warning" class="mb-6 p-4 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800/50 flex items-start gap-3">
            <svg class="w-5 h-5 text-amber-500 dark:text-amber-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856C18.51 19 20 17.57 20 15.75V8.25c0-1.67-1.49-3-3.362-3H7.362C5.49 5.25 4 6.68 4 8.5v7.25c0 1.67 1.49 3 3.362 3z" /></svg>
            <p class="text-sm text-amber-700 dark:text-amber-300">{pc?.causationWarning || 'Remember: Correlation does not imply causation. A significant correlation only indicates association, not that one variable causes the other.'}</p>
          </div>

          <details class="group">
            <summary class="flex items-center gap-2 cursor-pointer text-sm font-semibold text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors select-none">
              <svg class="w-4 h-4 transition-transform duration-200 group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              {pc?.stepByStep || 'Step-by-Step Solution'}
            </summary>
            <div id="pearson-steps-content" class="mt-4 p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 text-sm text-surface-700 dark:text-surface-300 space-y-3 font-mono leading-relaxed"></div>
          </details>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.querySelectorAll('#pearson-calculator').forEach((calcEl) => {
    const tbody = calcEl.querySelector('#pearson-data-rows');
    const addBtn = calcEl.querySelector('#pearson-add-row-btn');
    const calcBtn = calcEl.querySelector('#pearson-calculate-btn');
    const clearBtn = calcEl.querySelector('#pearson-clear-btn');
    const errorEl = calcEl.querySelector('#pearson-error-msg');
    const resultsSection = calcEl.querySelector('#pearson-results-section');
    const xLabel = calcEl.getAttribute('data-x-label') || 'X';
    const yLabel = calcEl.getAttribute('data-y-label') || 'Y';
    const invalidData = calcEl.getAttribute('data-invalid-data') || 'Please enter at least 2 valid data points';
    const pValueLabel = calcEl.getAttribute('data-p-value') || 'P-value';
    const stdDevXLabel = calcEl.getAttribute('data-std-dev-x') || 'Std. Dev. of X (sₓ)';
    const stdDevYLabel = calcEl.getAttribute('data-std-dev-y') || 'Std. Dev. of Y (sᵧ)';
    const slopeLabel = calcEl.getAttribute('data-regression-slope') || 'Regression Slope (from r)';
    const causationWarning = calcEl.getAttribute('data-causation-warning') || 'Remember: Correlation does not imply causation. A significant correlation only indicates association, not that one variable causes the other.';
    const altFormulaLabel = calcEl.getAttribute('data-alt-formula') || 'Alternative Formula (using raw sums)';
    const significantLabel = calcEl.getAttribute('data-significant') || 'Significant at α = 0.05';
    const notSignificantLabel = calcEl.getAttribute('data-not-significant') || 'Not significant at α = 0.05';
    let rowCounter = 0;

    function logGamma(z) {
      const c = [76.18009172947146, -86.50532032941677, 24.01409824083091, -1.231739572450155, 0.1208650973866179e-2, -0.5395239384953e-5];
      let x = z;
      let y = z;
      let tmp = 1.000000000190015;
      for (let j = 0; j < 6; j++) tmp += c[j] / ++y;
      return 0.5 * Math.log(2 * Math.PI) + (x + 4.5) * Math.log(x + 4.5) - (x + 4.5) + Math.log(tmp) - Math.log(x);
    }

    function gammaLn(z) { return logGamma(z); }

    function betaLn(a, b) { return gammaLn(a) + gammaLn(b) - gammaLn(a + b); }

    function betacf(a, b, x) {
      const maxIter = 200;
      const eps = 3e-7;
      const qab = a + b;
      const qap = a + 1;
      const qam = a - 1;
      let c = 1;
      let d = 1 - qab * x / qap;
      if (Math.abs(d) < 1e-30) d = 1e-30;
      d = 1 / d;
      let h = d;
      for (let m = 1; m <= maxIter; m++) {
        const m2 = 2 * m;
        let aa = m * (b - m) * x / ((qam + m2) * (a + m2));
        d = 1 + aa * d;
        if (Math.abs(d) < 1e-30) d = 1e-30;
        c = 1 + aa / c;
        if (Math.abs(c) < 1e-30) c = 1e-30;
        d = 1 / d;
        h *= d * c;
        aa = -(a + m) * (qab + m) * x / ((a + m2) * (qap + m2));
        d = 1 + aa * d;
        if (Math.abs(d) < 1e-30) d = 1e-30;
        c = 1 + aa / c;
        if (Math.abs(c) < 1e-30) c = 1e-30;
        d = 1 / d;
        const del = d * c;
        h *= del;
        if (Math.abs(del - 1) < eps) break;
      }
      return h;
    }

    function regularizedBeta(a, b, x) {
      if (x < 0 || x > 1) return 0;
      if (x === 0 || x === 1) return x;
      const lnBeta = betaLn(a, b);
      const front = Math.exp(Math.log(x) * a + Math.log(1 - x) * b - lnBeta);
      if (x < (a + 1) / (a + b + 2)) {
        return front * betacf(a, b, x) / a;
      }
      return 1 - front * betacf(b, a, 1 - x) / b;
    }

    function tDistPValue(tStat, df) {
      const x = df / (df + tStat * tStat);
      const p = regularizedBeta(df / 2, 0.5, x);
      return Math.min(1, Math.max(0, p));
    }

    function createRow(xVal = '', yVal = '') {
      rowCounter++;
      const tr = document.createElement('tr');
      tr.className = 'border-b border-surface-200 dark:border-surface-600 transition-colors duration-150 hover:bg-primary-50/30 dark:hover:bg-primary-900/10';
      tr.innerHTML = `
        <td class="px-3 py-2 text-xs text-surface-400 dark:text-surface-500 font-mono">${rowCounter}</td>
        <td class="px-3 py-2"><input type="number" step="any" class="data-x w-full px-3 py-1.5 text-sm rounded-lg border border-surface-200 dark:border-surface-600 bg-white dark:bg-surface-700 dark:text-surface-200 dark:placeholder-surface-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-300 dark:focus:border-primary-600 transition-all duration-150 hover:border-primary-300 dark:hover:border-primary-700" placeholder="${xLabel}" value="${xVal}" /></td>
        <td class="px-3 py-2"><input type="number" step="any" class="data-y w-full px-3 py-1.5 text-sm rounded-lg border border-surface-200 dark:border-surface-600 bg-white dark:bg-surface-700 dark:text-surface-200 dark:placeholder-surface-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-300 dark:focus:border-primary-600 transition-all duration-150 hover:border-primary-300 dark:hover:border-primary-700" placeholder="${yLabel}" value="${yVal}" /></td>
        <td class="px-3 py-2"><button type="button" class="remove-row text-surface-300 dark:text-surface-600 hover:text-red-500 dark:hover:text-red-400 transition-colors duration-150" aria-label="Remove row"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button></td>
      `;
      tr.querySelector('.remove-row')?.addEventListener('click', () => {
        tr.style.opacity = '0';
        tr.style.transform = 'translateX(10px)';
        tr.style.transition = 'all 0.15s ease';
        setTimeout(() => { tr.remove(); renumberRows(); }, 150);
      });
      tbody?.appendChild(tr);
    }

    function renumberRows() {
      const rows = tbody?.querySelectorAll('tr') ?? [];
      rows.forEach((row, i) => {
        row.querySelector('td')!.textContent = String(i + 1);
      });
      rowCounter = rows.length;
    }

    function getData() {
      const rows = tbody?.querySelectorAll('tr') ?? [];
      const points = [];
      for (const row of rows) {
        const xInput = row.querySelector('.data-x');
        const yInput = row.querySelector('.data-y');
        const x = parseFloat(xInput?.value ?? '');
        const y = parseFloat(yInput?.value ?? '');
        if (!isNaN(x) && !isNaN(y)) {
          points.push({ x, y });
        }
      }
      return points;
    }

    function showError(msg) {
      if (errorEl) {
        errorEl.textContent = msg;
        errorEl.classList.remove('hidden');
      }
      if (resultsSection) resultsSection.classList.add('hidden');
    }

    function hideError() {
      if (errorEl) errorEl.classList.add('hidden');
    }

    function getStrength(absR) {
      if (absR >= 0.9) return 'Very Strong';
      if (absR >= 0.7) return 'Strong';
      if (absR >= 0.5) return 'Moderate';
      if (absR >= 0.3) return 'Weak';
      return 'Very Weak / None';
    }

    function getDirection(r) {
      if (r > 0) return 'Positive';
      if (r < 0) return 'Negative';
      return 'None';
    }

    function computePearson(points) {
      const n = points.length;
      if (n < 2) {
        showError(invalidData);
        return null;
      }

      const sumX = points.reduce((s, p) => s + p.x, 0);
      const sumY = points.reduce((s, p) => s + p.y, 0);
      const meanX = sumX / n;
      const meanY = sumY / n;

      let ssXX = 0, ssYY = 0, ssXY = 0;
      let sumX2 = 0, sumY2 = 0, sumXY = 0;
      for (const p of points) {
        const dx = p.x - meanX;
        const dy = p.y - meanY;
        ssXX += dx * dx;
        ssYY += dy * dy;
        ssXY += dx * dy;
        sumX2 += p.x * p.x;
        sumY2 += p.y * p.y;
        sumXY += p.x * p.y;
      }

      if (ssXX === 0 || ssYY === 0) {
        showError(invalidData);
        return null;
      }

      const r = ssXY / Math.sqrt(ssXX * ssYY);
      const rSquared = r * r;
      const covariance = ssXY / (n - 1);
      const sX = Math.sqrt(ssXX / (n - 1));
      const sY = Math.sqrt(ssYY / (n - 1));
      const slope = r * sY / sX;

      let pValue = null;
      let tStat = null;
      if (n >= 3 && rSquared < 1) {
        tStat = r * Math.sqrt((n - 2) / (1 - rSquared));
        pValue = 2 * tDistPValue(Math.abs(tStat), n - 2);
      }

      const steps = [
        `<strong>Step 1:</strong> Calculate means → x̄ = ${sumX.toFixed(4)} / ${n} = ${meanX.toFixed(4)}, ȳ = ${sumY.toFixed(4)} / ${n} = ${meanY.toFixed(4)}`,
        `<strong>Step 2:</strong> Compute deviations from the mean`,
        ...points.map((p, i) => `&nbsp;&nbsp;Point ${i + 1}: (x${i + 1} - x̄) = ${(p.x - meanX).toFixed(4)}, (y${i + 1} - ȳ) = ${(p.y - meanY).toFixed(4)}, product = ${((p.x - meanX) * (p.y - meanY)).toFixed(4)}`),
        `<strong>Step 3:</strong> Sums of squares → Σ(x-x̄)² = ${ssXX.toFixed(4)}, Σ(y-ȳ)² = ${ssYY.toFixed(4)}, Σ(x-x̄)(y-ȳ) = ${ssXY.toFixed(4)}`,
        `<strong>Step 4:</strong> Pearson r = Σ(x-x̄)(y-ȳ) / √[Σ(x-x̄)² · Σ(y-ȳ)²]`,
        `&nbsp;&nbsp;r = ${ssXY.toFixed(4)} / √[${ssXX.toFixed(4)} × ${ssYY.toFixed(4)}]`,
        `&nbsp;&nbsp;r = ${ssXY.toFixed(4)} / √${(ssXX * ssYY).toFixed(4)}`,
        `&nbsp;&nbsp;r = ${ssXY.toFixed(4)} / ${Math.sqrt(ssXX * ssYY).toFixed(4)} = <strong>${r.toFixed(4)}</strong>`,
        `<strong>Step 5:</strong> R² = r² = ${r.toFixed(4)}² = ${rSquared.toFixed(4)}`,
        `<strong>Step 6:</strong> Standard deviations → sₓ = √[Σ(x-x̄)²/(n-1)] = √[${ssXX.toFixed(4)}/${n - 1}] = ${sX.toFixed(4)},  sᵧ = √[Σ(y-ȳ)²/(n-1)] = √[${ssYY.toFixed(4)}/${n - 1}] = ${sY.toFixed(4)}`,
        `<strong>Step 7:</strong> Regression slope from r → m = r × sᵧ / sₓ = ${r.toFixed(4)} × ${sY.toFixed(4)} / ${sX.toFixed(4)} = <strong>${slope.toFixed(4)}</strong>`,
        `<strong>Step 8:</strong> Covariance = Σ(x-x̄)(y-ȳ) / (n-1) = ${ssXY.toFixed(4)} / ${n - 1} = ${covariance.toFixed(4)}`,
      ];

      if (pValue !== null && tStat !== null) {
        const pStr = pValue < 0.0001 ? pValue.toExponential(4) : pValue.toFixed(4);
        steps.push(`<strong>Step 9:</strong> P-value (two-tailed) → t = r√[(n-2)/(1-r²)] = ${r.toFixed(4)}√[${n - 2}/${(1 - rSquared).toFixed(4)}] = ${tStat.toFixed(4)}`);
        steps.push(`&nbsp;&nbsp;p = 2 × P(T > |${tStat.toFixed(4)}|) with df = ${n - 2} → p = <strong>${pStr}</strong> ${pValue < 0.05 ? '✓ ' + significantLabel : '✗ ' + notSignificantLabel}`);
      }

      steps.push(
        `<strong>Step ${pValue !== null ? '10' : '9'}:</strong> Interpretation → |r| = ${Math.abs(r).toFixed(4)} → ${getStrength(Math.abs(r))} ${getDirection(r).toLowerCase()} correlation`,
        ``,
        `<em>${altFormulaLabel}:</em>`,
        `&nbsp;&nbsp;Σx = ${sumX.toFixed(4)}, Σy = ${sumY.toFixed(4)}, Σx² = ${sumX2.toFixed(4)}, Σy² = ${sumY2.toFixed(4)}, Σxy = ${sumXY.toFixed(4)}`,
        `&nbsp;&nbsp;r = (nΣxy - ΣxΣy) / √[(nΣx² - (Σx)²)(nΣy² - (Σy)²)]`,
        `&nbsp;&nbsp;r = (${n}×${sumXY.toFixed(4)} - ${sumX.toFixed(4)}×${sumY.toFixed(4)}) / √[(${n}×${sumX2.toFixed(4)} - ${sumX.toFixed(4)}²)×(${n}×${sumY2.toFixed(4)} - ${sumY.toFixed(4)}²)]`,
        `&nbsp;&nbsp;r = ${(n * sumXY - sumX * sumY).toFixed(4)} / √[${(n * sumX2 - sumX * sumX).toFixed(4)} × ${(n * sumY2 - sumY * sumY).toFixed(4)}] = <strong>${r.toFixed(4)}</strong>`,
      );

      return { r, rSquared, strength: getStrength(Math.abs(r)), direction: getDirection(r), meanX, meanY, covariance, n, sX, sY, slope, pValue, steps };
    }

    addBtn?.addEventListener('click', () => createRow());
    for (let i = 0; i < 5; i++) createRow();

    calcBtn?.addEventListener('click', () => {
      hideError();
      const points = getData();
      const result = computePearson(points);
      if (!result) return;

      calcEl.querySelector('#pearson-result-r')!.textContent = result.r.toFixed(4);
      calcEl.querySelector('#pearson-result-rsquared')!.textContent = result.rSquared.toFixed(4);
      calcEl.querySelector('#pearson-result-strength')!.textContent = result.strength;
      calcEl.querySelector('#pearson-result-direction')!.textContent = result.direction;
      calcEl.querySelector('#pearson-result-meanx')!.textContent = result.meanX.toFixed(4);
      calcEl.querySelector('#pearson-result-meany')!.textContent = result.meanY.toFixed(4);
      calcEl.querySelector('#pearson-result-covariance')!.textContent = result.covariance.toFixed(4);
      calcEl.querySelector('#pearson-result-n')!.textContent = String(result.n);
      calcEl.querySelector('#pearson-result-sdx')!.textContent = result.sX.toFixed(4);
      calcEl.querySelector('#pearson-result-sdy')!.textContent = result.sY.toFixed(4);
      calcEl.querySelector('#pearson-result-slope')!.textContent = result.slope.toFixed(4);

      const pValueEl = calcEl.querySelector('#pearson-result-pvalue');
      const pNoteEl = calcEl.querySelector('#pearson-result-pvalue-note');
      if (result.pValue !== null) {
        const pStr = result.pValue < 0.0001 ? result.pValue.toExponential(4) : result.pValue.toFixed(4);
        pValueEl.textContent = pStr;
        if (pNoteEl) {
          pNoteEl.textContent = result.pValue < 0.05 ? significantLabel : notSignificantLabel;
          pNoteEl.className = `text-xs font-medium mt-1 ${result.pValue < 0.05 ? 'text-green-600 dark:text-green-400' : 'text-surface-500 dark:text-surface-400'}`;
        }
      } else {
        pValueEl.textContent = 'N/A';
        if (pNoteEl) { pNoteEl.textContent = ''; pNoteEl.className = 'text-xs font-medium mt-1'; }
      }

      const stepsEl = calcEl.querySelector('#pearson-steps-content');
      if (stepsEl) {
        stepsEl.innerHTML = result.steps.map((s) => `<p>${s}</p>`).join('');
      }

      if (resultsSection) {
        resultsSection.classList.remove('hidden');
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });

    clearBtn?.addEventListener('click', () => {
      hideError();
      if (resultsSection) resultsSection.classList.add('hidden');
      if (tbody) tbody.innerHTML = '';
      rowCounter = 0;
      for (let i = 0; i < 5; i++) createRow();
    });
  });
</script>
