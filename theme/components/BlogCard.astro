---
interface Props {
  title: string;
  description: string;
  image: string;
  href: string;
  readMoreLabel: string;
}

const { title, description, image, href, readMoreLabel } = Astro.props;
---

<article class="group rounded-2xl overflow-hidden border border-surface-200/80 dark:border-surface-700 bg-white dark:bg-surface-800 shadow-sm dark:shadow-surface-950/50 hover:shadow-lg dark:hover:shadow-surface-950/50 transition-shadow duration-300">
  <a href={href} class="block overflow-hidden">
    <div class="aspect-video overflow-hidden">
      <img
        src={image}
        alt={title}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    </div>
  </a>

  <div class="p-5">
    <h3 class="text-lg font-bold text-surface-900 dark:text-surface-50 mb-2 group-hover:text-primary-700 dark:hover:text-primary-400 transition-colors duration-200">
      <a href={href}>{title}</a>
    </h3>
    <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed mb-4 line-clamp-3">{description}</p>
    <a
      href={href}
      class="inline-flex items-center gap-1 text-sm font-semibold text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors duration-200"
    >
      {readMoreLabel}
      <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    </a>
  </div>
</article>