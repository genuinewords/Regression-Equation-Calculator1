---
import { getLocalizedUrl } from 'theme/i18n/utils';
import navConfig from 'src/data/nav.json';
import socialConfig from 'src/data/social.json';
import siteConfig from 'src/data/site-config.json';
import Logo from 'theme/components/Logo.astro';
import LanguageSwitcher from 'theme/components/LanguageSwitcher.astro';
import type { MergedTranslations } from 'theme/i18n/types';

interface Props {
  locale: string;
  translations: MergedTranslations;
}

const { locale, translations } = Astro.props;
const year = new Date().getFullYear();
const hasSocial = !!(socialConfig.facebook || socialConfig.twitter || socialConfig.linkedin || socialConfig.pinterest);

const toolsNav = navConfig.footerNav.filter(item => ['home', 'pearsonCorrelation', 'grubbsTest', 'assumptionsChecker', 'blog'].includes(item.label));
const companyNav = navConfig.footerNav.filter(item => ['aboutUs', 'contactUs', 'terms', 'privacy', 'sitemap'].includes(item.label));
---

<footer class="bg-surface-900 dark:bg-surface-950 text-surface-300 mt-auto border-t border-surface-800 dark:border-surface-800">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 2xl:px-0 2xl:max-w-[1440px] py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-5">
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={getLocalizedUrl('/', locale)} class="flex items-center gap-2.5 mb-4">
          <Logo class="h-8 w-8 rounded-lg" width="32" height="32" />
          <span class="text-lg font-bold text-white">{translations.siteTitle}</span>
        </a>
        <p class="text-sm leading-relaxed text-surface-400 max-w-xs">
          {translations.footer?.description ?? siteConfig.description}
        </p>
      </div>

      <div>
        <h2 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Tools & Pages</h2>
        <ul class="space-y-2.5">
          {toolsNav.map((item) => {
            const label = translations.nav?.[item.label as keyof typeof translations.nav] ?? item.label;
            const href = getLocalizedUrl(item.href, locale);
            return (
              <li>
                <a href={href} class="text-sm text-surface-400 transition-colors duration-200 hover:text-accent-300">
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Company</h2>
        <ul class="space-y-2.5">
          {companyNav.map((item) => {
            const label = translations.nav?.[item.label as keyof typeof translations.nav] ?? item.label;
            const href = getLocalizedUrl(item.href, locale);
            return (
              <li>
                <a href={href} class="text-sm text-surface-400 transition-colors duration-200 hover:text-accent-300">
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <div>
        {hasSocial && (
          <>
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Connect</h3>
            <div class="flex items-center gap-3">
              {socialConfig.facebook && (
                <a href={socialConfig.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex items-center justify-center w-10 h-10 rounded-xl bg-surface-800 text-surface-400 transition-all duration-200 hover:bg-primary-600 hover:text-white">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              )}
              {socialConfig.twitter && (
                <a href={socialConfig.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter / X" class="flex items-center justify-center w-10 h-10 rounded-xl bg-surface-800 text-surface-400 transition-all duration-200 hover:bg-primary-600 hover:text-white">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              )}
              {socialConfig.linkedin && (
                <a href={socialConfig.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="flex items-center justify-center w-10 h-10 rounded-xl bg-surface-800 text-surface-400 transition-all duration-200 hover:bg-primary-600 hover:text-white">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              )}
              {socialConfig.pinterest && (
                <a href={socialConfig.pinterest} target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="flex items-center justify-center w-10 h-10 rounded-xl bg-surface-800 text-surface-400 transition-all duration-200 hover:bg-primary-600 hover:text-white">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.762 24 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001 12.017.001z"/></svg>
                </a>
              )}
            </div>
            <div class="mt-3 space-y-1.5">
              <a href="mailto:Contact@regressionequationcalculator.com" class="flex items-center gap-2 text-sm text-surface-400 transition-colors duration-200 hover:text-accent-300">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                Contact@regressionequationcalculator.com
              </a>
              <a href="tel:+14155550199" class="flex items-center gap-2 text-sm text-surface-400 transition-colors duration-200 hover:text-accent-300">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                +1 (415) 555-0199
              </a>
            </div>
          </>
        )}
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Language</h3>
        <LanguageSwitcher locale={locale} />
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-surface-800">
      <p class="text-sm text-surface-500 text-center">
        &copy; {year} {siteConfig.legalName}. {translations.footer?.copyright ?? 'All rights reserved.'}
      </p>
    </div>
  </div>
</footer>
