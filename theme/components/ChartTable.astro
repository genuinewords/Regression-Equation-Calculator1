---
import type { MergedTranslations } from 'theme/i18n/types';

interface Props {
  translations: MergedTranslations;
}

const { translations } = Astro.props;
const home = translations.home;

const stats = [
  { statistic: home.tableSlope, symbol: home.tableSlopeSym, interpretation: home.tableSlopeInt },
  { statistic: home.tableIntercept, symbol: home.tableInterceptSym, interpretation: home.tableInterceptInt },
  { statistic: home.tableRSquared, symbol: home.tableRSquaredSym, interpretation: home.tableRSquaredInt },
  { statistic: home.tableCorrelation, symbol: home.tableCorrelationSym, interpretation: home.tableCorrelationInt },
  { statistic: home.tableStdError, symbol: home.tableStdErrorSym, interpretation: home.tableStdErrorInt },
  { statistic: home.tablePValue, symbol: home.tablePValueSym, interpretation: home.tablePValueInt },
];
---

<section>
  <div class="mx-auto max-w-3xl">
    <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-50 text-center mb-2">{home.tableTitle}</h2>
    <p class="text-sm text-surface-500 dark:text-surface-400 text-center mb-6">{home.tableDescription}</p>

    <div class="rounded-2xl overflow-hidden border border-surface-200 dark:border-surface-700/60 shadow-sm dark:shadow-surface-950/30 bg-white dark:bg-surface-800/70 backdrop-blur-sm">
      <table class="w-full">
        <thead>
          <tr class="bg-gradient-to-r from-primary-600 to-accent-600">
            <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">{home.tableStat}</th>
            <th class="px-5 py-3.5 text-center text-xs font-semibold text-white uppercase tracking-wider">{home.tableSymbol}</th>
            <th class="px-5 py-3.5 text-left text-xs font-semibold text-white uppercase tracking-wider">{home.tableInterpretation}</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-surface-100 dark:divide-surface-700/50">
          {stats.map((s, i) => (
            <tr class={`transition-all duration-150 ${i % 2 === 0 ? 'bg-white dark:bg-surface-800/30' : 'bg-surface-50/60 dark:bg-surface-700/20'} hover:bg-primary-50/50 dark:hover:bg-primary-900/15 hover:pl-1`}>
              <td class="px-5 py-3.5 text-sm font-medium text-surface-800 dark:text-surface-200 transition-colors duration-150">{s.statistic}</td>
              <td class="px-5 py-3.5 text-sm font-mono font-bold text-primary-600 dark:text-primary-400 text-center transition-colors duration-150">{s.symbol}</td>
              <td class="px-5 py-3.5 text-sm text-surface-600 dark:text-surface-400 transition-colors duration-150">{s.interpretation}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
