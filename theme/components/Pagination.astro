---
interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
  prevLabel: string;
  nextLabel: string;
}

const { currentPage, totalPages, basePath, prevLabel, nextLabel } = Astro.props;

function getPageUrl(page: number): string {
  if (page === 1) return basePath;
  return `${basePath}${page}/`;
}

const pages: number[] = [];
const delta = 2;
const start = Math.max(2, currentPage - delta);
const end = Math.min(totalPages - 1, currentPage + delta);

if (totalPages > 1) {
  pages.push(1);
  if (start > 2) pages.push(-1);
  for (let i = start; i <= end; i++) pages.push(i);
  if (end < totalPages - 1) pages.push(-1);
  if (totalPages > 1) pages.push(totalPages);
}
---

{totalPages > 1 && (
  <nav class="flex items-center justify-center gap-1.5 py-8" aria-label="Pagination">
    <a
      href={currentPage > 1 ? getPageUrl(currentPage - 1) : undefined}
      class={`inline-flex items-center gap-1.5 px-3.5 py-2 text-sm font-medium rounded-lg border transition-all duration-200 ${
        currentPage <= 1
          ? 'border-surface-200 dark:border-surface-700 text-surface-300 dark:text-surface-600 bg-surface-50 dark:bg-surface-800 cursor-not-allowed pointer-events-none'
          : 'border-surface-200 dark:border-surface-700 text-surface-600 dark:text-surface-400 bg-white dark:bg-surface-800 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-600 dark:hover:text-primary-400 hover:bg-primary-50 dark:hover:bg-primary-900/20'
      }`}
      aria-label={prevLabel}
      aria-disabled={currentPage <= 1}
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      {prevLabel}
    </a>

    <div class="flex items-center gap-1">
      {pages.map((page) =>
        page === -1 ? (
          <span class="px-2 py-2 text-surface-400 dark:text-surface-500 text-sm select-none">&hellip;</span>
        ) : (
          <a
            href={getPageUrl(page)}
            class={`inline-flex items-center justify-center w-9 h-9 text-sm font-medium rounded-lg transition-all duration-200 ${
              page === currentPage
                ? 'bg-gradient-to-r from-primary-600 to-accent-600 text-white shadow-md shadow-primary-600/20'
                : 'text-surface-600 dark:text-surface-400 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-600 dark:hover:text-primary-400 hover:bg-primary-50 dark:hover:bg-primary-900/20'
            }`}
            aria-label={`Page ${page}`}
            aria-current={page === currentPage ? 'page' : undefined}
          >
            {page}
          </a>
        )
      )}
    </div>

    <a
      href={currentPage < totalPages ? getPageUrl(currentPage + 1) : undefined}
      class={`inline-flex items-center gap-1.5 px-3.5 py-2 text-sm font-medium rounded-lg border transition-all duration-200 ${
        currentPage >= totalPages
          ? 'border-surface-200 dark:border-surface-700 text-surface-300 dark:text-surface-600 bg-surface-50 dark:bg-surface-800 cursor-not-allowed pointer-events-none'
          : 'border-surface-200 dark:border-surface-700 text-surface-600 dark:text-surface-400 bg-white dark:bg-surface-800 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-600 dark:hover:text-primary-400 hover:bg-primary-50 dark:hover:bg-primary-900/20'
      }`}
      aria-label={nextLabel}
      aria-disabled={currentPage >= totalPages}
    >
      {nextLabel}
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    </a>
  </nav>
)}