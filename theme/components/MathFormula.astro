---
export interface Props {
  formula: string;
  description?: string;
}

const { formula, description } = Astro.props;
---

<div class="my-10 relative rounded-2xl overflow-hidden group">
  <!-- Animated glow background -->
  <div class="absolute inset-0 bg-gradient-to-r from-primary-600 via-accent-500 to-primary-600 opacity-10 group-hover:opacity-20 transition-opacity duration-500 blur-xl"></div>
  
  <!-- Outer glowing border -->
  <div class="absolute inset-px rounded-2xl bg-gradient-to-r from-primary-400/40 to-accent-400/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0"></div>
  
  <div class="relative z-10 bg-white/80 dark:bg-surface-900/80 backdrop-blur-xl border border-surface-200/50 dark:border-surface-700/50 rounded-2xl p-8 sm:p-10 text-center shadow-lg hover:shadow-xl transition-all duration-300">
    <div class="text-2xl sm:text-3xl md:text-4xl font-extrabold font-mono tracking-wider bg-gradient-to-br from-primary-600 to-accent-600 dark:from-primary-400 dark:to-accent-400 bg-clip-text text-transparent transform group-hover:scale-105 transition-transform duration-500" set:html={formula}></div>
    
    {description && (
      <div class="mt-4 text-sm font-medium text-surface-500 dark:text-surface-400 uppercase tracking-widest opacity-80 group-hover:opacity-100 transition-opacity">
        {description}
      </div>
    )}
  </div>
</div>
