---
interface Props {
  class?: string;
  width?: string | number;
  height?: string | number;
  alt?: string;
}

const { class: className = "h-8 w-8 rounded-lg", width = 32, height = 32, alt = "Logo" } = Astro.props;
---
<img
  src="/logo.svg"
  alt={alt}
  class={className}
  width={width}
  height={height}
/>
