---
import type { MergedTranslations } from 'theme/i18n/types';

interface Props {
  translations: MergedTranslations;
}

const { translations } = Astro.props;
const qc = (translations as any).quadCalc;
---

<section class="py-8" id="quadratic-regression-calculator" data-x-label={qc?.xLabel || 'X'} data-y-label={qc?.yLabel || 'Y'} data-invalid-data={qc?.invalidData || 'Please enter at least 3 valid data points'}>
  <div class="mx-auto max-w-3xl">
    <div class="rounded-2xl shadow-lg dark:shadow-surface-950/40 shadow-primary-900/5 border border-surface-200/80 dark:border-surface-700/60 overflow-hidden bg-white dark:bg-surface-800/80 backdrop-blur-sm transition-colors duration-300">
      <div class="bg-gradient-to-r from-primary-600 to-accent-600 px-6 py-5">
        <h2 class="text-xl font-bold text-white">{qc?.title || 'Quadratic Regression Calculator'}</h2>
        <p class="text-primary-100 text-sm mt-1">{qc?.description || 'Enter your data points to calculate the quadratic regression equation (y = ax² + bx + c)'}</p>
      </div>

      <div class="p-6 bg-surface-50/50 dark:bg-surface-800/50">
        <div class="mb-4">
          <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-300 mb-3">{qc?.enterData || 'Enter your data points'}</h3>
          <div class="overflow-x-auto rounded-lg border border-surface-200 dark:border-surface-600">
            <table class="w-full" id="qr-data-table">
              <thead>
                <tr class="bg-surface-100 dark:bg-surface-700/50 border-b border-surface-200 dark:border-surface-600">
                  <th class="px-3 py-2 text-left text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider w-12">#</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider">{qc?.xLabel || 'X'}</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider">{qc?.yLabel || 'Y'}</th>
                  <th class="px-3 py-2 w-10"></th>
                </tr>
              </thead>
              <tbody id="qr-data-rows">
              </tbody>
            </table>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 mb-6">
          <button
            id="qr-add-row-btn"
            type="button"
            class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/25 border border-primary-200 dark:border-primary-800/50 rounded-lg transition-all duration-200 hover:bg-primary-100 dark:hover:bg-primary-900/40 hover:border-primary-300 dark:hover:border-primary-700 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary-500/30"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            {qc?.addRow || 'Add Row'}
          </button>
          <button
            id="qr-calculate-btn"
            type="button"
            class="inline-flex items-center gap-1.5 px-6 py-2 text-sm font-semibold text-white bg-gradient-to-r from-primary-600 to-accent-600 rounded-lg shadow-md shadow-primary-600/20 dark:shadow-primary-900/40 transition-all duration-200 hover:shadow-lg hover:shadow-primary-600/30 dark:hover:shadow-primary-900/50 hover:brightness-110 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary-500/30"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
            {qc?.calculate || 'Calculate'}
          </button>
          <button
            id="qr-clear-btn"
            type="button"
            class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-surface-600 dark:text-surface-400 bg-surface-100 dark:bg-surface-700 border border-surface-200 dark:border-surface-600 rounded-lg transition-all duration-200 hover:bg-surface-200 dark:hover:bg-surface-600 hover:border-surface-300 dark:hover:border-surface-500 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-surface-400/30"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            {qc?.clear || 'Clear'}
          </button>
        </div>

        <div id="qr-error-msg" class="hidden mb-4 p-3 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/50 text-red-700 dark:text-red-400 text-sm"></div>

        <div id="qr-results-section" class="hidden animate-[fadeIn_0.3s_ease-out]">
          <div class="mb-6">
            <h3 class="text-lg font-bold text-surface-800 dark:text-surface-200 mb-4">{qc?.result || 'Results'}</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="p-4 rounded-xl bg-gradient-to-br from-primary-50 dark:from-primary-900/30 to-accent-50 dark:to-accent-900/30 border border-primary-100 dark:border-primary-800/40 hover:shadow-md dark:hover:shadow-primary-900/20 transition-all duration-200 hover:scale-[1.01] sm:col-span-2">
                <p class="text-xs font-semibold text-primary-500 dark:text-primary-400 uppercase tracking-wider mb-1">{qc?.equation || 'Equation'}</p>
                <p id="qr-result-equation" class="text-lg font-bold text-primary-800 dark:text-primary-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{qc?.coeffA || 'Coefficient a'}</p>
                <p id="qr-result-a" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{qc?.coeffB || 'Coefficient b'}</p>
                <p id="qr-result-b" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{qc?.coeffC || 'Coefficient c'}</p>
                <p id="qr-result-c" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01]">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{qc?.rSquared || 'R-Squared'}</p>
                <p id="qr-result-rsquared" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 hover:shadow-md dark:hover:shadow-surface-950/30 transition-all duration-200 hover:scale-[1.01] sm:col-span-2">
                <p class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider mb-1">{qc?.correlation || 'Correlation r'}</p>
                <p id="qr-result-correlation" class="text-lg font-bold text-surface-800 dark:text-surface-200 font-mono"></p>
              </div>
            </div>
          </div>

          <details class="group">
            <summary class="flex items-center gap-2 cursor-pointer text-sm font-semibold text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors select-none">
              <svg class="w-4 h-4 transition-transform duration-200 group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              {qc?.stepByStep || 'Step-by-Step Solution'}
            </summary>
            <div id="qr-steps-content" class="mt-4 p-4 rounded-xl bg-white dark:bg-surface-700/50 border border-surface-200 dark:border-surface-600/50 text-sm text-surface-700 dark:text-surface-300 space-y-3 font-mono leading-relaxed"></div>
          </details>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.querySelectorAll('#quadratic-regression-calculator').forEach((calcEl) => {
    const tbody = calcEl.querySelector('#qr-data-rows');
    const addBtn = calcEl.querySelector('#qr-add-row-btn');
    const calcBtn = calcEl.querySelector('#qr-calculate-btn');
    const clearBtn = calcEl.querySelector('#qr-clear-btn');
    const errorEl = calcEl.querySelector('#qr-error-msg');
    const resultsSection = calcEl.querySelector('#qr-results-section');
    const xLabel = calcEl.getAttribute('data-x-label') || 'X';
    const yLabel = calcEl.getAttribute('data-y-label') || 'Y';
    const invalidData = calcEl.getAttribute('data-invalid-data') || 'Please enter at least 3 valid data points';
    let rowCounter = 0;

    function createRow(xVal = '', yVal = '') {
      rowCounter++;
      const tr = document.createElement('tr');
      tr.className = 'border-b border-surface-200 dark:border-surface-600 transition-colors duration-150 hover:bg-primary-50/30 dark:hover:bg-primary-900/10';
      tr.innerHTML = `
        <td class="px-3 py-2 text-xs text-surface-400 dark:text-surface-500 font-mono">${rowCounter}</td>
        <td class="px-3 py-2"><input type="number" step="any" class="data-x w-full px-3 py-1.5 text-sm rounded-lg border border-surface-200 dark:border-surface-600 bg-white dark:bg-surface-700 dark:text-surface-200 dark:placeholder-surface-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-300 dark:focus:border-primary-600 transition-all duration-150 hover:border-primary-300 dark:hover:border-primary-700" placeholder="${xLabel}" value="${xVal}" /></td>
        <td class="px-3 py-2"><input type="number" step="any" class="data-y w-full px-3 py-1.5 text-sm rounded-lg border border-surface-200 dark:border-surface-600 bg-white dark:bg-surface-700 dark:text-surface-200 dark:placeholder-surface-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-300 dark:focus:border-primary-600 transition-all duration-150 hover:border-primary-300 dark:hover:border-primary-700" placeholder="${yLabel}" value="${yVal}" /></td>
        <td class="px-3 py-2"><button type="button" class="remove-row text-surface-300 dark:text-surface-600 hover:text-red-500 dark:hover:text-red-400 transition-colors duration-150" aria-label="Remove row"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button></td>
      `;
      tr.querySelector('.remove-row')?.addEventListener('click', () => {
        tr.style.opacity = '0';
        tr.style.transform = 'translateX(10px)';
        tr.style.transition = 'all 0.15s ease';
        setTimeout(() => { tr.remove(); renumberRows(); }, 150);
      });
      tbody?.appendChild(tr);
    }

    function renumberRows() {
      const rows = tbody?.querySelectorAll('tr') ?? [];
      rows.forEach((row, i) => {
        row.querySelector('td')!.textContent = String(i + 1);
      });
      rowCounter = rows.length;
    }

    function getData() {
      const rows = tbody?.querySelectorAll('tr') ?? [];
      const points = [];
      for (const row of rows) {
        const xInput = row.querySelector('.data-x');
        const yInput = row.querySelector('.data-y');
        const x = parseFloat(xInput?.value ?? '');
        const y = parseFloat(yInput?.value ?? '');
        if (!isNaN(x) && !isNaN(y)) {
          points.push({ x, y });
        }
      }
      return points;
    }

    function showError(msg) {
      if (errorEl) {
        errorEl.textContent = msg;
        errorEl.classList.remove('hidden');
      }
      if (resultsSection) resultsSection.classList.add('hidden');
    }

    function hideError() {
      if (errorEl) errorEl.classList.add('hidden');
    }

    function gaussianElimination(A, b) {
      const n = A.length;
      const aug = A.map((row, i) => [...row, b[i]]);

      for (let col = 0; col < n; col++) {
        let maxRow = col;
        let maxVal = Math.abs(aug[col][col]);
        for (let row = col + 1; row < n; row++) {
          if (Math.abs(aug[row][col]) > maxVal) {
            maxVal = Math.abs(aug[row][col]);
            maxRow = row;
          }
        }
        [aug[col], aug[maxRow]] = [aug[maxRow], aug[col]];

        const pivot = aug[col][col];
        if (Math.abs(pivot) < 1e-12) return null;

        for (let j = col; j <= n; j++) {
          aug[col][j] /= pivot;
        }

        for (let row = 0; row < n; row++) {
          if (row === col) continue;
          const factor = aug[row][col];
          for (let j = col; j <= n; j++) {
            aug[row][j] -= factor * aug[col][j];
          }
        }
      }

      return aug.map(row => row[n]);
    }

    function computeQuadraticRegression(points) {
      const n = points.length;
      if (n < 3) {
        showError(invalidData);
        return null;
      }

      let sumX = 0, sumX2 = 0, sumX3 = 0, sumX4 = 0;
      let sumY = 0, sumXY = 0, sumX2Y = 0;
      for (const p of points) {
        const x = p.x;
        const y = p.y;
        const x2 = x * x;
        const x3 = x2 * x;
        const x4 = x3 * x;
        sumX += x;
        sumX2 += x2;
        sumX3 += x3;
        sumX4 += x4;
        sumY += y;
        sumXY += x * y;
        sumX2Y += x2 * y;
      }

      const A = [
        [n, sumX, sumX2],
        [sumX, sumX2, sumX3],
        [sumX2, sumX3, sumX4]
      ];
      const b = [sumY, sumXY, sumX2Y];

      const solution = gaussianElimination(A, b);
      if (!solution) {
        showError(invalidData);
        return null;
      }

      const c = solution[0];
      const bCoeff = solution[1];
      const aCoeff = solution[2];

      const meanY = sumY / n;
      let ssRes = 0;
      let ssTot = 0;
      for (const p of points) {
        const predicted = aCoeff * p.x * p.x + bCoeff * p.x + c;
        ssRes += (p.y - predicted) ** 2;
        ssTot += (p.y - meanY) ** 2;
      }
      const rSquared = ssTot === 0 ? 1 : 1 - ssRes / ssTot;
      const r = ssTot === 0 ? 1 : Math.sqrt(Math.max(0, rSquared));

      const fmt = (v) => v.toFixed(4);
      let eqStr = 'y = ';
      if (aCoeff !== 0) {
        eqStr += `${fmt(aCoeff)}x²`;
      }
      if (bCoeff !== 0) {
        if (bCoeff > 0 && aCoeff !== 0) eqStr += ' + ';
        else if (bCoeff < 0) eqStr += ' - ';
        eqStr += `${fmt(Math.abs(bCoeff))}x`;
      }
      if (c !== 0 || (aCoeff === 0 && bCoeff === 0)) {
        if (c > 0 && (aCoeff !== 0 || bCoeff !== 0)) eqStr += ' + ';
        else if (c < 0) eqStr += ' - ';
        eqStr += `${fmt(Math.abs(c))}`;
      }

      const steps = [
        `<strong>Step 1:</strong> Compute sums from ${n} data points`,
        `&nbsp;&nbsp;Σx = ${fmt(sumX)}, Σx² = ${fmt(sumX2)}, Σx³ = ${fmt(sumX3)}, Σx⁴ = ${fmt(sumX4)}`,
        `&nbsp;&nbsp;Σy = ${fmt(sumY)}, Σxy = ${fmt(sumXY)}, Σx²y = ${fmt(sumX2Y)}`,
        ``,
        `<strong>Step 2:</strong> Set up normal equations (matrix form)`,
        `&nbsp;&nbsp;⎡ n    Σx   Σx²  ⎤ ⎡ c ⎤   ⎡ Σy   ⎤`,
        `&nbsp;&nbsp;⎢ Σx   Σx²  Σx³  ⎥ ⎢ b ⎥ = ⎢ Σxy  ⎥`,
        `&nbsp;&nbsp;⎣ Σx²  Σx³  Σx⁴  ⎦ ⎣ a ⎦   ⎣ Σx²y ⎦`,
        ``,
        `&nbsp;&nbsp;⎡ ${n}    ${fmt(sumX)}   ${fmt(sumX2)}  ⎤ ⎡ c ⎤   ⎡ ${fmt(sumY)}   ⎤`,
        `&nbsp;&nbsp;⎢ ${fmt(sumX)}   ${fmt(sumX2)}  ${fmt(sumX3)}  ⎥ ⎢ b ⎥ = ⎢ ${fmt(sumXY)}  ⎥`,
        `&nbsp;&nbsp;⎣ ${fmt(sumX2)}  ${fmt(sumX3)}  ${fmt(sumX4)}  ⎦ ⎣ a ⎦   ⎣ ${fmt(sumX2Y)} ⎦`,
        ``,
        `<strong>Step 3:</strong> Solve using Gaussian elimination with partial pivoting`,
        `&nbsp;&nbsp;a = ${fmt(aCoeff)}`,
        `&nbsp;&nbsp;b = ${fmt(bCoeff)}`,
        `&nbsp;&nbsp;c = ${fmt(c)}`,
        ``,
        `<strong>Step 4:</strong> Compute predicted values and residuals`,
        ...points.map((p, i) => {
          const pred = aCoeff * p.x * p.x + bCoeff * p.x + c;
          return `&nbsp;&nbsp;Point ${i + 1}: ŷ${i + 1} = ${fmt(aCoeff)}(${p.x})² + ${fmt(bCoeff)}(${p.x}) + ${fmt(c)} = ${fmt(pred)}, residual = ${fmt(p.y - pred)}`;
        }),
        ``,
        `<strong>Step 5:</strong> Compute R²`,
        `&nbsp;&nbsp;SSres = Σ(yᵢ - ŷᵢ)² = ${fmt(ssRes)}`,
        `&nbsp;&nbsp;SStot = Σ(yᵢ - ȳ)² = ${fmt(ssTot)}`,
        `&nbsp;&nbsp;R² = 1 - SSres/SStot = 1 - ${fmt(ssRes)}/${fmt(ssTot)} = <strong>${fmt(rSquared)}</strong>`,
        ``,
        `<strong>Step 6:</strong> Correlation r = √R² = <strong>${fmt(r)}</strong>`,
      ];

      return { a: aCoeff, b: bCoeff, c, rSquared, r, equation: eqStr, steps };
    }

    addBtn?.addEventListener('click', () => createRow());
    for (let i = 0; i < 5; i++) createRow();

    calcBtn?.addEventListener('click', () => {
      hideError();
      const points = getData();
      const result = computeQuadraticRegression(points);
      if (!result) return;

      calcEl.querySelector('#qr-result-equation')!.textContent = result.equation;
      calcEl.querySelector('#qr-result-a')!.textContent = result.a.toFixed(4);
      calcEl.querySelector('#qr-result-b')!.textContent = result.b.toFixed(4);
      calcEl.querySelector('#qr-result-c')!.textContent = result.c.toFixed(4);
      calcEl.querySelector('#qr-result-rsquared')!.textContent = result.rSquared.toFixed(4);
      calcEl.querySelector('#qr-result-correlation')!.textContent = result.r.toFixed(4);

      const stepsEl = calcEl.querySelector('#qr-steps-content');
      if (stepsEl) {
        stepsEl.innerHTML = result.steps.map((s) => `<p>${s}</p>`).join('');
      }

      if (resultsSection) {
        resultsSection.classList.remove('hidden');
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });

    clearBtn?.addEventListener('click', () => {
      hideError();
      if (resultsSection) resultsSection.classList.add('hidden');
      if (tbody) tbody.innerHTML = '';
      rowCounter = 0;
      for (let i = 0; i < 5; i++) createRow();
    });
  });
</script>
