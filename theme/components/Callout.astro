---
export interface Props {
  type?: 'info' | 'warning' | 'success' | 'conceptual';
  title?: string;
  icon?: string;
}

const { type = 'info', title, icon } = Astro.props;

const styles = {
  info: 'from-blue-500/10 to-indigo-500/10 border-indigo-400/30 text-indigo-900 dark:text-indigo-100',
  warning: 'from-amber-500/10 to-orange-500/10 border-orange-400/30 text-orange-900 dark:text-orange-100',
  success: 'from-emerald-500/10 to-teal-500/10 border-teal-400/30 text-teal-900 dark:text-teal-100',
  conceptual: 'from-primary-500/10 to-accent-500/10 border-primary-400/30 text-primary-900 dark:text-primary-100',
};

const icons = {
  info: `<svg class="w-6 h-6 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  warning: `<svg class="w-6 h-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>`,
  success: `<svg class="w-6 h-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  conceptual: `<svg class="w-6 h-6 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`,
};

const appliedStyle = styles[type] || styles.info;
const appliedIcon = icon || icons[type] || icons.info;
---

<div class={`my-10 relative overflow-hidden rounded-2xl border bg-gradient-to-br backdrop-blur-sm p-6 sm:p-8 shadow-sm ${appliedStyle}`}>
  <div class="absolute -top-10 -right-10 w-32 h-32 bg-white/10 dark:bg-black/10 rounded-full blur-2xl"></div>
  <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-white/10 dark:bg-black/10 rounded-full blur-2xl"></div>
  
  <div class="relative z-10 flex gap-4 sm:gap-6 items-start">
    <div class="flex-shrink-0 mt-1 bg-white/60 dark:bg-black/20 p-2 rounded-xl backdrop-blur-md border border-white/20 shadow-inner" set:html={appliedIcon} />
    <div class="flex-1">
      {title && <h4 class="text-lg font-bold mb-2 !mt-0 uppercase tracking-wide opacity-90">{title}</h4>}
      <div class="prose-p:!my-0 prose-p:!mb-4 last:prose-p:!mb-0 text-base leading-relaxed opacity-90">
        <slot />
      </div>
    </div>
  </div>
</div>
