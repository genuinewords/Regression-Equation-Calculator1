---
import { getLocalizedUrl } from 'theme/i18n/utils';
import navConfig from 'src/data/nav.json';
import type { MergedTranslations } from 'theme/i18n/types';

interface Props {
  locale: string;
  translations: MergedTranslations;
}

const { locale, translations } = Astro.props;
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full border-b border-surface-200/60 dark:border-surface-700/40 bg-white/80 dark:bg-surface-900/80 backdrop-blur-lg supports-[backdrop-filter]:bg-white/70 dark:supports-[backdrop-filter]:bg-surface-900/70 transition-shadow duration-300"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8 2xl:px-0 2xl:max-w-[1440px]">
    <a href={getLocalizedUrl('/', locale)} class="flex items-center gap-2.5 group" aria-label={translations.siteTitle}>
      <img src="/logo.svg" alt="" class="h-8 w-8 rounded-lg transition-transform duration-300 group-hover:scale-110" width="32" height="32" />
      <span class="text-lg font-bold bg-gradient-to-r from-primary-700 to-accent-600 dark:from-primary-400 dark:to-accent-400 bg-clip-text text-transparent">
        {translations.siteTitle}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {navConfig.headerNav.map((item) => {
        const label = translations.nav?.[item.label as keyof typeof translations.nav] ?? item.label;
        const href = item.href ? getLocalizedUrl(item.href, locale) : undefined;
        const children = (item as any).children;

        if (children && Array.isArray(children)) {
          return (
            <div class="relative group/dropdown">
              <button
                type="button"
                class="relative px-3 py-2 text-sm font-medium text-surface-600 dark:text-surface-300 transition-colors duration-200 hover:text-primary-600 dark:hover:text-primary-400 flex items-center gap-1 after:absolute after:bottom-0.5 after:left-3 after:right-3 after:h-0.5 after:rounded-full after:bg-accent-500 after:scale-x-0 after:origin-center after:transition-transform after:duration-300 hover:after:scale-x-100"
              >
                {label}
                <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover/dropdown:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="absolute top-full left-0 pt-2 opacity-0 pointer-events-none group-hover/dropdown:opacity-100 group-hover/dropdown:pointer-events-auto transition-all duration-200 -translate-y-1 group-hover/dropdown:translate-y-0">
                <div class="min-w-[220px] rounded-xl border border-surface-200 dark:border-surface-700 bg-white dark:bg-surface-800 shadow-xl dark:shadow-surface-950/60 backdrop-blur-lg py-2">
                  {children.map((child: any) => {
                    const childLabel = translations.nav?.[child.label as keyof typeof translations.nav] ?? child.label;
                    const childHref = getLocalizedUrl(child.href, locale);
                    return (
                      <a
                        href={childHref}
                        class="flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium text-surface-600 dark:text-surface-300 transition-colors duration-150 hover:bg-primary-50 dark:hover:bg-primary-900/30 hover:text-primary-700 dark:hover:text-primary-400"
                      >
                        <span class="w-1.5 h-1.5 rounded-full bg-primary-400 dark:bg-primary-500 flex-shrink-0"></span>
                        {childLabel}
                      </a>
                    );
                  })}
                </div>
              </div>
            </div>
          );
        }

        return (
          <a
            href={href}
            class="relative px-3 py-2 text-sm font-medium text-surface-600 dark:text-surface-300 transition-colors duration-200 hover:text-primary-600 dark:hover:text-primary-400 after:absolute after:bottom-0.5 after:left-3 after:right-3 after:h-0.5 after:rounded-full after:bg-accent-500 after:scale-x-0 after:origin-center after:transition-transform after:duration-300 hover:after:scale-x-100"
          >
            {label}
          </a>
        );
      })}

      <button
        id="theme-toggle"
        type="button"
        class="ml-2 flex items-center justify-center w-9 h-9 rounded-lg text-surface-500 dark:text-surface-400 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors duration-200"
        aria-label="Toggle dark mode"
      >
        <svg id="sun-icon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg id="moon-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </nav>

    <div class="flex items-center gap-1 md:hidden">
      <button
        id="theme-toggle-mobile"
        type="button"
        class="flex items-center justify-center w-9 h-9 rounded-lg text-surface-500 dark:text-surface-400 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors duration-200"
        aria-label="Toggle dark mode"
      >
        <svg class="sun-icon-m h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="moon-icon-m h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
      <button
        id="mobile-menu-toggle"
        class="relative flex items-center justify-center w-10 h-10 rounded-lg text-surface-600 dark:text-surface-300 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={translations.common?.menu ?? 'Menu'}
      >
        <svg id="hamburger-icon" class="h-6 w-6 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="h-6 w-6 absolute transition-transform duration-300 scale-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 z-40 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  ></div>

  <div
    id="mobile-menu"
    class="fixed top-0 right-0 z-50 h-full w-72 bg-white dark:bg-surface-900 shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out md:hidden overflow-y-auto"
    aria-hidden="true"
  >
    <div class="flex items-center justify-between p-4 border-b border-surface-200 dark:border-surface-700">
      <a href={getLocalizedUrl('/', locale)} class="flex items-center gap-2.5 mobile-nav-link">
        <img src="/logo.svg" alt="" class="h-7 w-7 rounded-lg" width="28" height="28" />
        <span class="text-base font-bold bg-gradient-to-r from-primary-700 to-accent-600 dark:from-primary-400 dark:to-accent-400 bg-clip-text text-transparent">
          {translations.siteTitle}
        </span>
      </a>
      <button
        id="mobile-menu-close"
        class="flex items-center justify-center w-9 h-9 rounded-lg text-surface-500 dark:text-surface-400 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors"
        aria-label={translations.common?.close ?? 'Close'}
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="flex flex-col p-4 gap-1" aria-label="Mobile navigation">
      {navConfig.headerNav.map((item) => {
        const label = translations.nav?.[item.label as keyof typeof translations.nav] ?? item.label;
        const href = item.href ? getLocalizedUrl(item.href, locale) : undefined;
        const children = (item as any).children;

        if (children && Array.isArray(children)) {
          return (
            <div class="mobile-tools-group">
              <button
                type="button"
                class="mobile-tools-toggle w-full flex items-center justify-between px-4 py-3 rounded-xl text-surface-700 dark:text-surface-300 font-medium transition-colors duration-200 hover:bg-primary-50 dark:hover:bg-primary-900/30 hover:text-primary-700 dark:hover:text-primary-400"
              >
                <span class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-500 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  {label}
                </span>
                <svg class="mobile-tools-chevron w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="mobile-tools-subnav hidden pl-4 py-1 flex flex-col gap-0.5">
                {children.map((child: any) => {
                  const childLabel = translations.nav?.[child.label as keyof typeof translations.nav] ?? child.label;
                  const childHref = getLocalizedUrl(child.href, locale);
                  return (
                    <a
                      href={childHref}
                      class="mobile-nav-link flex items-center gap-2.5 px-4 py-2.5 rounded-lg text-sm text-surface-600 dark:text-surface-400 font-medium transition-colors duration-200 hover:bg-primary-50 dark:hover:bg-primary-900/30 hover:text-primary-700 dark:hover:text-primary-400"
                    >
                      <span class="w-1 h-1 rounded-full bg-primary-400 dark:bg-primary-500 flex-shrink-0"></span>
                      {childLabel}
                    </a>
                  );
                })}
              </div>
            </div>
          );
        }

        return (
          <a
            href={href}
            class="mobile-nav-link flex items-center px-4 py-3 rounded-xl text-surface-700 dark:text-surface-300 font-medium transition-colors duration-200 hover:bg-primary-50 dark:hover:bg-primary-900/30 hover:text-primary-700 dark:hover:text-primary-400"
          >
            {label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');
  const closeBtn = document.getElementById('mobile-menu-close');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileLinks = menu?.querySelectorAll('.mobile-nav-link');

  function openMenu() {
    menu?.classList.remove('translate-x-full');
    menu?.classList.add('translate-x-0');
    menu?.setAttribute('aria-hidden', 'false');
    overlay?.classList.remove('opacity-0', 'pointer-events-none');
    overlay?.classList.add('opacity-100', 'pointer-events-auto');
    toggle?.setAttribute('aria-expanded', 'true');
    hamburger?.classList.add('scale-0');
    closeIcon?.classList.remove('scale-0');
    closeIcon?.classList.add('scale-100');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('translate-x-full');
    menu?.classList.remove('translate-x-0');
    menu?.setAttribute('aria-hidden', 'true');
    overlay?.classList.add('opacity-0', 'pointer-events-none');
    overlay?.classList.remove('opacity-100', 'pointer-events-auto');
    toggle?.setAttribute('aria-expanded', 'false');
    hamburger?.classList.remove('scale-0');
    closeIcon?.classList.add('scale-0');
    closeIcon?.classList.remove('scale-100');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);

  mobileLinks?.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  document.querySelectorAll('.mobile-tools-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const group = btn.closest('.mobile-tools-group');
      const subnav = group?.querySelector('.mobile-tools-subnav');
      const chevron = btn.querySelector('.mobile-tools-chevron');
      if (subnav) {
        subnav.classList.toggle('hidden');
        chevron?.classList.toggle('rotate-180');
      }
    });
  });
</script>

<script>
  function initThemeToggle(btnId: string, sunClass: string, moonClass: string) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    const sun = btn.querySelector('.' + sunClass) as HTMLElement | null;
    const moon = btn.querySelector('.' + moonClass) as HTMLElement | null;

    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      sun?.classList.toggle('hidden', !isDark);
      sun?.classList.toggle('block', isDark);
      moon?.classList.toggle('hidden', isDark);
      moon?.classList.toggle('block', !isDark);
    }

    updateIcons();

    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcons();
      document.querySelectorAll('[data-theme-sync]').forEach((el) => {
        (el as HTMLElement).dispatchEvent(new CustomEvent('themechange', { detail: { dark: isDark } }));
      });
    });
  }

  initThemeToggle('theme-toggle', 'sun-icon', 'moon-icon');
  initThemeToggle('theme-toggle-mobile', 'sun-icon-m', 'moon-icon-m');
</script>
