---
import 'src/styles/global.css';
import Header from 'theme/components/Header.astro';
import Footer from 'theme/components/Footer.astro';
import siteConfig from 'src/data/site-config.json';
import navConfig from 'src/data/nav.json';
import socialConfig from 'src/data/social.json';
import { mergeTranslations, getDirection, getLocaleOgLocale } from 'theme/i18n/utils';
import type { MergedTranslations } from 'theme/i18n/types';

interface Props {
  title: string;
  description: string;
  locale?: string;
  canonicalUrl?: string;
  isHomePage?: boolean;
  isAboutPage?: boolean;
  isContactPage?: boolean;
}

const {
  title,
  description,
  locale = 'en',
  canonicalUrl,
  isHomePage = false,
  isAboutPage = false,
  isContactPage = false,
} = Astro.props;

const translations: MergedTranslations = await mergeTranslations(locale);
const direction = getDirection(locale);
const ogLocale = getLocaleOgLocale(locale);
const fullTitle = title === siteConfig.defaultTitle ? title : `${title} | ${siteConfig.siteName}`;
const resolvedCanonical = canonicalUrl ?? new URL(Astro.url.pathname, siteConfig.siteUrl).href;
const ogImageUrl = new URL(siteConfig.ogImage, siteConfig.siteUrl).href;

const sameAs = Object.values(socialConfig).filter((url): url is string => Boolean(url));

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteConfig.siteName,
  url: siteConfig.siteUrl,
  legalName: siteConfig.legalName,
  logo: {
    '@type': 'ImageObject',
    url: new URL('/logo.svg', siteConfig.siteUrl).href,
  },
  description: siteConfig.description,
  sameAs,
};

const navSchema = {
  '@context': 'https://schema.org',
  '@type': 'SiteNavigationElement',
  name: navConfig.headerNav.map((item) => translations.nav?.[item.label as keyof typeof translations.nav] ?? item.label),
  url: navConfig.headerNav.map((item) => new URL(item.href === '/' ? '/' : item.href, siteConfig.siteUrl).href),
};

let conditionalSchema: Record<string, any> | null = null;
if (isAboutPage) {
  conditionalSchema = {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: title,
    description,
    url: resolvedCanonical,
  };
} else if (isContactPage) {
  conditionalSchema = {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: title,
    description,
    url: resolvedCanonical,
  };
}

const websiteSchema = isHomePage
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: siteConfig.siteName,
      url: siteConfig.siteUrl,
      description: siteConfig.description,
    }
  : null;
---

<!doctype html>
<html lang={locale} dir={direction}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function(){var t=localStorage.getItem('theme');if(t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}})();
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />

    <link rel="icon" type="image/svg+xml" href={siteConfig.favicon} />
    <link rel="icon" href="/favicon.ico" />

    {siteConfig.googleSiteVerification && (
      <meta name="google-site-verification" content={siteConfig.googleSiteVerification} />
    )}
    {siteConfig.bingVerification && (
      <meta name="msvalidate.01" content={siteConfig.bingVerification} />
    )}
    {siteConfig.yandexVerification && (
      <meta name="yandex-verification" content={siteConfig.yandexVerification} />
    )}

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(siteConfig.ogImageWidth)} />
    <meta property="og:image:height" content={String(siteConfig.ogImageHeight)} />
    <meta property="og:image:alt" content={siteConfig.siteName} />
    <meta property="og:type" content={isHomePage ? 'website' : 'article'} />

    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(navSchema)} />
    {conditionalSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(conditionalSchema)} />
    )}
    {websiteSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    )}
  </head>
  <body class="bg-gradient-to-br from-surface-50 via-white to-primary-50/20 dark:from-surface-950 dark:via-surface-900 dark:to-primary-950/40 min-h-screen">
    <Header locale={locale} translations={translations} />
    <main class="min-h-screen">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 2xl:px-0 2xl:max-w-[1440px]">
        <slot />
      </div>
    </main>
    <Footer locale={locale} translations={translations} />
  </body>
</html>
